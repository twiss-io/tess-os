# ---------------------------------------------------------------------------
# Vault constants
# ---------------------------------------------------------------------------

VAULT_DIR = ".claude/vault"
VAULT_BLOB = ".claude/vault/vault.age"
VAULT_REGISTRY = ".claude/vault/vault.registry.json"
VAULT_GITKEEP = ".claude/vault/.gitkeep"
VAULT_VERSION = 1

# Keychain service/account identifiers for macOS `security` and Linux secret-tool
_KEYCHAIN_SERVICE = "tess-vault-identity"
_KEYCHAIN_ACCOUNT = "tess-vault"

# Global (cross-project) vault config dir — outside any repo, outside iCloud
_GLOBAL_VAULT_DIR = Path.home() / ".config" / "tess" / "vault"
_GLOBAL_IDENTITY_FILE = _GLOBAL_VAULT_DIR / "identity.age"

# Secret-shaped patterns for dispatch content scan (Cyra c)
# Used by both vault-dispatch-scan.py hook and vault scan
VAULT_SECRET_PATTERNS = [
    r"-----BEGIN (?:RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----",
    r"ghp_[A-Za-z0-9]{36,}",
    r"gho_[A-Za-z0-9]{36,}",
    r"ghs_[A-Za-z0-9]{36,}",
    r"ghr_[A-Za-z0-9]{36,}",
    r"github_pat_[A-Za-z0-9_]{22,}",
    r"sk_live_[A-Za-z0-9]{20,}",
    r"pk_live_[A-Za-z0-9]{20,}",
    r"xox[bpoa]-[0-9A-Za-z-]{20,}",
    r"AKIA[0-9A-Z]{16}",
    r"AGE-SECRET-KEY-[A-Z0-9]{50,}",
    r"(?:api[_-]?key|secret|token|password)\s*[=:]\s*[\"']?[A-Za-z0-9+/=_\-\.]{20,}",
]


# ---------------------------------------------------------------------------
# Vault crypto backend — pyrage preferred, age/rage CLI fallback
# ---------------------------------------------------------------------------

def _vault_check_crypto() -> str:
    """
    Detect available crypto backend. Returns 'pyrage', 'age', or 'rage'.
    Exits with a clear install message if none available.
    """
    try:
        import pyrage as _pr  # noqa: F401
        return "pyrage"
    except ImportError:
        pass
    for cli in ("age", "rage"):
        if shutil.which(cli):
            return cli
    sys.exit(
        "tessctl vault: no age crypto backend found.\n\n"
        "  Preferred (pure Python, no binary required):\n"
        "    pip install pyrage\n\n"
        "  Alternative (Go binary):\n"
        "    macOS:  brew install age\n"
        "    Linux:  apt install age  OR  snap install age  OR  go install filippo.io/age/cmd/age@latest\n\n"
        "  After installing, re-run your vault command.\n"
        "  See: https://github.com/FiloSottile/age"
    )


def _vault_generate_identity_pyrage() -> tuple[str, str]:
    """Generate age X25519 identity using pyrage. Returns (private_str, public_str)."""
    import pyrage
    identity = pyrage.x25519.Identity.generate()
    return str(identity), str(identity.to_public())


def _vault_generate_identity_cli(cli: str) -> tuple[str, str]:
    """
    Generate age identity using the age-keygen / rage-keygen binary.
    The keygen binary is a separate executable from the age/rage encrypt/decrypt CLI;
    `age keygen` is not a valid subcommand.  Probe for age-keygen then rage-keygen.
    Returns (private_str, public_str).
    """
    # age-keygen (FiloSottile age) and rage-keygen (str4d rage) print to stdout:
    #   # created: <date>
    #   # public key: age1...
    #   AGE-SECRET-KEY-...
    keygen_bin = shutil.which("age-keygen") or shutil.which("rage-keygen")
    if not keygen_bin:
        sys.exit(
            f"tessctl vault: age/rage CLI detected ({cli}) but key-generation binary not found.\n"
            f"  age-keygen is a separate binary (FiloSottile age ships it alongside age).\n"
            f"  Install: brew install age  OR  pip install pyrage (preferred, no binary needed)"
        )
    result = subprocess.run([keygen_bin], capture_output=True, text=True)
    if result.returncode != 0:
        sys.exit(f"tessctl vault: failed to generate age identity: {result.stderr}")
    private_str = public_str = ""
    for line in result.stdout.splitlines():
        line = line.strip()
        if line.startswith("AGE-SECRET-KEY-"):
            private_str = line
        elif line.startswith("# public key:"):
            public_str = line.split(":", 1)[1].strip()
        elif line.startswith("age1"):
            public_str = line
    if not private_str or not public_str:
        sys.exit(f"tessctl vault: could not parse age keygen output:\n{result.stdout}")
    return private_str, public_str


def _vault_generate_identity(backend: str) -> tuple[str, str]:
    """Generate identity. Returns (private_key_str, public_key_str)."""
    if backend == "pyrage":
        return _vault_generate_identity_pyrage()
    return _vault_generate_identity_cli(backend)


def _vault_encrypt(backend: str, plaintext: bytes, public_key_str: str) -> bytes:
    """Encrypt plaintext bytes to an age-armored blob for the given public key."""
    if backend == "pyrage":
        import pyrage
        recipient = pyrage.x25519.Recipient.from_str(public_key_str)
        return pyrage.encrypt(plaintext, [recipient], armored=True)
    # CLI path: pipe through age -r <recipient> -a
    cli = backend
    result = subprocess.run(
        [cli, "-r", public_key_str, "-a"],
        input=plaintext, capture_output=True
    )
    if result.returncode != 0:
        sys.exit(f"tessctl vault: encryption failed: {result.stderr.decode('utf-8', errors='replace')}")
    return result.stdout


def _vault_decrypt(backend: str, ciphertext: bytes, private_key_str: str) -> bytes:
    """Decrypt an age-armored blob using the private identity."""
    if backend == "pyrage":
        import pyrage
        identity = pyrage.x25519.Identity.from_str(private_key_str)
        return pyrage.decrypt(ciphertext, [identity])
    # CLI path: write identity to a 0600 temp inside the 0700 vault config dir
    # (not world-traversable /tmp) to match the custody posture of stored identities.
    cli = backend
    _GLOBAL_VAULT_DIR.mkdir(parents=True, exist_ok=True)
    try:
        os.chmod(str(_GLOBAL_VAULT_DIR), 0o700)
    except OSError:
        pass
    tmp_fd, id_tmp = tempfile.mkstemp(dir=str(_GLOBAL_VAULT_DIR), suffix=".age", prefix=".tess_dec_tmp_")
    try:
        with os.fdopen(tmp_fd, "w") as f:
            f.write(private_key_str + "\n")
        os.chmod(id_tmp, 0o600)
        result = subprocess.run(
            [cli, "--decrypt", "-i", id_tmp],
            input=ciphertext, capture_output=True
        )
    finally:
        try:
            os.unlink(id_tmp)
        except OSError:
            pass
    if result.returncode != 0:
        sys.exit(
            f"tessctl vault: decryption failed. Wrong identity? "
            f"Details: {result.stderr.decode('utf-8', errors='replace')}"
        )
    return result.stdout


# ---------------------------------------------------------------------------
# Identity custody — keychain (desktop) or file/env (headless)
# ---------------------------------------------------------------------------

def _vault_store_identity_keychain(private_key_str: str) -> bool:
    """
    Store the private key in the OS keychain.
    macOS: `security add-generic-password`
    Returns True on success, False if keychain unavailable.
    """
    if sys.platform == "darwin":
        r = subprocess.run(
            ["security", "add-generic-password",
             "-U",                      # update if exists
             "-s", _KEYCHAIN_SERVICE,
             "-a", _KEYCHAIN_ACCOUNT,
             "-w", private_key_str],
            capture_output=True
        )
        return r.returncode == 0
    # Linux: try secret-tool
    if shutil.which("secret-tool"):
        r = subprocess.run(
            ["secret-tool", "store",
             "--label", "tess-vault-identity",
             "service", _KEYCHAIN_SERVICE,
             "account", _KEYCHAIN_ACCOUNT],
            input=private_key_str.encode(),
            capture_output=True
        )
        return r.returncode == 0
    return False


def _vault_load_identity_keychain() -> str | None:
    """
    Retrieve the private key from the OS keychain.
    Returns the private key string, or None if not found.
    NEVER prints or logs the key.
    """
    if sys.platform == "darwin":
        r = subprocess.run(
            ["security", "find-generic-password",
             "-s", _KEYCHAIN_SERVICE,
             "-a", _KEYCHAIN_ACCOUNT,
             "-w"],
            capture_output=True
        )
        if r.returncode == 0:
            return r.stdout.decode("utf-8").strip() or None
        return None
    # Linux: secret-tool
    if shutil.which("secret-tool"):
        r = subprocess.run(
            ["secret-tool", "lookup",
             "service", _KEYCHAIN_SERVICE,
             "account", _KEYCHAIN_ACCOUNT],
            capture_output=True
        )
        if r.returncode == 0:
            return r.stdout.decode("utf-8").strip() or None
    return None


def _vault_identity_file_write(private_key_str: str, path: Path) -> None:
    """Write identity to file at 0600. Never prints the value."""
    path.parent.mkdir(parents=True, exist_ok=True)
    # Atomic: write to temp, chmod, rename
    tmp_fd, tmp_path = tempfile.mkstemp(dir=str(path.parent), prefix=".tess_id_tmp_")
    try:
        with os.fdopen(tmp_fd, "w") as fh:
            fh.write(private_key_str + "\n")
        os.chmod(tmp_path, 0o600)
        os.replace(tmp_path, str(path))
    except Exception:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise
    # Ensure the dir is 0700
    try:
        os.chmod(str(path.parent), 0o700)
    except OSError:
        pass


def _vault_load_identity(root: Path) -> str:
    """
    Load the age private identity. Resolution order:
    1. TESS_VAULT_IDENTITY env var (headless / CI)
    2. OS keychain (macOS security / Linux secret-tool)
    3. ~/.config/tess/vault/identity.age file (0600)

    Returns the private key string (AGE-SECRET-KEY-...).
    Exits if no identity found.
    NEVER logs or prints the key.
    """
    # 1. Env override (headless / CI / droplet)
    env_id = os.environ.get("TESS_VAULT_IDENTITY", "").strip()
    if env_id:
        if not env_id.startswith("AGE-SECRET-KEY-"):
            sys.exit(
                "tessctl vault: TESS_VAULT_IDENTITY is set but does not look like "
                "an age private key (expected AGE-SECRET-KEY-...). "
                "Check the value."
            )
        return env_id

    # 2. OS keychain
    keychain_key = _vault_load_identity_keychain()
    if keychain_key:
        return keychain_key

    # 3. Identity file
    if _GLOBAL_IDENTITY_FILE.exists():
        mode = stat.S_IMODE(_GLOBAL_IDENTITY_FILE.stat().st_mode)
        if mode & 0o077:
            sys.exit(
                f"tessctl vault: identity file {_GLOBAL_IDENTITY_FILE} has unsafe permissions "
                f"({oct(mode)}). Fix: chmod 600 {_GLOBAL_IDENTITY_FILE}"
            )
        return _GLOBAL_IDENTITY_FILE.read_text(encoding="utf-8").strip()

    sys.exit(
        "tessctl vault: no identity found.\n"
        "  Run `tessctl vault init` to set up the vault, or:\n"
        "  - Headless/CI: set TESS_VAULT_IDENTITY=<AGE-SECRET-KEY-...>\n"
        "  - Desktop:     run `tessctl vault init` to store in OS keychain\n"
        "  - File:        save your private key to ~/.config/tess/vault/identity.age (chmod 600)"
    )


def _vault_load_public_key(root: Path) -> str:
    """Load the recipients file to get the public key for encryption."""
    recip_path = root / VAULT_DIR / "vault.recipients"
    if not recip_path.exists():
        sys.exit(
            f"tessctl vault: recipients file not found at {recip_path}.\n"
            "  Run `tessctl vault init` to create the vault."
        )
    content = recip_path.read_text(encoding="utf-8").strip()
    # First non-comment line is the public key
    for line in content.splitlines():
        line = line.strip()
        if line and not line.startswith("#") and line.startswith("age1"):
            return line
    sys.exit(
        f"tessctl vault: no valid age public key found in {recip_path}.\n"
        "  Expected a line starting with 'age1...' (the X25519 public key)."
    )


# ---------------------------------------------------------------------------
# Vault blob I/O
# ---------------------------------------------------------------------------

def _vault_blob_exists(root: Path) -> bool:
    return (root / VAULT_BLOB).exists()


def _vault_read_blob(root: Path) -> dict:
    """
    Decrypt the vault blob and return the in-memory dict.
    Structure: {"version": 1, "entries": {"ref": {"value": "...", "meta": {...}}}}
    Returns {"version": 1, "entries": {}} for a missing blob (new vault).
    NEVER logs or prints any entry value.
    """
    blob_path = root / VAULT_BLOB
    if not blob_path.exists():
        return {"version": VAULT_VERSION, "entries": {}}

    backend = _vault_check_crypto()
    private_key = _vault_load_identity(root)
    ciphertext = blob_path.read_bytes()
    try:
        plaintext = _vault_decrypt(backend, ciphertext, private_key)
    except SystemExit:
        raise
    except Exception as e:
        # Interpolate type name only — the exception message here comes from the
        # age CLI or pyrage and should not contain plaintext, but we stay cautious.
        sys.exit(f"tessctl vault: failed to decrypt vault: {type(e).__name__}")

    try:
        data = json.loads(plaintext.decode("utf-8"))
    except (json.JSONDecodeError, UnicodeDecodeError) as e:
        # These exceptions are computed over decrypted bytes; interpolate type only
        # to avoid any risk of vault contents surfacing in error output.
        sys.exit(
            f"tessctl vault: vault blob is not valid JSON after decryption "
            f"({type(e).__name__}). The blob may be corrupt or encrypted to a different identity."
        )

    if not isinstance(data, dict):
        sys.exit("tessctl vault: vault blob has unexpected structure (not a dict).")

    if "entries" not in data:
        data["entries"] = {}

    return data


def _vault_write_blob(root: Path, data: dict) -> None:
    """
    Re-encrypt the in-memory dict and atomically write to vault.age (0600).
    Uses a temp sibling file + os.replace() so the vault is never partially written.
    NEVER logs or prints any entry value.
    """
    blob_path = root / VAULT_BLOB
    blob_path.parent.mkdir(parents=True, exist_ok=True)
    try:
        os.chmod(str(blob_path.parent), 0o700)
    except OSError:
        pass

    public_key = _vault_load_public_key(root)
    backend = _vault_check_crypto()

    plaintext = json.dumps(data, indent=2, ensure_ascii=False, sort_keys=True).encode("utf-8")
    ciphertext = _vault_encrypt(backend, plaintext, public_key)

    # Atomic write: 0600 temp → os.replace
    tmp_fd, tmp_path = tempfile.mkstemp(
        dir=str(blob_path.parent), prefix=".tess_vault_tmp_"
    )
    try:
        with os.fdopen(tmp_fd, "wb") as fh:
            fh.write(ciphertext)
        os.chmod(tmp_path, 0o600)
        os.replace(tmp_path, str(blob_path))
    except Exception:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise


def _vault_mask_value(value: str, ref: str) -> str:
    """Return a masked display string. Shows prefix + dots + suffix."""
    if len(value) <= 6:
        return "•" * len(value)
    prefix = value[:4]
    suffix = value[-4:]
    return f"{prefix}{'•' * 8}{suffix}  (ref: {ref})"


def _vault_parse_ref(ref: str) -> tuple[str, str]:
    """Parse 'service/key' into (service, key). Validates format."""
    # Strip vault:// prefix if present
    if ref.startswith("vault://"):
        ref = ref[len("vault://"):]
    parts = ref.split("/", 1)
    if len(parts) != 2 or not parts[0] or not parts[1]:
        sys.exit(
            f"tessctl vault: invalid ref {ref!r}. "
            "Expected format: service/key (e.g. github/token)"
        )
    # Validate characters
    allowed = re.compile(r'^[a-zA-Z0-9_\-\.]+$')
    for part in parts:
        if not allowed.match(part):
            sys.exit(
                f"tessctl vault: ref component {part!r} contains invalid characters. "
                "Use letters, digits, underscores, hyphens, and dots only."
            )
    return parts[0], parts[1]


# ---------------------------------------------------------------------------
# Vault subcommands
# ---------------------------------------------------------------------------

def _vault_cmd_init(args, root: Path) -> None:
    """
    tess vault init — create vault, generate age identity, store key in keychain.
    Idempotent: re-running does not overwrite existing keys.

    Also installs git pre-commit + pre-push hooks (extended secret patterns).
    """
    headless = getattr(args, "headless", False)
    vault_dir = root / VAULT_DIR

    # Check crypto availability first (exits with install instructions if missing)
    backend = _vault_check_crypto()
    print(f"tessctl vault init: crypto backend = {backend}")

    # Create vault directory
    vault_dir.mkdir(parents=True, exist_ok=True)
    try:
        os.chmod(str(vault_dir), 0o700)
    except OSError:
        pass

    # .gitkeep (marks the dir as shippable scaffold)
    gitkeep_path = vault_dir / ".gitkeep"
    if not gitkeep_path.exists():
        gitkeep_path.write_text("# vault scaffold — blob and identity are gitignored\n", encoding="utf-8")
        print(f"  created {VAULT_GITKEEP}")

    # vault.registry.json scaffold (ships in public repo — no values)
    registry_path = vault_dir / "vault.registry.json"
    if not registry_path.exists():
        _vault_write_registry_scaffold(root)
        print(f"  created {VAULT_REGISTRY}")

    # Check for existing identity: vault.recipients is the authoritative "vault exists" marker.
    # If recipients exists (even without a blob), refuse to generate a new identity — doing so
    # would silently overwrite the recipients file and leave any existing .age blob undecryptable.
    # Require an explicit `rm .claude/vault/vault.recipients` (or --force/rekey) before reinit.
    recip_path = vault_dir / "vault.recipients"
    if recip_path.exists():
        print(
            "tessctl vault init: vault already initialized (vault.recipients exists).\n"
            "  To regenerate: rm .claude/vault/vault.recipients && tessctl vault init\n"
            "  WARNING: regenerating creates a new identity — migrate secrets first with vault rekey."
        )
        _vault_install_git_hooks(root)
        return

    # Generate new identity
    private_key, public_key = _vault_generate_identity(backend)
    print(f"  generated age X25519 identity (public: {public_key[:20]}...)")

    # Store private key (NEVER print or log it)
    if headless:
        _vault_identity_file_write(private_key, _GLOBAL_IDENTITY_FILE)
        print(f"  identity stored at {_GLOBAL_IDENTITY_FILE} (0600, headless mode)")
        print("  HEADLESS: also set TESS_VAULT_IDENTITY for CI/droplet environments.")
    else:
        stored_in_keychain = _vault_store_identity_keychain(private_key)
        if stored_in_keychain:
            ks = "macOS Keychain" if sys.platform == "darwin" else "OS secret-service"
            print(f"  identity stored in {ks} (service={_KEYCHAIN_SERVICE})")
        else:
            _vault_identity_file_write(private_key, _GLOBAL_IDENTITY_FILE)
            print(
                f"  keychain unavailable — identity stored at {_GLOBAL_IDENTITY_FILE} (0600).\n"
                f"  For headless/CI: set TESS_VAULT_IDENTITY env var."
            )

    # Write recipients file (public key — not secret)
    recip_path.write_text(
        f"# age public key for this vault\n"
        f"# Generated by tessctl vault init\n"
        f"{public_key}\n",
        encoding="utf-8",
    )
    print(f"  wrote vault.recipients (public key only)")

    # Create empty vault blob
    _vault_write_blob(root, {"version": VAULT_VERSION, "entries": {}})
    print(f"  created empty vault at {VAULT_BLOB}")

    # Install git hooks
    _vault_install_git_hooks(root)

    print(
        "\ntessctl vault init: complete.\n"
        "  Set secrets:   tessctl vault set github/token\n"
        "  Use in agent:  tess vault exec --ref github/token -- gh pr create ...\n"
        "  Audit:         tessctl vault doctor"
    )


def _vault_write_registry_scaffold(root: Path) -> None:
    """Write vault.registry.json scaffold (NEUTRAL EXAMPLE, no values — safe to commit).

    This ships in the public scaffold, so it must NOT describe any real operator
    stack (which services, agents, and MCP servers an install actually wires would
    leak the operator's footprint). It is a single neutral `example/api_key`
    service the operator replaces with their own as they onboard secrets.
    """
    scaffold = {
        "_doc": (
            "vault.registry.json — ECOSYSTEM catalog. NO VALUES. "
            "Describes services/refs/consumers/exposure. Safe to commit. "
            "This is a NEUTRAL EXAMPLE — replace it with your own services as you "
            "onboard secrets via `tessctl vault set`. See: conductor/vault.md"
        ),
        "services": {
            "example": {
                "keys": ["example/api_key"],
                "consumers": {"agents": ["YourAgent"], "mcp": ["your-mcp-server"]},
                "exposure": "host-env",
                "rotation": "https://example.com/account/api-tokens",
                "rotate_days": 90
            }
        }
    }
    registry_path = root / VAULT_REGISTRY
    registry_path.write_text(
        json.dumps(scaffold, indent=2, ensure_ascii=False) + "\n",
        encoding="utf-8",
    )


def _vault_install_git_hooks(root: Path) -> None:
    """
    Install vault-extended pre-commit and pre-push hooks into .git/hooks/.
    Extended patterns: *.age, .claude/vault/, clients/*/.vault/, *.env.json.
    Idempotent (v2-aware):
      - Skips only if the installed hook already carries the v2 marker.
      - Self-upgrades stale (v1 / unversioned) hooks — does NOT skip them.
      - Splices into any existing hook that has no vault guard at all.

    Pre-commit: scans staged files (git diff --cached).
    Pre-push:   reads stdin ref ranges (git protocol) and scans each pushed range.
    These are separate scripts — the pre-push uses stdin, not $1.

    Coexistence strategy (Finding 9 — never neuter the operator's own hook):
    the vault guard runs FIRST, but when a pre-existing hook is present the guard
    is spliced ABOVE it inside a containment subshell — `if ( <guard> ); then :;
    else exit $?; fi` — so that:
      * a secret/vault VIOLATION makes the subshell exit non-zero and is
        propagated (`exit $?`), BLOCKING the commit/push; while
      * a CLEAN result (including the early empty-staged exit) makes the subshell
        exit 0, and control FALLS THROUGH to the operator's original hook, which
        is preserved verbatim below a `# tess-vault-guard end` sentinel.
    The guard's `set -euo pipefail` stays inside the subshell, so the operator's
    hook (their own linter / secret-scanner) keeps its own shell semantics and is
    never silently voided by the guard's terminal `exit 0`.  A clear NOTICE is
    printed whenever a pre-existing hook is detected and spliced.
    """
    git_hooks_dir = root / ".git" / "hooks"
    if not git_hooks_dir.exists():
        print("  NOTE: .git/hooks/ not found — git hooks not installed (no git repo here?).")
        return

    _HOOK_MARKER_V2  = "# tess-vault-guard v2"   # current version — safe to skip
    _HOOK_MARKER_ANY = "# tess-vault-guard"        # catches v1 or unversioned → must upgrade

    # Shared secret-scan body (used in both hooks; operates on a file list in $STAGED).
    _SCAN_BODY = r"""
[ -z "$STAGED" ] && exit 0

VIOLATIONS=""

# Forbidden path shapes (vault/secret material)
while IFS= read -r file; do
  [ -z "$file" ] && continue
  case "$file" in
    *.age|*vault.age|*identity.age)
      VIOLATIONS="${VIOLATIONS}\n  VAULT/AGE FILE: $file" ;;
    .claude/vault/vault.age|.claude/vault/identity.age|.claude/vault/vault.recipients)
      VIOLATIONS="${VIOLATIONS}\n  VAULT FILE: $file" ;;
    clients/*/.vault/*)
      VIOLATIONS="${VIOLATIONS}\n  CLIENT VAULT: $file" ;;
    *.env.json)
      VIOLATIONS="${VIOLATIONS}\n  ENV-JSON (may contain secrets): $file" ;;
    .claude/tess-secrets/*)
      VIOLATIONS="${VIOLATIONS}\n  LEGACY SECRET FILE: $file" ;;
  esac
  case "$(basename "$file")" in
    id_rsa|id_ed25519|id_ecdsa|id_dsa|*.pem|*.key)
      VIOLATIONS="${VIOLATIONS}\n  PRIVATE KEY FILE: $file" ;;
  esac
done <<< "$STAGED"

# Content scan for secret patterns
while IFS= read -r file; do
  [ -z "$file" ] && continue
  [ -f "$file" ] || continue
  if grep -qE 'AGE-SECRET-KEY-[A-Z0-9]{50,}' "$file" 2>/dev/null; then
    VIOLATIONS="${VIOLATIONS}\n  AGE PRIVATE KEY in $file"
  fi
  if grep -qE '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----' "$file" 2>/dev/null; then
    VIOLATIONS="${VIOLATIONS}\n  PEM PRIVATE KEY in $file"
  fi
  if grep -qE '(ghp_|gho_|ghs_|ghr_)[A-Za-z0-9]{36,}|github_pat_[A-Za-z0-9_]{22,}' "$file" 2>/dev/null; then
    VIOLATIONS="${VIOLATIONS}\n  GITHUB TOKEN in $file"
  fi
  if grep -qE 'AKIA[0-9A-Z]{16}' "$file" 2>/dev/null; then
    VIOLATIONS="${VIOLATIONS}\n  AWS KEY in $file"
  fi
  if grep -qE '(sk_live_|pk_live_)[A-Za-z0-9]{20,}' "$file" 2>/dev/null; then
    VIOLATIONS="${VIOLATIONS}\n  STRIPE KEY in $file"
  fi
  if grep -qE '(xoxb-|xoxp-|xoxo-|xoxa-)[0-9A-Za-z-]{20,}' "$file" 2>/dev/null; then
    VIOLATIONS="${VIOLATIONS}\n  SLACK TOKEN in $file"
  fi
  if grep -qEi '(api[_-]?key|secret[_-]?key|password|token)\s*[:=]\s*["\x27][A-Za-z0-9+/=_-]{20,}' "$file" 2>/dev/null; then
    VIOLATIONS="${VIOLATIONS}\n  POSSIBLE SECRET in $file"
  fi
done <<< "$STAGED"

if [ -n "$VIOLATIONS" ]; then
  printf 'TESS VAULT GUARD — BLOCKED:\n%b\n\nReview files. Use vault:// refs, not raw values.\n' "$VIOLATIONS" >&2
  exit 1
fi
"""

    pre_commit_script = r"""#!/usr/bin/env bash
# tess-vault-guard v2
# Pre-commit hook: scan staged files for secrets and vault material.
# Installed by `tessctl vault init`.

set -euo pipefail

if ! git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
  exit 0
fi

STAGED="$(git diff --cached --name-only 2>/dev/null || true)"
""" + _SCAN_BODY + "exit 0\n"

    # Pre-push hook: reads stdin per git protocol.
    # Git calls: pre-push <remote-name> <remote-url>
    # Stdin lines: <local-ref> <local-sha> <remote-ref> <remote-sha>
    # We collect all files changed between remotesha..localsha across all pushed refs.
    pre_push_script = r"""#!/usr/bin/env bash
# tess-vault-guard v2
# Pre-push hook: scan commits being pushed for secrets and vault material.
# Installed by `tessctl vault init`.
# Git passes: $1=<remote-name> $2=<remote-url>; ref ranges on stdin.

set -euo pipefail

if ! git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
  exit 0
fi

# Read ref lines from stdin: <localref> <localsha> <remoteref> <remotesha>
# Accumulate unique changed file names across all pushed ranges.
STAGED=""
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$local_sha" ] && continue
  # All-zeros remote sha means the ref is new (no prior remote commits).
  if echo "$remote_sha" | grep -qE '^0+$'; then
    # New branch/tag: scan ALL commits including the very first by diffing against
    # git's empty-tree object (4b825dc6...).  Using rev-list --max-parents=0 gives
    # the root commit SHA, but root..local produces an empty diff — the root commit's
    # own files are silently skipped.  The empty-tree diff covers every file ever added.
    files="$(git diff --name-only 4b825dc642cb6eb9a060e54bf8d69288fbee4904.."$local_sha" 2>/dev/null || true)"
  else
    files="$(git diff --name-only "${remote_sha}..${local_sha}" 2>/dev/null || true)"
  fi
  if [ -n "$files" ]; then
    STAGED="${STAGED}${files}"$'\n'
  fi
done

# Deduplicate
STAGED="$(printf '%s' "$STAGED" | sort -u)"
""" + _SCAN_BODY + "exit 0\n"

    import re as _re

    def _guard_body_for_splice(hook_script: str, feeds_stdin: bool = False) -> str:
        """
        Build a guard block to place ABOVE a pre-existing user hook (Finding 9).

        Unlike the standalone hook script — whose terminal `exit 0` would stop the
        whole hook and silently neuter the operator's own pre-existing hook — this
        form runs the guard inside a containment subshell:
          * a VIOLATION makes the subshell exit non-zero, propagated via `exit $?`
            so the commit/push is BLOCKED;
          * a CLEAN result (incl. the early empty-staged exit) makes the subshell
            exit 0, so control FALLS THROUGH to the operator's hook below.
        `set -euo pipefail` stays contained inside the subshell.

        feeds_stdin=True (pre-push, Reid HIGH — pre-push stdin):
            git delivers the ref ranges to scan on STDIN, and the guard's
            `while read` loop consumes ALL of it. If we let the guard read stdin
            directly, a coexisting operator pre-push hook below would be STARVED —
            it would see EOF instead of the ref lines it needs. So we capture stdin
            ONCE, byte-exact (the `; printf x` … `%x}` idiom preserves the trailing
            newline so the last/only ref line is not dropped by `while read`), feed
            a copy to the guard via a pipe, and the caller re-feeds the SAME bytes
            to the operator's hook (see _splice_operator_rest).

        Returns the block WITHOUT a leading shebang (the caller supplies it).
        The block carries the v2 marker (so it stays detectable/idempotent) and a
        `# tess-vault-guard end` sentinel that delimits it from the user hook.
        """
        lines = hook_script.splitlines()[1:]  # drop the shebang
        # Drop the leading marker/description comment + blank lines so the
        # subshell body starts at the first real statement (`set -euo pipefail`).
        while lines and (lines[0].startswith("#") or lines[0].strip() == ""):
            lines.pop(0)
        inner = "\n".join(lines).rstrip("\n")
        header = (
            "# tess-vault-guard v2\n"
            "# Spliced above a pre-existing hook by `tessctl vault init`.\n"
            "# Guard runs first inside a containment subshell: it BLOCKS on a\n"
            "# secret/vault violation and FALLS THROUGH on a clean result so the\n"
            "# operator's pre-existing hook (preserved below) still runs.\n"
        )
        if feeds_stdin:
            return (
                header
                + "# Capture stdin once (byte-exact) so the guard AND the operator's\n"
                + "# pre-existing hook below both receive the pushed ref ranges.\n"
                + 'GUARD_STDIN="$(cat; printf x)"; GUARD_STDIN="${GUARD_STDIN%x}"\n'
                + "if printf '%s' \"$GUARD_STDIN\" | (\n"
                + f"{inner}\n"
                + "); then :; else\n"
                + "  exit $?\n"
                + "fi\n"
                + "# tess-vault-guard end — pre-existing hook follows (fed the same stdin)\n"
            )
        return (
            header
            + "if (\n"
            + f"{inner}\n"
            + "); then :; else\n"
            + "  exit $?\n"
            + "fi\n"
            + "# tess-vault-guard end — pre-existing hook follows\n"
        )

    def _splice_operator_rest(hook_name: str, rest: str) -> str:
        """
        Wrap the operator's pre-existing hook content so it runs after a clean
        guard fall-through. For pre-push (Reid HIGH), the operator's hook is fed
        the SAME stdin the guard captured (`printf '%s' "$GUARD_STDIN" | { … }`)
        so it is not starved of the ref lines git put on stdin. For every other
        hook (e.g. pre-commit, which reads no stdin) the content is preserved
        verbatim.
        """
        # Nothing to run (operator hook was just a shebang / blank lines): emitting
        # an empty brace group `printf ... | { }` below would be a bash SYNTAX
        # ERROR that bricks the installed hook, so return the (empty) rest as-is.
        if not rest.strip():
            return rest
        if hook_name == "pre-push":
            return (
                "printf '%s' \"$GUARD_STDIN\" | {\n"
                + rest.rstrip("\n") + "\n"
                + "}\n"
            )
        return rest

    def _strip_guard_block(text: str) -> tuple:
        """
        Parse a hook file that already contains a tess-vault-guard block (any version).
        Returns (pre_shebang, pre_existing_rest) where:
          - pre_shebang: the shebang line if one was present, else ""
          - pre_existing_rest: any content that came AFTER the guard block
            (a pre-existing hook the guard was spliced above), possibly "".

        Two on-disk forms are recognised:
          A. Current splice form — the guard ends at an explicit
             `# tess-vault-guard end` sentinel (the operator's hook follows it).
          B. Legacy form — the guard body ends at its terminal `fi\\nexit 0\\n`.
        """
        # Form A: explicit end sentinel (current splice format).
        m = _re.match(
            r'(#![^\n]*\n)?'                       # group 1: optional shebang
            r'# tess-vault-guard[^\n]*\n'          # marker line (any version)
            r'.*?'                                  # guard body (non-greedy)
            r'# tess-vault-guard end[^\n]*\n'      # explicit end sentinel
            r'\n?'                                  # optional blank separator
            r'(.*)',                                # group 2: pre-existing rest
            text,
            flags=_re.DOTALL,
        )
        if m:
            return (m.group(1) or ""), (m.group(2) or "")
        # Form B: legacy guard terminated by `fi\nexit 0\n`.
        m = _re.match(
            r'(#![^\n]*\n)?'                  # group 1: optional shebang
            r'(?:# tess-vault-guard[^\n]*\n'  # marker line (any version)
            r'.*?'                             # guard body (non-greedy)
            r'fi\nexit 0\n)'                  # guard terminal
            r'\n?'                             # optional blank separator line
            r'(.*)',                           # group 2: pre-existing rest (may be empty)
            text,
            flags=_re.DOTALL,
        )
        if m:
            return (m.group(1) or ""), (m.group(2) or "")
        # Fallback: treat as standalone guard with no pre-existing content
        return "", ""

    hook_scripts = {
        "pre-commit": pre_commit_script,
        "pre-push": pre_push_script,
    }

    for hook_name, hook_script in hook_scripts.items():
        hook_path = git_hooks_dir / hook_name
        if hook_path.exists():
            existing = hook_path.read_text(encoding="utf-8", errors="replace")

            if _HOOK_MARKER_V2 in existing:
                # Already current — nothing to do
                print(f"  git hook {hook_name}: already v2 (skipped)")
                continue

            if _HOOK_MARKER_ANY in existing:
                # Stale v1 / unversioned marker — self-upgrade to v2
                print(f"  git hook {hook_name}: upgrading stale guard to v2 ...")
                pre_shebang, pre_existing_rest = _strip_guard_block(existing)

                if pre_existing_rest.strip():
                    # Had a pre-existing operator hook below the old guard.  Re-splice
                    # with the containment form so that hook STILL RUNS (Finding 9:
                    # the old prepend form's terminal `exit 0` left it as dead code).
                    spliced = _guard_body_for_splice(hook_script, feeds_stdin=(hook_name == "pre-push"))
                    shebang = pre_shebang or "#!/usr/bin/env bash\n"
                    updated = shebang + spliced + "\n" + _splice_operator_rest(hook_name, pre_existing_rest)
                    print(
                        f"  NOTICE: pre-existing {hook_name} hook detected — the v2 vault "
                        f"guard now FALLS THROUGH to it (your hook still runs)."
                    )
                else:
                    # Was a standalone guard (no pre-existing hook content) — overwrite
                    updated = hook_script

                hook_path.write_text(updated, encoding="utf-8")
                os.chmod(str(hook_path), 0o755)
                print(f"  upgraded git {hook_name} hook to v2 at {hook_path}")
                continue

            # No guard present at all — splice the guard ABOVE the operator's existing
            # hook (Finding 9).  The guard runs FIRST inside a containment subshell and
            # FALLS THROUGH to the operator's hook on a clean result, so their own
            # linter / secret-scanner is never silently neutered.
            spliced = _guard_body_for_splice(hook_script, feeds_stdin=(hook_name == "pre-push"))
            existing_lines = existing.splitlines(keepends=True)
            if existing_lines and existing_lines[0].startswith("#!"):
                shebang = existing_lines[0]
                rest = "".join(existing_lines[1:])
                updated = shebang + spliced + "\n" + _splice_operator_rest(hook_name, rest)
            else:
                # No shebang in the existing hook — supply the guard's own.
                updated = "#!/usr/bin/env bash\n" + spliced + "\n" + _splice_operator_rest(hook_name, existing)
            print(
                f"  NOTICE: pre-existing {hook_name} hook detected — the vault guard was "
                f"spliced ABOVE it and FALLS THROUGH on a clean result (your hook still runs)."
            )
            hook_path.write_text(updated, encoding="utf-8")
        else:
            hook_path.write_text(hook_script, encoding="utf-8")
        os.chmod(str(hook_path), 0o755)
        print(f"  installed git {hook_name} hook at {hook_path}")


def _vault_cmd_set(args, root: Path) -> None:
    """
    tess vault set <ref> — set a secret value.
    Value read from stdin (piped) or a secure TTY prompt. NEVER from argv.
    """
    ref = getattr(args, "ref", None)
    if not ref:
        sys.exit("tessctl vault set: specify a ref (e.g. tessctl vault set github/token)")
    service, key = _vault_parse_ref(ref)

    # Read value from stdin or secure prompt — NEVER from argv (argv leaks to ps/history)
    if sys.stdin.isatty():
        try:
            value = getpass.getpass(f"Value for {ref}: ")
        except (EOFError, KeyboardInterrupt):
            sys.exit("\ntessctl vault set: aborted.")
        if not value:
            sys.exit("tessctl vault set: empty value not stored.")
    else:
        value = sys.stdin.read().rstrip("\n")
        if not value:
            sys.exit("tessctl vault set: empty value received on stdin — nothing stored.")

    data = _vault_read_blob(root)
    existing = ref in data.get("entries", {})

    data.setdefault("entries", {})[ref] = {
        "value": value,
        "meta": {
            "minted_at": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
            "minted_by": os.environ.get("USER", "unknown"),
            "service": service,
            "key": key,
            "format": "token",
            "rotates": "",
            "purpose": ""
        }
    }

    _vault_write_blob(root, data)
    verb = "updated" if existing else "stored"
    print(f"tessctl vault: {verb} {ref}  (value masked — use `tessctl vault get {ref}` to verify)")


def _vault_cmd_get(args, root: Path) -> None:
    """
    tess vault get <ref> — show masked value by default.
    --reveal prints the full value to stdout only if stdout is NOT a terminal.
    --force allows reveal to a terminal (for scripting).
    """
    ref = getattr(args, "ref", None)
    if not ref:
        sys.exit("tessctl vault get: specify a ref (e.g. tessctl vault get github/token)")
    _vault_parse_ref(ref)  # validate format

    reveal = getattr(args, "reveal", False)
    force = getattr(args, "force", False)

    data = _vault_read_blob(root)
    entry = data.get("entries", {}).get(ref)
    if entry is None:
        sys.exit(f"tessctl vault: ref not found: {ref}")

    value = entry.get("value", "")
    meta = entry.get("meta", {})

    if reveal:
        if sys.stdout.isatty() and not force:
            sys.exit(
                "tessctl vault get --reveal: stdout is a terminal. "
                "Raw values are not printed to TTY to prevent shoulder-surfing and shell history.\n"
                "  Pipe the output: tessctl vault get --reveal github/token | <cmd>\n"
                "  Or use: tessctl vault exec --ref github/token -- <cmd>\n"
                "  Force TTY output (scripting): tessctl vault get --reveal --force github/token"
            )
        # Machine-readable: print raw value, nothing else
        # This is the apiKeyHelper path
        sys.stdout.write(value)
        sys.stdout.flush()
    else:
        masked = _vault_mask_value(value, ref)
        minted = meta.get("minted_at", "unknown")
        purpose = meta.get("purpose", "")
        purpose_str = f"  purpose: {purpose}" if purpose else ""
        print(f"  {ref}")
        print(f"  value:   {masked}")
        print(f"  minted:  {minted}{purpose_str}")


def _vault_cmd_list(args, root: Path) -> None:
    """tess vault list — show refs + metadata. NEVER values."""
    data = _vault_read_blob(root)
    entries = data.get("entries", {})

    if not entries:
        print("tessctl vault: vault is empty. Use `tessctl vault set <ref>` to add secrets.")
        return

    scope = getattr(args, "scope", None)
    print(f"\ntessctl vault — {len(entries)} secret(s) stored\n")
    print(f"  {'REF':<30}  {'SERVICE':<15}  {'MINTED':<22}  ROTATES")
    print(f"  {'-'*30}  {'-'*15}  {'-'*22}  -------")
    for ref, entry in sorted(entries.items()):
        if scope and not ref.startswith(scope + "/"):
            continue
        meta = entry.get("meta", {})
        service = meta.get("service", "-")
        minted = meta.get("minted_at", "-")[:19]
        rotates = meta.get("rotates", "-") or "-"
        print(f"  {ref:<30}  {service:<15}  {minted:<22}  {rotates}")
    print()
    print("  Values are NEVER shown by list. Use `tessctl vault get <ref>` (masked).")


def _vault_cmd_rm(args, root: Path) -> None:
    """tess vault rm <ref> — remove a secret entry."""
    ref = getattr(args, "ref", None)
    if not ref:
        sys.exit("tessctl vault rm: specify a ref (e.g. tessctl vault rm github/token)")
    _vault_parse_ref(ref)

    data = _vault_read_blob(root)
    if ref not in data.get("entries", {}):
        sys.exit(f"tessctl vault rm: ref not found: {ref}")

    del data["entries"][ref]
    _vault_write_blob(root, data)
    print(f"tessctl vault: removed {ref}")


def _vault_cmd_rotate(args, root: Path) -> None:
    """
    tess vault rotate <ref> — re-encrypt a new value for an existing ref.
    Opens the registry's per-service rotation URL if known.
    """
    ref = getattr(args, "ref", None)
    if not ref:
        sys.exit("tessctl vault rotate: specify a ref (e.g. tessctl vault rotate github/token)")
    service, _ = _vault_parse_ref(ref)

    data = _vault_read_blob(root)
    if ref not in data.get("entries", {}):
        sys.exit(
            f"tessctl vault rotate: ref not found: {ref}.\n"
            f"  Use `tessctl vault set {ref}` to create it."
        )

    # Show rotation URL from registry if available
    registry_path = root / VAULT_REGISTRY
    if registry_path.exists():
        try:
            registry = json.loads(registry_path.read_text(encoding="utf-8"))
            svc = registry.get("services", {}).get(service, {})
            rotation_url = svc.get("rotation", "")
            if rotation_url:
                print(f"  Rotation URL: {rotation_url}")
                print(f"  Rotate the credential at your provider, then enter the new value below.")
        except (json.JSONDecodeError, KeyError):
            pass

    # Read new value — same stdin/prompt logic as set
    if sys.stdin.isatty():
        try:
            value = getpass.getpass(f"New value for {ref}: ")
        except (EOFError, KeyboardInterrupt):
            sys.exit("\ntessctl vault rotate: aborted.")
        if not value:
            sys.exit("tessctl vault rotate: empty value not stored.")
    else:
        value = sys.stdin.read().rstrip("\n")
        if not value:
            sys.exit("tessctl vault rotate: empty value received on stdin.")

    old_meta = data["entries"][ref].get("meta", {})
    old_meta["rotated_at"] = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    old_meta["minted_at"] = old_meta.get("rotated_at")

    data["entries"][ref] = {"value": value, "meta": old_meta}
    _vault_write_blob(root, data)
    print(f"tessctl vault: rotated {ref}  (new value stored; value masked)")


def _vault_cmd_exec(args, root: Path) -> None:
    """
    tess vault exec --ref <ref> [--as ENVVAR] -- <command...>

    Just-in-time injection: decrypts ONLY the requested ref, injects it as an
    env var into the child process environment, runs the command. The secret
    value NEVER appears in tessctl's stdout/stderr — only in the child's env.
    Child stdout/stderr are connected directly to the terminal (not captured).

    This is the §3.2 injection wrapper — the vault → child-process-env path.
    """
    ref = getattr(args, "ref", None)
    as_var = getattr(args, "as_var", None)
    cmd_list = getattr(args, "cmd", None) or []

    if not ref:
        sys.exit("tessctl vault exec: --ref <service/key> is required")

    # argparse REMAINDER includes '--' as the first item when present; strip it
    if cmd_list and cmd_list[0] == "--":
        cmd_list = cmd_list[1:]

    if not cmd_list:
        sys.exit("tessctl vault exec: specify a command after --  (e.g. tessctl vault exec --ref github/token -- gh pr list)")

    _vault_parse_ref(ref)  # validate

    # Determine the env var name
    if as_var:
        env_var = as_var.upper()
    else:
        # Default: SERVICE_KEY in upper snake_case
        env_var = ref.replace("/", "_").replace("-", "_").upper()

    # Decrypt just the requested ref
    data = _vault_read_blob(root)
    entry = data.get("entries", {}).get(ref)
    if entry is None:
        sys.exit(f"tessctl vault exec: ref not found: {ref}")

    value = entry.get("value", "")
    if not value:
        sys.exit(f"tessctl vault exec: ref {ref!r} has an empty value — set it first.")

    # Build child env: inherit current env + inject the secret
    child_env = dict(os.environ)
    child_env[env_var] = value

    # Clear the value from Python's memory as soon as it's in child_env
    # (best-effort; Python GC is not deterministic, but we don't hold extra refs)
    del value

    # Run child with stdout/stderr connected directly to terminal.
    # tessctl never captures child output — the secret value goes only into
    # the child's env, never into tessctl's own output stream.
    try:
        result = subprocess.run(cmd_list, env=child_env)
    except FileNotFoundError:
        sys.exit(f"tessctl vault exec: command not found: {cmd_list[0]!r}")
    except Exception as e:
        sys.exit(f"tessctl vault exec: failed to run command: {e}")
    finally:
        # Explicitly delete child_env to minimize window where secret is in memory
        del child_env

    sys.exit(result.returncode)


def _vault_cmd_doctor(args, root: Path) -> None:
    """
    tess vault doctor [--strict] — audit vault health.
    Checks: perms, gitignore coverage, manifest hard-guard, git hooks, registry.
    --strict: additionally validates vault.registry.json rejects value-shaped fields.
    """
    strict = getattr(args, "strict", False)
    issues = []
    warnings_list = []

    # 1. Check vault dir exists
    vault_dir = root / VAULT_DIR
    if not vault_dir.exists():
        issues.append(f"vault dir missing: {VAULT_DIR}  (run `tessctl vault init`)")
    else:
        # Check dir perms (should be 0700)
        mode = stat.S_IMODE(vault_dir.stat().st_mode)
        if mode & 0o077:
            issues.append(f"vault dir has unsafe permissions {oct(mode)}: {VAULT_DIR}  (fix: chmod 700)")

        # Check blob perms if exists
        blob_path = root / VAULT_BLOB
        if blob_path.exists():
            bmode = stat.S_IMODE(blob_path.stat().st_mode)
            if bmode & 0o077:
                issues.append(f"vault.age has unsafe permissions {oct(bmode)}: {VAULT_BLOB}  (fix: chmod 600)")

        # Check registry exists
        registry_path = root / VAULT_REGISTRY
        if not registry_path.exists():
            warnings_list.append(f"vault.registry.json missing — run `tessctl vault init` to create it")

    # 2. Check .gitignore covers vault paths
    gitignore_path = root / ".gitignore"
    if gitignore_path.exists():
        gi_content = gitignore_path.read_text(encoding="utf-8", errors="replace")
        for pattern, desc in [
            (".claude/vault/", "project vault dir"),
            ("**/vault.age", "vault blobs"),
            ("**/identity.age", "identity files"),
        ]:
            if pattern not in gi_content:
                issues.append(f".gitignore missing pattern: {pattern!r}  ({desc})")
    else:
        issues.append(".gitignore not found — vault paths may not be protected")

    # 3. Check identity file perms (if using file custody)
    if _GLOBAL_IDENTITY_FILE.exists():
        id_mode = stat.S_IMODE(_GLOBAL_IDENTITY_FILE.stat().st_mode)
        if id_mode & 0o077:
            issues.append(
                f"identity file has unsafe permissions {oct(id_mode)}: "
                f"{_GLOBAL_IDENTITY_FILE}  (fix: chmod 600)"
            )

    # 4. Check git hooks installed (version-aware: v2 marker required)
    git_hooks_dir = root / ".git" / "hooks"
    _HOOK_MARKER_V2  = "# tess-vault-guard v2"
    _HOOK_MARKER_ANY = "# tess-vault-guard"
    if git_hooks_dir.exists():
        for hook_name in ("pre-commit", "pre-push"):
            hook_path = git_hooks_dir / hook_name
            if not hook_path.exists():
                warnings_list.append(
                    f"git {hook_name} hook not installed — run `tessctl vault init` to install"
                )
            else:
                content = hook_path.read_text(encoding="utf-8", errors="replace")
                if _HOOK_MARKER_V2 in content:
                    pass  # current v2 marker present — OK
                elif _HOOK_MARKER_ANY in content:
                    warnings_list.append(
                        f"git {hook_name} hook has a stale guard (v1/unversioned) — "
                        f"run `tessctl vault init` to upgrade to v2"
                    )
                else:
                    warnings_list.append(
                        f"git {hook_name} hook exists but tess-vault-guard not present — "
                        f"run `tessctl vault init` to install"
                    )
    else:
        warnings_list.append(".git/hooks/ not found — git hooks not verifiable (not in a git repo?)")

    # 5. Check dispatch content-scan hook wired
    settings_path = root / ".claude" / "settings.json"
    if settings_path.exists():
        try:
            settings = json.loads(settings_path.read_text(encoding="utf-8"))
            pre_hooks = settings.get("hooks", {}).get("PreToolUse", [])
            scan_wired = any(
                "vault-dispatch-scan" in json.dumps(h)
                for h in pre_hooks
            )
            if not scan_wired:
                warnings_list.append(
                    "vault-dispatch-scan hook not wired in .claude/settings.json "
                    "(defense-in-depth scan on Task|Agent dispatch)"
                )
        except (json.JSONDecodeError, KeyError):
            pass

    # 6. --strict: validate registry rejects value-shaped fields
    if strict:
        registry_path = root / VAULT_REGISTRY
        if registry_path.exists():
            try:
                registry = json.loads(registry_path.read_text(encoding="utf-8"))
                # A value-rejecting check: no field named 'value', 'secret', 'password', 'token'
                # with a non-empty string value in the registry
                registry_str = json.dumps(registry)
                suspicious = re.findall(
                    r'"(?:value|secret|password|api_key|token)"\s*:\s*"([^"]{8,})"',
                    registry_str
                )
                if suspicious:
                    issues.append(
                        f"vault.registry.json contains value-shaped fields "
                        f"(--strict check). Registry must NOT contain actual secret values."
                    )
            except json.JSONDecodeError as e:
                issues.append(f"vault.registry.json is invalid JSON: {e}")
        else:
            warnings_list.append("vault.registry.json not found — cannot run --strict schema check")

    # Print results
    print(f"\ntessctl vault doctor{'  (--strict)' if strict else ''}")
    print("=" * 50)

    ok_count = 0
    _checks = [
        "vault dir + perms",
        ".gitignore coverage",
        "identity file perms",
        "git pre-commit/pre-push hooks",
        "dispatch content-scan hook",
    ]
    if strict:
        _checks.append("registry value-rejecting schema")

    if not issues and not warnings_list:
        print("  OK: all vault checks passed.")
        print("\nvault doctor: OK")
        return

    for issue in issues:
        print(f"  FAIL  {issue}")
    for warn in warnings_list:
        print(f"  WARN  {warn}")

    print(f"\nvault doctor: {'FAIL' if issues else 'WARN'} "
          f"({len(issues)} error(s), {len(warnings_list)} warning(s))")

    if issues:
        sys.exit(1)


def _vault_cmd_scan(args, root: Path) -> None:
    """
    tess vault scan — dry-run the secret-pattern guard over the working tree + staged set.
    """
    staged_only = getattr(args, "staged", False)
    if staged_only:
        result = subprocess.run(["git", "diff", "--cached", "--name-only"],
                                capture_output=True, text=True, cwd=str(root))
        files = [root / f for f in result.stdout.splitlines() if f.strip()]
    else:
        # All tracked files
        result = subprocess.run(["git", "ls-files"],
                                capture_output=True, text=True, cwd=str(root))
        files = [root / f for f in result.stdout.splitlines() if f.strip()]

    hits = []
    compiled = [re.compile(p, re.IGNORECASE) for p in VAULT_SECRET_PATTERNS]
    for fpath in files:
        if not fpath.is_file():
            continue
        try:
            content = fpath.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        for pat in compiled:
            if pat.search(content):
                hits.append(str(fpath.relative_to(root)))
                break  # one match per file is enough

    if hits:
        print(f"vault scan: {len(hits)} file(s) match secret patterns:")
        for h in hits:
            print(f"  {h}")
        sys.exit(1)
    else:
        print(f"vault scan: clean — no secret patterns found in {len(files)} file(s)")


def cmd_vault(args, root: Path) -> None:
    """
    Dispatch `tessctl vault <subcommand>`.
    """
    sub = getattr(args, "vault_sub", None)
    dispatch = {
        "init":    _vault_cmd_init,
        "set":     _vault_cmd_set,
        "get":     _vault_cmd_get,
        "list":    _vault_cmd_list,
        "rm":      _vault_cmd_rm,
        "rotate":  _vault_cmd_rotate,
        "exec":    _vault_cmd_exec,
        "doctor":  _vault_cmd_doctor,
        "scan":    _vault_cmd_scan,
    }
    fn = dispatch.get(sub)
    if not fn:
        # Print vault help
        print(
            "tessctl vault — age-encrypted secret store (M5)\n\n"
            "  Subcommands:\n"
            "    init                  create vault, generate identity, store in keychain\n"
            "    set <ref>             store secret (prompt or stdin, NEVER argv)\n"
            "    get <ref>             show masked value (--reveal for raw; refused on TTY)\n"
            "    list [--scope <s>]    list refs + metadata (never values)\n"
            "    rm <ref>              remove an entry\n"
            "    rotate <ref>          re-encrypt a new value, show rotation URL\n"
            "    exec --ref <r> [--as VAR] -- <cmd>  JIT inject into child env\n"
            "    doctor [--strict]     audit perms, gitignore, hooks, registry\n"
            "    scan [--staged]       dry-run secret scan over working tree\n\n"
            "  References: vault://service/key (e.g. vault://github/token)\n"
            "  Design:     conductor/vault.md\n\n"
            "  Dependency: pip install pyrage  (or: brew install age)"
        )
        sys.exit(0)
    fn(args, root)


# ---------------------------------------------------------------------------
# Main entrypoint
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="tessctl",
        description="Tess OS keystone CLI — framework lifecycle management",
    )
    sub = parser.add_subparsers(dest="command", metavar="COMMAND")

    # init
    p_init = sub.add_parser("init", help="scaffold project from framework; run restore + render")
    p_init.add_argument("--from", dest="from_upstream", metavar="UPSTREAM", help="git upstream URL (TODO: network)")

    # restore
    p_restore = sub.add_parser("restore", help="re-sync live tree from .tess/core (no network, idempotent)")
    p_restore.add_argument("--dry-run", action="store_true", dest="dry_run")

    # doctor
    p_doctor = sub.add_parser("doctor", help="SHA-integrity check; flag security-tier drift")
    p_doctor.add_argument("--fix", action="store_true", help="auto-capture uncaptured drift")
    p_doctor.add_argument("--json", action="store_true", dest="json_out", help="machine-readable JSON output")
    p_doctor.add_argument("path", nargs="?", help="check a specific file")

    # update
    p_update = sub.add_parser("update", help="fetch new version; snapshot → doctor → signed-verify → merge → render → re-pin")
    p_update.add_argument("--check", action="store_true", help="report without writing (safe nightly version-watch)")
    p_update.add_argument("--dry-run", action="store_true", dest="dry_run")
    p_update.add_argument("--ref", metavar="TAG",
                          help="signed release tag to fetch (e.g. v2.1.0); default: framework.upstream_ref in tess.lock")
    p_update.add_argument("--to", metavar="TAG",
                          help="alias for --ref (legacy semver arg; tag used directly)")
    p_update.add_argument(
        "--trust-on-first-use", action="store_true", dest="trust_on_first_use",
        help=(
            "explicit opt-in for TOFU (trust-on-first-use) when trusted_key_fingerprint "
            "is not set in tess.lock.  Verifies the tag signature with the system keyring, "
            "pins the 40-hex fingerprint, and saves it to tess.lock.  Without this flag, "
            "fetch is refused if no fingerprint is pinned (fail-closed default)."
        ),
    )

    # publish
    p_publish = sub.add_parser("publish", help="copy core→live, status→user-published")
    p_publish.add_argument("path", nargs="?", help="path to publish (live_path or core_key)")
    p_publish.add_argument("--tag", metavar="SELECTOR", help="publish a group: hooks | doctrine | settings | entry-point")
    p_publish.add_argument("--force", action="store_true", help="show diff + confirm before re-seeding")

    # override
    p_override = sub.add_parser("override", help="record diff vs core as patch-override in tess.lock")
    p_override.add_argument("path", help="live path to override")

    # capture
    p_capture = sub.add_parser("capture", help="detect in-place edit → locally-modified + provenance log")
    p_capture.add_argument("path", nargs="?", help="specific file to capture (default: scan all core-managed)")
    p_capture.add_argument("--all", action="store_true", help="scan all files regardless of status")
    p_capture.add_argument("--dry-run", action="store_true", dest="dry_run")
    p_capture.add_argument("--rationale", metavar="TEXT", help="why this edit was made (required for security-tier files)")
    p_capture.add_argument("--source", metavar="SOURCE", default="manual", help="provenance source (default: manual)")
    p_capture.add_argument("--auto", action="store_true", help="non-interactive (hook mode)")

    # rollback
    p_rollback = sub.add_parser("rollback", help="restore from snapshot + rewrite tess.lock")
    p_rollback.add_argument("--to", metavar="TS", help="snapshot timestamp (default: most recent)")

    # diff
    p_diff = sub.add_parser("diff", help="show core (rendered) vs live")
    p_diff.add_argument("path", nargs="?", help="specific file to diff")
    p_diff.add_argument("--stat", action="store_true", help="summary only")
    p_diff.add_argument("--upstream", action="store_true", help="(TODO) diff vs upstream version")

    # render
    p_render = sub.add_parser("render", help="render CLAUDE.md from template + operator/ stubs; render settings.json")

    # verify (defect #3)
    p_verify = sub.add_parser("verify", help="verify .tess/core bytes vs base_sha; flag security-tier tampering")

    # approve (defect #1)
    p_approve = sub.add_parser("approve", help="accept a quarantined security-tier edit (rationale required)")
    p_approve.add_argument("path", help="live path of the quarantined file")
    p_approve.add_argument("--rationale", metavar="TEXT", default="",
                           help="REQUIRED (fail-loud if absent): reason this security-doctrine change is acceptable (the operator gate)")

    # resolve (defect #7)
    p_resolve = sub.add_parser("resolve", help="resolve a conflict file after tessctl update collision")
    p_resolve.add_argument("path", help="live path of the conflicted file")
    p_resolve_mode = p_resolve.add_mutually_exclusive_group()
    p_resolve_mode.add_argument("--ours", action="store_true", help="accept local version")
    p_resolve_mode.add_argument("--theirs", action="store_true", help="accept incoming upstream version")
    p_resolve_mode.add_argument("--edit", action="store_true", help="open $EDITOR on conflict file")

    # reset (M1) — explicit discard of a captured/locally-modified edit
    p_reset = sub.add_parser("reset", help="discard captured edit; restore from core and re-pin lock to pristine")
    p_reset.add_argument("path", help="live path to reset (must be locally-modified or core-managed)")

    # self-update
    p_selfupdate = sub.add_parser(
        "self-update",
        help="update the tessctl engine itself (.tess/bin/tessctl) from a signed upstream tag",
    )
    p_selfupdate.add_argument(
        "--ref", metavar="TAG",
        help="signed release tag to fetch (e.g. v2.1.0); default: framework.upstream_ref in tess.lock"
    )
    p_selfupdate.add_argument(
        "--to", metavar="TAG",
        help="alias for --ref (legacy semver arg)"
    )
    p_selfupdate.add_argument(
        "--trust-on-first-use", action="store_true", dest="trust_on_first_use",
        help=(
            "explicit opt-in for TOFU when trusted_key_fingerprint is not set in tess.lock. "
            "Pins the fingerprint on first use.  Without this flag, self-update is refused "
            "when no fingerprint is pinned (fail-closed default)."
        ),
    )

    # lock (M1) — CI gate verb + MAINTAINER re-baseline
    p_lock = sub.add_parser(
        "lock",
        help="lock file ops (--check: CI integrity gate; --regen: MAINTAINER re-baseline base_sha to current core)",
    )
    p_lock_mode = p_lock.add_mutually_exclusive_group()
    p_lock_mode.add_argument("--check", action="store_true",
                             help="exit non-zero if any drift, core tamper, or quarantined file found (CI gate)")
    p_lock_mode.add_argument("--regen", action="store_true",
                             help="MAINTAINER: re-pin every base_sha to sha256 of the current .tess/core file "
                                  "(re-baselines integrity to current core; requires --yes or interactive y/N)")
    p_lock.add_argument("--yes", action="store_true",
                        help="confirm --regen non-interactively (acknowledges re-baselining integrity to current core)")

    # roster — curated-squad management (M2: staged status + install sets)
    p_roster = sub.add_parser(
        "roster",
        help="squad management: apply <path> installs a starter squad; list shows installed vs staged",
    )
    roster_sub = p_roster.add_subparsers(dest="roster_sub", metavar="SUBCOMMAND")
    p_roster_apply = roster_sub.add_parser(
        "apply",
        help="install squad+universal-base for a starter path; stage everything else (idempotent)",
    )
    p_roster_apply.add_argument(
        "path_name", metavar="PATH",
        choices=["founders", "builders", "operators"],
        help="starter path: founders | builders | operators",
    )
    roster_sub.add_parser("list", help="show installed vs staged agent counts and listing")

    # recruit — staged → core-managed + write live file
    p_recruit = sub.add_parser(
        "recruit",
        help="move staged agent(s) to installed (staged → core-managed + write live dispatch file)",
    )
    p_recruit.add_argument(
        "names", nargs="+", metavar="NAME",
        help=(
            "agent name(s) to recruit. Accepts: exact name (vega), orchestrator shorthand "
            "(revenue → revenue-orchestrator), or path group (founders → whole founders squad+orchestrators)"
        ),
    )

    # bench — core-managed → staged + remove live file
    p_bench = sub.add_parser(
        "bench",
        help="move installed agent(s) to staged (core-managed → staged + remove live dispatch file)",
    )
    p_bench.add_argument(
        "names", nargs="+", metavar="NAME",
        help="agent name(s) to bench (same name resolution as recruit)",
    )

    # M6: identity — show or set conductor/operator names
    p_identity = sub.add_parser(
        "identity",
        help="show or set conductor name + operator name (M6); re-renders on change",
    )
    p_identity.add_argument(
        "--name", dest="assistant_name", metavar="NAME",
        help="conductor/assistant name (same as `tessctl rename <name>`)",
    )
    p_identity.add_argument(
        "--operator", dest="operator_name", metavar="NAME",
        help="operator's name (same as `tessctl set-operator <name>`)",
    )

    # M6: rename — set conductor name
    p_rename = sub.add_parser(
        "rename",
        help="set conductor/assistant name and re-render (M6)",
    )
    p_rename.add_argument(
        "name", metavar="NAME",
        help="new conductor name (letters, digits, spaces, hyphens, apostrophes; max 30 chars)",
    )

    # M6: set-operator — set operator's name
    p_setop = sub.add_parser(
        "set-operator",
        help="set the operator's name and re-render (M6)",
    )
    p_setop.add_argument(
        "name", metavar="NAME",
        help="operator's name (letters, digits, spaces, hyphens, apostrophes; max 30 chars)",
    )

    # M4: pathway — show or switch conductor persona
    p_pathway = sub.add_parser(
        "pathway",
        help="show or switch conductor communication pathway/persona (M4); re-renders on change",
    )
    p_pathway.add_argument(
        "key", nargs="?", metavar="KEY",
        help=(
            "pathway key to activate, or 'list' to show all options. "
            "Valid keys: chief-of-staff | co-founder | strategist | guide | operator"
        ),
    )

    # M5: vault — age-encrypted secret store
    p_vault = sub.add_parser(
        "vault",
        help="age-encrypted secret store (M5) — tess vault <subcommand>",
    )
    vault_sub = p_vault.add_subparsers(dest="vault_sub", metavar="SUBCOMMAND")

    # vault init
    p_vinit = vault_sub.add_parser("init", help="create vault, generate age identity, store in keychain")
    p_vinit.add_argument("--headless", action="store_true",
                         help="headless mode: store identity in ~/.config/tess/vault/identity.age (not keychain)")

    # vault set
    p_vset = vault_sub.add_parser("set", help="store a secret (prompt or stdin, NEVER argv)")
    p_vset.add_argument("ref", metavar="service/key", help="ref to set (e.g. github/token)")

    # vault get
    p_vget = vault_sub.add_parser("get", help="show a secret (masked by default)")
    p_vget.add_argument("ref", metavar="service/key", help="ref to retrieve")
    p_vget.add_argument("--reveal", action="store_true",
                        help="print raw value to stdout (refused if stdout is a TTY unless --force)")
    p_vget.add_argument("--force", action="store_true",
                        help="allow --reveal to a TTY (for scripting)")

    # vault list
    p_vlist = vault_sub.add_parser("list", help="list all refs + metadata (never values)")
    p_vlist.add_argument("--scope", metavar="PREFIX", help="filter refs by service/scope prefix")

    # vault rm
    p_vrm = vault_sub.add_parser("rm", help="remove a secret entry")
    p_vrm.add_argument("ref", metavar="service/key", help="ref to remove")

    # vault rotate
    p_vrotate = vault_sub.add_parser("rotate", help="re-encrypt a new value for an existing ref")
    p_vrotate.add_argument("ref", metavar="service/key", help="ref to rotate")

    # vault exec
    p_vexec = vault_sub.add_parser(
        "exec",
        help="JIT-inject a secret into a child process env and run the command",
        description=(
            "Decrypts the requested ref just-in-time into the child process environment "
            "only. The value NEVER appears in tessctl stdout/stderr or any log."
        ),
    )
    p_vexec.add_argument("--ref", metavar="service/key", required=True,
                         help="vault ref to inject (e.g. github/token)")
    p_vexec.add_argument("--as", dest="as_var", metavar="ENVVAR",
                         help="env var name to inject as (default: SERVICE_KEY uppercase)")
    p_vexec.add_argument("cmd", nargs=argparse.REMAINDER, metavar="-- <command>",
                         help="command to run (after --)")

    # vault doctor
    p_vdoctor = vault_sub.add_parser("doctor", help="audit vault health (perms, gitignore, hooks, registry)")
    p_vdoctor.add_argument("--strict", action="store_true",
                           help="also validate vault.registry.json against value-rejecting schema")

    # vault scan
    p_vscan = vault_sub.add_parser("scan", help="dry-run secret-pattern scan over working tree")
    p_vscan.add_argument("--staged", action="store_true", help="scan staged files only (pre-commit check)")

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    root = find_tess_root()

    # LOW fix: scope tool checks to what each command actually invokes.
    # The original blanket check demanded git+diff+patch for all SUBPROCESS_COMMANDS,
    # but e.g. capture only needs diff; update needs git+patch; resolve needs nothing
    # (--ours/--theirs do no subprocess; --edit invokes $EDITOR, not checked here).
    _TOOL_REQUIREMENTS: dict[str, list[str]] = {
        "update":      ["git", "patch", "gpg"],  # signed-tag fetch (git) + merge-file (git) + patch-apply (patch) + isolated GNUPGHOME (gpg)
        "self-update": ["git", "gpg"],           # signed-tag fetch + clone + isolated GNUPGHOME
        "capture":     ["diff"],           # diff -u for provenance log
        "diff":        ["git"],            # git diff --no-index
        "doctor":      ["diff"],           # doctor --fix calls diff -u (Reid LOW-1)
        "override":    ["diff"],           # diff -u to compute patch
        "approve":     ["diff"],           # diff -u for event log
        "publish":     ["git"],            # git diff --no-index (--force mode)
        "resolve":     [],                 # --ours/--theirs: no subprocess; --edit: $EDITOR
    }
    tools_needed = _TOOL_REQUIREMENTS.get(args.command, [])
    if tools_needed:
        _check_tools(*tools_needed)

    dispatch = {
        "init":         cmd_init,
        "restore":      cmd_restore,
        "doctor":       cmd_doctor,
        "update":       cmd_update,
        "self-update":  cmd_self_update,
        "publish":      cmd_publish,
        "override":     cmd_override,
        "capture":      cmd_capture,
        "rollback":     cmd_rollback,
        "diff":         cmd_diff,
        "render":       cmd_render,
        "verify":       cmd_verify,
        "approve":      cmd_approve,
        "resolve":      cmd_resolve,
        "reset":        cmd_reset,
        "lock":         cmd_lock,
        # M2: curated-squad mechanism
        "roster":       cmd_roster,
        "recruit":      cmd_recruit,
        "bench":        cmd_bench,
        # M4/M6: persona + name render layer
        "identity":     cmd_identity,
        "rename":       cmd_rename,
        "set-operator": cmd_set_operator,
        "pathway":      cmd_pathway,
        # M5: vault — age-encrypted secret store
        "vault":        cmd_vault,
    }

    fn = dispatch.get(args.command)
    if not fn:
        sys.exit(f"tessctl: unknown command: {args.command}")

    # GateError propagated out of single-file command entrypoints (cmd_publish
    # single-target, cmd_override, cmd_approve, cmd_reset, cmd_resolve,
    # _do_render, etc.) is caught here and converted to sys.exit(str(e)),
    # preserving the exact UX and exit-code behavior that sys.exit() in
    # check_manifest_write_gate produced before we switched to raising GateError.
    # Bulk callers (_do_restore, _apply_per_file_resolution, cmd_publish --tag,
    # cmd_capture scan/--all) catch GateError per-iteration before it reaches
    # here, so this handler only fires for genuinely single-target violations.
    try:
        fn(args, root)
    except GateError as e:
        sys.exit(str(e))


if __name__ == "__main__":
    main()
