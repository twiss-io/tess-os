"""
tessctl — Tess OS keystone CLI
Spec: kb/wiki/synthesis/2026-06-27-keystone-architecture.md §§3-5
Runtime: Python 3 (stdlib + pyyaml). No Node. Self-contained single file.

Implemented commands (Phase 1 + Phase 2 core + security hardening):
  init        scaffold operator/ stubs, run restore + render
  restore     re-sync live tree from .tess/core at locked version (no network, idempotent)
  doctor      SHA-integrity check every core-managed file; flag security-tier drift + core tamper
  update      snapshot → doctor gate → git subtree pull → per-file resolution → render → re-pin
  publish     copy core→live, status→user-published, stamp @published-from
  override    record diff vs core as patch-override in tess.lock
  capture     hash-detect in-place edit → locally-modified (security-tier → quarantined)
  rollback    restore from .tess/snapshots/<ts> + rewrite tess.lock
  diff        show core (rendered) vs live via git diff
  render      render CLAUDE.md from CLAUDE.md.tpl + operator/ stubs; render settings.json
  verify      core-integrity audit: .tess/core bytes vs base_sha + security-tier tampering check
  approve     accept a quarantined security-tier edit (the operator gate, rationale hard-required)
  resolve     resolve a conflict file: --ours / --theirs / --edit (open $EDITOR)

Merge engine: git merge-file (3-way textual). No custom diff algorithm.
"""

from __future__ import annotations  # PEP 563 — lazy annotation eval; keeps 3.9 compat (int|None, X|Y unions)

import argparse
import datetime
import fnmatch
import getpass
import glob
import hashlib
import json
import os
import re
import shutil
import stat
import subprocess
import sys
import tempfile
from pathlib import Path

try:
    import yaml
except ImportError:
    sys.exit("tessctl requires pyyaml: pip install pyyaml")


class GateError(Exception):
    """Raised by check_manifest_write_gate on any write-gate violation.

    Replaces sys.exit() so that BULK callers (_do_restore, _apply_per_file_resolution,
    cmd_publish (--tag), cmd_capture (scan/--all)) can catch per-iteration and
    skip-with-warning rather than aborting the entire run.
    Single-file command entrypoints let the exception propagate to main(), where it is
    converted to sys.exit(str(e)) to preserve identical UX/exit-code behavior.
    """


# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

LOCK_FILE = ".tess/tess.lock"
MANIFEST_FILE = "tess.manifest.json"
CORE_DIR = ".tess/core"
SNAPSHOTS_DIR = ".tess/snapshots"
STAGING_DIR = ".tess/staging"
MODIFIED_JSON = ".tess/modified.json"
UPDATE_LOCK = ".tess/update.lock"
MAX_SNAPSHOTS = 5
MAX_PRE_SNAPSHOTS = 20   # N2: independent cap for single-file -pre snapshots
QUARANTINE_DIR = ".tess/quarantine"
ROSTER_PATHS_FILE = ".tess/core/roster-paths.json"

LOCK_HEADER = """\
# tess.lock — Tess OS framework merge base of record.
# COMMITTED. Per spec kb/wiki/synthesis/2026-06-27-keystone-architecture.md sec.4.
# base_sha = sha256 of the PRISTINE .tess/core/<file> bytes at the pinned version.
# This file is the reproducibility guarantee; `tessctl verify` is the CI integrity gate
# (also available as `tessctl lock --check` for a strict CI-only non-zero-on-drift verb).
# MAINTAINER re-baseline: `tessctl lock --regen --yes` re-pins every base_sha to the
# CURRENT .tess/core bytes. Use ONLY after a deliberate, reviewed change to core (e.g. a
# de-identification scrub); it blesses whatever core is now as pristine.
"""

SECURITY_TIER_PATHS = {
    "conductor/guardrails.md",
    "conductor/verification-routing.md",
    "conductor/channel-guardrails.md",
    "conductor/dispatch-brief.md",
}

# R2: live paths whose content is generated by `tessctl render` (not hand-edited).
# When doctor detects drift on these paths the correct remedy is `tessctl render`
# (re-sync from operator-state), NEVER `tessctl capture` (which would launder a
# stale render as a deliberate local modification).
RENDER_GENERATED_LIVE_PATHS: frozenset = frozenset({
    "CLAUDE.md",
    ".claude/settings.json",
    "conductor/identity.md",
    "conductor/personality.md",
    # QUINN: client template carries {{ASSISTANT_NAME}} tokens; re-rendered by
    # `tessctl render` (and rename/set-operator) so drift is a stale render, not
    # a hand-edit.  Correct remedy: `tessctl render`, never `tessctl capture`.
    "clients/_template/CLAUDE.md",
})

# ---------------------------------------------------------------------------
# Single security-tier predicate — canonical source of truth (§6 + defect #8)
# ---------------------------------------------------------------------------

def is_security_tier(core_key: str, attrs: dict) -> bool:
    """
    ONE predicate for security-tier determination. Used by capture, doctor,
    verify, restore, and the write gate.  Priority:
      1. tess.lock tier: security field (authoritative when set)
      2. SECURITY_TIER_PATHS fallback (handles files whose lock entry pre-dates
         the tier field, and dispatch-brief.md which is security by doctrine).
    """
    if attrs.get("tier") == "security":
        return True
    live_rel = attrs.get("live_path", "")
    if live_rel in SECURITY_TIER_PATHS:
        return True
    # Also match by core_key (e.g. .tess/core/conductor/dispatch-brief.md)
    for p in SECURITY_TIER_PATHS:
        if core_key.endswith("/" + p) or core_key == p:
            return True
    return False


# Token → file mapping for CLAUDE.md template rendering
CLAUDE_TOKEN_MAP = {
    "{{CORE_RULE_ZERO}}":       ".tess/core/templates/claude-md/rule-zero.md",
    "{{CORE_SYSTEM_LAWS}}":     ".tess/core/templates/claude-md/system-laws.md",
    "{{CORE_ORCHESTRATORS}}":   ".tess/core/templates/claude-md/orchestrators.md",
    "{{CORE_COMMANDS}}":        ".tess/core/templates/claude-md/commands.md",
    "{{CORE_DIRECTORY}}":       ".tess/core/templates/claude-md/directory.md",
}

OPERATOR_TOKEN_MAP = {
    "{{OPERATOR_IDENTITY}}":    "operator/identity-stub.md",
    "{{OPERATOR_PROFILE}}":     "operator/user-profile.md",
    "{{OPERATOR_CHANNELS}}":    "operator/org-channels.md",
}


# ---------------------------------------------------------------------------
# Root discovery
# ---------------------------------------------------------------------------

def find_tess_root() -> Path:
    """Walk up from CWD to find the directory containing tess.manifest.json."""
    # Honour explicit env override first (set by the ./tessctl wrapper)
    if "TESS_ROOT" in os.environ:
        root = Path(os.environ["TESS_ROOT"]).resolve()
        if (root / MANIFEST_FILE).exists():
            return root
        # Still honour it even without manifest during init
        return root
    cur = Path.cwd().resolve()
    for candidate in [cur] + list(cur.parents):
        if (candidate / MANIFEST_FILE).exists():
            return candidate
    sys.exit(
        "tessctl: cannot find tess.manifest.json in this directory or any parent.\n"
        "  Run from inside a Tess OS project, or set TESS_ROOT."
    )


# ---------------------------------------------------------------------------
# SHA256 utilities
# ---------------------------------------------------------------------------

def sha256_bytes(data: bytes) -> str:
    return "sha256:" + hashlib.sha256(data).hexdigest()


def sha256_file(path: Path) -> str:
    if not path.exists():
        return "sha256:MISSING"
    return sha256_bytes(path.read_bytes())


def sha256_str(s: str) -> str:
    return sha256_bytes(s.encode("utf-8"))


# ---------------------------------------------------------------------------
# Lock file I/O
# ---------------------------------------------------------------------------

def load_lock(root: Path) -> dict:
    lock_path = root / LOCK_FILE
    if not lock_path.exists():
        sys.exit(f"tessctl: {LOCK_FILE} not found. Run `tessctl init` first.")
    with open(lock_path, "r", encoding="utf-8") as f:
        data = yaml.safe_load(f)
    if data is None:
        sys.exit(f"tessctl: {LOCK_FILE} is empty or invalid YAML.")
    return data


def save_lock(root: Path, data: dict) -> None:
    """Write tess.lock back, preserving the header comment."""
    lock_path = root / LOCK_FILE
    body = yaml.dump(
        data,
        default_flow_style=False,
        allow_unicode=True,
        sort_keys=False,
        width=120,
    )
    lock_path.write_text(LOCK_HEADER + body, encoding="utf-8")


def load_manifest(root: Path) -> dict:
    mf_path = root / MANIFEST_FILE
    if not mf_path.exists():
        sys.exit(f"tessctl: {MANIFEST_FILE} not found.")
    return json.loads(mf_path.read_text(encoding="utf-8"))


def check_manifest_write_gate(root: Path, manifest: dict, live_rel: str, op: str = "write") -> str:
    """
    Manifest write gate (spec §2.4 + C1 security hardening): every live-tree
    write must pass this gate BEFORE touching the filesystem.  Raises GateError
    on any violation (caught per-iteration by bulk callers; converted to sys.exit
    in main()).  Returns the normalized in-tree relative path (norm_rel) to callers
    that need it (guarded_write uses this for the actual write).

    Security model — ALLOWLIST (C1):
      1. Pre-validation: absolute paths, '../' traversal, out-of-tree resolve,
         and symlink directory components are all hard-rejected.
      2. norm_rel is computed from the resolved, contained target path.
      3. Hard guards (.git/**, vault blobs, *.local.md) deny regardless of
         owned_globs AND regardless of manifest contents (hardcoded tier).
      4. ALLOWLIST: norm_rel must match owned_globs — paths in neither list DENY.
      5. effective_never includes manifest never_touch plus .git / .git/**
         (defense-in-depth: .git is RCE-class even if accidentally added to owned).

    Precedence: owned_globs > never_touch EXCEPT for the hard guards in Step 3
    (.local.md, .git, vault) which owned_globs can NEVER override, regardless
    of manifest contents.

    M5 hardening (.local.md promoted to hardcoded tier): previously the
    .local.md guard only fired when *.local.md appeared in the manifest's
    never_touch list. Under a fully-poisoned manifest (never_touch:[], owned_globs:
    ['**']) the check was bypassable because local_guard resolved to [].  The guard
    is now unconditional — same tier as .git and vault — in Step 3c.
    """
    # ---- Step 1: Pre-validation (C1 containment) ----
    if os.path.isabs(live_rel):
        raise GateError(
            f"tessctl {op}: WRITE REFUSED — {live_rel!r} is an absolute path. "
            f"All writes must use paths relative to the Tess root (C1 containment)."
        )

    if ".." in Path(live_rel).parts:
        raise GateError(
            f"tessctl {op}: WRITE REFUSED — {live_rel!r} contains '..' traversal "
            f"components. Path traversal is always denied (C1 containment)."
        )

    root_resolved = root.resolve()
    try:
        target = (root / live_rel).resolve()
    except Exception as e:
        raise GateError(
            f"tessctl {op}: WRITE REFUSED — path resolution error for {live_rel!r}: {e}"
        )

    try:
        target.relative_to(root_resolved)
    except ValueError:
        raise GateError(
            f"tessctl {op}: WRITE REFUSED — {live_rel!r} resolves to {target}, "
            f"which is outside the Tess root {root_resolved} "
            f"(path traversal via symlink or resolve — C1 containment)."
        )

    # Reject symlink directory components (TOCTOU defense-in-depth)
    _check = root_resolved
    for _part in Path(live_rel).parts[:-1]:
        _check = _check / _part
        if _check.exists() and _check.is_symlink():
            raise GateError(
                f"tessctl {op}: WRITE REFUSED — {live_rel!r} traverses symlink "
                f"directory '{_part}' (symlink attack mitigation — C1 containment)."
            )

    # ---- Step 2: Normalize ----
    try:
        norm_rel = str(target.relative_to(root_resolved)).replace(os.sep, "/")
    except ValueError:
        raise GateError(
            f"tessctl {op}: WRITE REFUSED — cannot normalize {live_rel!r} relative to root."
        )

    # ---- Step 3: Hard guards (RCE sinks — override any owned_globs entry) ----
    # Case-insensitive, nested: ANY path component normalizing to '.git' is rejected.
    # Normalization: rstrip trailing dots and spaces per component (Windows-class poison:
    # the Win32 layer folds '.git.' → '.git', so 'agents/.git./hooks/x',
    # 'agents/.git /hooks/x', and 'conductor/.GIT./config' are all equivalent to
    # writing into .git/ on Windows).  Mirrors the rstrip(". ") approach in the
    # .local.md hard guard below.
    # This handles: .GIT/hooks/x, agents/sub/.git/hooks/y, .git./config, .GIT. etc.
    _norm_parts_lower = [c.rstrip(". ").lower() for c in Path(norm_rel).parts]
    if ".git" in _norm_parts_lower:
        raise GateError(
            f"tessctl {op}: WRITE REFUSED — {norm_rel!r} contains a '.git' path component "
            f"(case-insensitive check; parts={_norm_parts_lower!r}). "
            f"RCE sink: git hooks fire on the same tree tessctl runs in. "
            f"Always denied regardless of owned_globs (C1 defense-in-depth)."
        )

    # ---- Step 3b: Vault hard-guard (radioactive data tier — Cyra j, §6 Layer 2) ----
    # vault.age, identity.age, and the full .claude/vault/ blob tree are promoted
    # to the same hard-guard tier as .git. owned_globs CANNOT override this guard —
    # even if a future glob broadening adds .claude/** to owned, vault material stays
    # blocked. The only committable vault paths (.gitkeep + vault.registry.json) are
    # explicitly exempted so the framework scaffold can be rendered/shipped.
    _VAULT_EXEMPT = {
        ".claude/vault/.gitkeep",
        ".claude/vault/vault.registry.json",
    }
    _VAULT_SENSITIVE_GLOBS = [
        "**/*.age",              # any age-encrypted blob or identity
        ".claude/vault/**",      # project vault dir (except exempted above)
        "clients/*/.vault/**",   # per-client vault dirs
    ]
    # Case/trailing-dot normalization for the *.age arm (parity with .git/.local.md guards):
    # VAULT.AGE, vault.age., SECRET.AGE — all map to *.age match on a
    # case-insensitive or dot-folding FS, so we normalize before matching.
    # We normalize each path component (rstrip(". ").lower()) and then check
    # whether the final component ends with '.age' or matches the vault dir patterns.
    # This is done both via the glob matcher and via a direct extension check on the
    # normalized last component, which handles root-level files (no '/') that
    # '**/*.age' misses.
    _norm_parts_vault = [c.rstrip(". ").lower() for c in Path(norm_rel).parts]
    _norm_rel_lower_stripped = "/".join(_norm_parts_vault)
    _age_by_extension = _norm_parts_vault[-1].endswith(".age") if _norm_parts_vault else False
    _VAULT_SENSITIVE_GLOBS_NORMALIZED = [
        "**/*.age",
        "*.age",
        ".claude/vault/**",
        "clients/*/.vault/**",
    ]
    if norm_rel not in _VAULT_EXEMPT and (
        path_matches_globs(norm_rel, _VAULT_SENSITIVE_GLOBS)
        or _age_by_extension
        or path_matches_globs(_norm_rel_lower_stripped, _VAULT_SENSITIVE_GLOBS_NORMALIZED)
    ):
        raise GateError(
            f"tessctl {op}: WRITE REFUSED — {norm_rel!r} is a vault-protected path "
            f"(hard-guard tier, same as .git). Vault blobs, identity files, and age "
            f"material are always denied regardless of owned_globs. "
            f"Allowed vault paths: .claude/vault/.gitkeep, .claude/vault/vault.registry.json. "
            f"(Design: §6 Layer 2; Cyra j — vault-hard-guard.)"
        )

    # ---- Step 3c: .local.md hard guard (hardcoded tier — same as .git and vault) ----
    # Promoted from manifest-dependent (M5 hardening — Cyra-found poisoned-manifest
    # bypass): under a fully-poisoned manifest (never_touch:[], owned_globs:['**'])
    # the previous implementation (local_guard = [g for g in effective_never if g in
    # LOCAL_MD_GUARD]) returned [] because *.local.md was absent from effective_never,
    # and x.local.md was ALLOWED.  The .git and vault guards are manifest-independent;
    # this guard is promoted to the same unconditional tier.
    #
    # Normalization: rstrip(". ").lower() per component — same Windows-class poison
    # handling as the .git and vault arms (VAULT.AGE., .GIT., etc.).
    # Only the FINAL path component is checked — *.local.md is a FILE-level guard.
    _norm_parts_local = [c.rstrip(". ").lower() for c in Path(norm_rel).parts]
    _final_local = _norm_parts_local[-1] if _norm_parts_local else ""
    if _final_local.endswith(".local.md"):
        raise GateError(
            f"tessctl {op}: WRITE REFUSED — {norm_rel!r} is a .local.md shadow "
            f"(normalized final component {_final_local!r} ends in '.local.md'). "
            f"Hard guard — denied unconditionally regardless of manifest contents "
            f"(owned_globs or never_touch cannot override). "
            f"The .local.md layer is the operator's append-first customization tier and "
            f"is NEVER a framework write target "
            f"(spec §2.4 + §5 Layer 2 — M5 hardening, Cyra-found poisoned-manifest bypass)."
        )

    owned = manifest.get("owned_globs", [])
    never = manifest.get("never_touch", [])
    # Defense-in-depth: .git always in effective never even if not in manifest
    effective_never = list(never) + [".git", ".git/**"]

    # ---- Step 4: ALLOWLIST — must match owned_globs ----
    in_owned = path_matches_globs(norm_rel, owned)
    if not in_owned:
        raise GateError(
            f"tessctl {op}: WRITE REFUSED — {norm_rel!r} (normalized from {live_rel!r}) "
            f"does not match any pattern in manifest owned_globs. "
            f"tessctl may only write to framework-owned paths (spec §2.4 ALLOWLIST). "
            f"Paths matching neither owned_globs nor never_touch are DENIED."
        )

    # ---- Step 5: never_touch belt-and-suspenders (with documented precedence) ----
    # owned_globs > never_touch: if in both, ALLOW (e.g. clients/_template/**).
    # .local.md, .git, and vault blobs are already caught above as hard guards (Steps 3/3b/3c).
    # This check catches anything in never_touch that is not in owned_globs —
    # logically unreachable after step 4, but kept as explicit documentation.
    in_never = path_matches_globs(norm_rel, effective_never)
    if in_never and not in_owned:
        raise GateError(
            f"tessctl {op}: WRITE REFUSED — {norm_rel!r} is in manifest never_touch "
            f"and NOT in owned_globs. Writes into kb/, clients/, operator/, "
            f".env, or settings.local.json are structurally blocked (spec §2.4)."
        )

    return norm_rel


def guarded_write(root: Path, live_rel: str, data: bytes, op: str = "write",
                  manifest: dict = None) -> None:
    """
    Manifest-gated atomic live-tree write (C1 + H1 + M3).

    ALL framework→live writes MUST go through this function so that the
    manifest write gate (C1 containment + allowlist) and atomic filesystem
    semantics (write to a sibling temp, then os.replace()) are uniformly
    enforced.  This function is the sole path from framework content to the
    live tree — 'guarded_write covers ALL framework→live writes' is a literal
    invariant, verified by audit.

    manifest is optional — loaded fresh if not provided.

    File mode (LOW fix): mkstemp creates files with 0600 perms.  After the
    atomic replace we set an explicit mode — 0755 for .sh files, 0644 for
    everything else — honoring the process umask.  When the target already
    exists its mode is preserved, then masked by umask.
    """
    if manifest is None:
        manifest = load_manifest(root)
    # Gate returns the normalized in-tree rel; use that for the write target
    # so the actual path is always canonical regardless of the raw live_rel.
    norm_rel = check_manifest_write_gate(root, manifest, live_rel, op=op)
    live_path = root / norm_rel

    # Capture existing mode before write (preserve it on update)
    existing_mode: int | None = None
    if live_path.exists():
        try:
            existing_mode = stat.S_IMODE(live_path.stat().st_mode)
        except OSError:
            pass

    live_path.parent.mkdir(parents=True, exist_ok=True)
    # Atomic write: temp sibling → os.replace() so no partial file is ever visible
    tmp_fd, tmp_path_str = tempfile.mkstemp(
        dir=str(live_path.parent), prefix=".tessctl_tmp_"
    )
    try:
        with os.fdopen(tmp_fd, "wb") as fh:
            fh.write(data)
        os.replace(tmp_path_str, str(live_path))
    except Exception:
        try:
            os.unlink(tmp_path_str)
        except OSError:
            pass
        raise

    # Set file mode, honoring umask
    if existing_mode is not None:
        final_mode = existing_mode
    elif norm_rel.endswith(".sh"):
        final_mode = 0o755
    else:
        final_mode = 0o644
    _umask = os.umask(0)
    os.umask(_umask)
    try:
        os.chmod(str(live_path), final_mode & ~_umask)
    except OSError:
        pass  # Best-effort; non-fatal on unusual filesystems


def _check_tools(*tools: str) -> None:
    """
    Preflight check for required external tools (M4).
    Exits with a clear remediation message if any tool is missing from PATH,
    mirroring the pyyaml-missing handling at module load.
    """
    missing = [t for t in tools if shutil.which(t) is None]
    if missing:
        sys.exit(
            f"tessctl: required tool(s) not found on PATH: {', '.join(missing)}\n"
            f"  Install the missing tool(s) and retry:\n"
            f"    git   — merge operations and diffs (git merge-file, git diff)\n"
            f"    diff  — override/capture patch generation (GNU diffutils)\n"
            f"    patch — patch-apply on update (GNU patch)"
        )


# ---------------------------------------------------------------------------
# Operator profile — M4/M6 persona + name tokens
# ---------------------------------------------------------------------------

VALID_PATHWAYS: frozenset = frozenset({
    "chief-of-staff",
    "co-founder",
    "strategist",
    "guide",
    "operator",
})

PATHWAY_LABELS: dict = {
    "chief-of-staff": "Chief of Staff  — formal, structured, one step below the operator",
    "co-founder":     "Co-founder      — peer energy, direct, 'we', pushes back as an equal",
    "strategist":     "Strategist      — frames before acting, surfaces trade-offs and assumptions",
    "guide":          "Guide           — patient navigator, contextualizes choices, builds understanding",
    "operator":       "Operator        — tactical, tight, status-first, execution-mode",
}

_OPERATOR_PROFILE_DEFAULTS: dict = {
    "operator_name": "Operator",
    "assistant_name": "Tess",
    "pathway": "chief-of-staff",
}


def _load_operator_profile(root: Path) -> dict:
    """
    Load operator/profile.json with defaults.

    Merges disk values over defaults so partial files are safe.
    Falls back gracefully on missing or malformed file.
    Defaults: assistant_name='Tess', operator_name='Operator', pathway='chief-of-staff'.
    """
    defaults = dict(_OPERATOR_PROFILE_DEFAULTS)
    profile_path = root / "operator" / "profile.json"
    if not profile_path.exists():
        return defaults
    try:
        data = json.loads(profile_path.read_text(encoding="utf-8"))
        if not isinstance(data, dict):
            return defaults
        merged = {**defaults, **data}
        # Coerce invalid pathway back to default.
        # HIGH-2: merged.get("pathway") may be a list/dict (unhashable); the bare
        # `not in VALID_PATHWAYS` test raises TypeError on those values.  Guard with
        # isinstance first so any non-str value is safely coerced to the default.
        _pw = merged.get("pathway")
        if not isinstance(_pw, str) or _pw not in VALID_PATHWAYS:
            merged["pathway"] = defaults["pathway"]
        # R3: coerce name fields to str and validate charset/length; fall back to
        # defaults on violation so render/doctor never crash with TypeError on a
        # hand-edited profile.json that contains a non-string name (e.g. 123).
        for field in ("assistant_name", "operator_name"):
            raw = merged.get(field, defaults[field])
            try:
                coerced = str(raw).strip()
                merged[field] = _validate_name(coerced, f"profile.{field}")
            except SystemExit:
                merged[field] = defaults[field]
        return merged
    except (json.JSONDecodeError, OSError):
        return defaults


def _save_operator_profile(root: Path, profile: dict) -> None:
    """
    Write operator/profile.json directly.

    operator/ is never_touch for the manifest write gate; this is a
    deliberate operator-directed mutation (not a framework content write),
    so it bypasses guarded_write and writes the file directly — matching the
    precedent set by _scaffold_operator_stubs for the same directory.
    """
    op_dir = root / "operator"
    op_dir.mkdir(exist_ok=True)
    profile_path = op_dir / "profile.json"
    profile_path.write_text(
        json.dumps(profile, indent=2, ensure_ascii=False) + "\n",
        encoding="utf-8",
    )


def _render_pathway_block(root: Path, pathway_key: str) -> str:
    """
    Read .tess/core/personas/<key>.md and return its trimmed content.

    The returned string is spliced into the content at {{PATHWAY}} by
    apply_token_sub. Name tokens inside the persona block ({{ASSISTANT_NAME}},
    {{OPERATOR_NAME}}) are resolved in the subsequent substitution pass.

    Falls back to a visible inline comment if the persona file is missing,
    so a partially-constructed install never silently loses the injection zone.
    """
    persona_path = root / ".tess" / "core" / "personas" / f"{pathway_key}.md"
    if persona_path.exists():
        return persona_path.read_text(encoding="utf-8").strip()
    return (
        f"<!-- PATHWAY PERSONA MISSING: {pathway_key!r} — "
        f"run `tessctl init` or `tessctl update` to restore core files. -->"
    )


# ---------------------------------------------------------------------------
# Content rendering (operator token substitution + .local.md append)
# ---------------------------------------------------------------------------

def apply_token_sub(content: str, root: Path) -> str:
    """
    Substitute operator tokens in content (M4/M6 Path B render layer).

    Resolution order (matters — {{PATHWAY}} block may itself contain name tokens):
      1. {{PATHWAY}}        → rendered persona block from .tess/core/personas/<key>.md
                              (expanded FIRST so its {{ASSISTANT_NAME}}/{{OPERATOR_NAME}}
                              sites are resolved by the single pass below)
      2. Single re.sub pass over {{TESS_ROOT}}, {{ASSISTANT_NAME}}, {{OPERATOR_NAME}}.
         re.sub never re-scans replacement text, so a value that itself contains a
         literal token string (e.g. assistant_name='{{OPERATOR_NAME}}') is NOT
         double-expanded — fixing the R4 sequential-replace vulnerability.

    Idempotent: repeated calls with unchanged profile produce identical output.
    """
    ALL_TOKENS = ("{{PATHWAY}}", "{{TESS_ROOT}}", "{{ASSISTANT_NAME}}", "{{OPERATOR_NAME}}")
    if not any(tok in content for tok in ALL_TOKENS):
        return content

    profile = _load_operator_profile(root)

    # Step 1: expand {{PATHWAY}} first (persona block may contain name tokens
    # that must be picked up by the single substitution pass below).
    if "{{PATHWAY}}" in content:
        content = content.replace(
            "{{PATHWAY}}", _render_pathway_block(root, profile["pathway"])
        )

    # Step 2: single-pass substitution — re.sub advances past the replacement
    # text, so values containing literal token strings are never re-matched.
    token_map = {
        "{{TESS_ROOT}}":      str(root),
        "{{ASSISTANT_NAME}}": profile["assistant_name"],
        "{{OPERATOR_NAME}}":  profile["operator_name"],
    }
    remaining = {k: v for k, v in token_map.items() if k in content}
    if remaining:
        pattern = re.compile("|".join(re.escape(k) for k in remaining))
        content = pattern.sub(lambda m: remaining[m.group(0)], content)

    return content


def local_md_path(live_path: Path) -> Path:
    """Given a live path like conductor/guardrails.md → conductor/guardrails.local.md"""
    return live_path.parent / (live_path.stem + ".local.md")


def render_core_to_live(core_path: Path, live_path: Path, root: Path) -> bytes:
    """
    Produce the bytes that should appear at live_path given the current core source.
    Applies {{TESS_ROOT}} substitution and appends any .local.md shadow.
    For CLAUDE.md: delegates to render_claude_md().
    For settings.json: delegates to render_settings_json().
    Returns rendered bytes (UTF-8 for text, raw for binary).
    """
    if not core_path.exists():
        return b""

    # Special-case: CLAUDE.md rendered from template
    if live_path.name == "CLAUDE.md" and live_path == root / "CLAUDE.md":
        return render_claude_md(root).encode("utf-8")

    # Special-case: .claude/settings.json rendered from settings-core.json
    if live_path == root / ".claude" / "settings.json":
        return render_settings_json(root).encode("utf-8")

    raw = core_path.read_bytes()

    # Only apply text-mode rendering to text files
    try:
        text = raw.decode("utf-8")
    except UnicodeDecodeError:
        return raw  # Binary file — return as-is

    # Apply {{TESS_ROOT}} substitution
    text = apply_token_sub(text, root)

    # Append .local.md shadow if it exists (markdown files only)
    if live_path.suffix in (".md", ".markdown"):
        local = root / local_md_path(live_path)
        if local.exists():
            local_content = local.read_text(encoding="utf-8").rstrip()
            if local_content:
                text = text.rstrip() + "\n\n" + local_content + "\n"

    return text.encode("utf-8")


# ---------------------------------------------------------------------------
# CLAUDE.md template rendering
# ---------------------------------------------------------------------------

def parse_operator_stub(content: str, path: Path) -> str:
    """
    Parse an operator stub file. Returns the injectable content.
    Stubs with 'inject: false' frontmatter return empty string.
    Files without stub frontmatter return their full content.
    """
    stripped = content.strip()

    # Pattern: optional <!-- comment --> then --- zone: ... inject: ... ---
    # Strip leading HTML comment if present
    after_comment = stripped
    if stripped.startswith("<!--"):
        end = stripped.find("-->")
        if end != -1:
            after_comment = stripped[end + 3:].strip()

    # Check for YAML frontmatter block
    if after_comment.startswith("---"):
        second_dashes = after_comment.find("---", 3)
        if second_dashes != -1:
            fm_text = after_comment[3:second_dashes].strip()
            try:
                fm = yaml.safe_load(fm_text)
            except yaml.YAMLError:
                fm = {}
            if isinstance(fm, dict):
                inject = fm.get("inject", True)
                if not inject:
                    return ""
                # Return everything after the closing ---
                rest = after_comment[second_dashes + 3:].strip()
                return rest

    # No stub frontmatter — return full content
    return stripped


def render_claude_md(root: Path) -> str:
    """
    Render CLAUDE.md from CLAUDE.md.tpl + operator/ stubs + .local.md shadow.
    """
    tpl_path = root / CORE_DIR / "templates" / "CLAUDE.md.tpl"
    if not tpl_path.exists():
        sys.exit(f"tessctl render: template not found at {tpl_path}")

    tpl = tpl_path.read_text(encoding="utf-8")

    # Resolve core fragment tokens
    for token, rel_path in CLAUDE_TOKEN_MAP.items():
        frag_path = root / rel_path
        if frag_path.exists():
            content = frag_path.read_text(encoding="utf-8").strip()
        else:
            content = f"<!-- MISSING: {rel_path} -->"
        tpl = tpl.replace(token, content)

    # Resolve operator tokens (with inject: true/false logic)
    for token, rel_path in OPERATOR_TOKEN_MAP.items():
        op_path = root / rel_path
        if op_path.exists():
            raw = op_path.read_text(encoding="utf-8")
            content = parse_operator_stub(raw, op_path)
        else:
            content = ""
        tpl = tpl.replace(token, content)

    # Append CLAUDE.md.local.md if it exists
    local = root / "CLAUDE.md.local.md"
    if local.exists():
        local_content = local.read_text(encoding="utf-8").strip()
        if local_content:
            tpl = tpl.rstrip() + "\n\n" + local_content + "\n"

    # M4/M6: apply operator token substitution to the fully-assembled CLAUDE.md.
    # This resolves {{ASSISTANT_NAME}}, {{OPERATOR_NAME}}, and {{TESS_ROOT}} in
    # both core fragments (via CLAUDE_TOKEN_MAP) and operator stubs (OPERATOR_TOKEN_MAP).
    tpl = apply_token_sub(tpl, root)

    return tpl


def render_settings_json(root: Path) -> str:
    """
    Render .claude/settings.json from .tess/core/settings-core.json
    with {{TESS_ROOT}} substituted.
    """
    src = root / CORE_DIR / "settings-core.json"
    if not src.exists():
        sys.exit(f"tessctl render: settings-core.json not found at {src}")
    raw = src.read_text(encoding="utf-8")
    rendered = apply_token_sub(raw, root)
    # Validate it's still valid JSON after substitution
    try:
        json.loads(rendered)
    except json.JSONDecodeError as e:
        sys.exit(f"tessctl render: settings-core.json renders to invalid JSON: {e}")
    return rendered


# ---------------------------------------------------------------------------
# Manifest glob matching
# ---------------------------------------------------------------------------

def path_matches_globs(rel_path: str, globs: list) -> bool:
    """True if rel_path matches any glob in the list (fnmatch-based)."""
    p = rel_path.replace(os.sep, "/")
    for pattern in globs:
        pattern = pattern.replace(os.sep, "/")
        # Support ** as a recursive match
        pat_re = fnmatch.translate(pattern.replace("**", "\x00"))
        pat_re = pat_re.replace("\\x00", ".*")
        if re.match(pat_re, p):
            return True
        # Simple fnmatch fallback for non-** patterns
        if fnmatch.fnmatch(p, pattern):
            return True
    return False


# ---------------------------------------------------------------------------
# Snapshot
# ---------------------------------------------------------------------------

def snapshot_live_tree(root: Path, lock: dict) -> str:
    """
    Snapshot all core-managed live files to .tess/snapshots/<ts>/.
    Keeps last MAX_SNAPSHOTS FULL snapshots; prunes oldest full ones only.
    Single-file -pre snapshots are excluded from the prune count (M2).
    Returns the snapshot timestamp string.
    """
    ts = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H-%M-%SZ")
    snap_dir = root / SNAPSHOTS_DIR / ts
    snap_dir.mkdir(parents=True, exist_ok=True)

    # N1: .kind marker removed — it was never read by rollback (classification is
    # by -pre name suffix) and was being blindly copied into the live repo root on
    # every full-snapshot rollback.

    files = lock.get("files", {})
    for core_key, attrs in files.items():
        live_path_rel = attrs.get("live_path")
        if not live_path_rel:
            continue
        live = root / live_path_rel
        if live.exists():
            dst = snap_dir / live_path_rel
            dst.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(live, dst)

    # Also snapshot tess.lock itself
    lock_src = root / LOCK_FILE
    if lock_src.exists():
        shutil.copy2(lock_src, snap_dir / "tess.lock.snapshot")

    # Prune old snapshots via shared helper (N2 + LOW-2)
    _prune_snapshots(root)

    return ts


def _prune_snapshots(root: Path) -> None:
    """
    Prune old snapshots independently per kind (N2 + Reid LOW-2).

    Full snapshots: cap at MAX_SNAPSHOTS (default 5).
    Single-file -pre snapshots: cap at MAX_PRE_SNAPSHOTS (default 20).

    Called from both snapshot_live_tree (full snapshot) and snapshot_single_file
    (single-file -pre snapshot) so that -pre snapshots are pruned eagerly rather
    than only at full-snapshot time.
    """
    snaps_root = root / SNAPSHOTS_DIR
    if not snaps_root.exists():
        return
    all_snaps = sorted(snaps_root.iterdir(), key=lambda p: p.stat().st_mtime)
    full_snaps = [s for s in all_snaps if not s.name.endswith("-pre")]
    pre_snaps  = [s for s in all_snaps if s.name.endswith("-pre")]
    while len(full_snaps) > MAX_SNAPSHOTS:
        oldest = full_snaps.pop(0)
        shutil.rmtree(oldest)
    while len(pre_snaps) > MAX_PRE_SNAPSHOTS:
        oldest = pre_snaps.pop(0)
        shutil.rmtree(oldest)


def snapshot_single_file(root: Path, live_rel: str) -> str:
    """
    Snapshot one live file before overwriting (defect #6 restore fix).
    Written into .tess/snapshots/<ts>-pre/ so it is human-findable and
    compatible with tessctl rollback --to <ts>.

    Returns the snapshot DIRECTORY NAME (the bare ts string, e.g.
    '2026-06-27T12-34-56Z-pre') so callers can pass it directly to rollback.
    This fixes the LOW correctness issue where cmd_reset printed the full file
    path while rollback expects the directory name.
    """
    ts = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H-%M-%SZ-pre")
    snap_dir = root / SNAPSHOTS_DIR / ts
    snap_dir.mkdir(parents=True, exist_ok=True)
    src = root / live_rel
    if src.exists():
        dst = snap_dir / live_rel
        dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, dst)
    # Prune eagerly so single-file -pre snapshots don't accumulate unbounded (LOW-2)
    _prune_snapshots(root)
    return ts


# ---------------------------------------------------------------------------
# Modified.json provenance log
# ---------------------------------------------------------------------------

def load_modified(root: Path) -> list:
    mj = root / MODIFIED_JSON
    if mj.exists():
        try:
            return json.loads(mj.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            return []
    return []


def save_modified(root: Path, events: list) -> None:
    mj = root / MODIFIED_JSON
    mj.parent.mkdir(parents=True, exist_ok=True)
    mj.write_text(json.dumps(events, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def record_capture_event(root: Path, core_key: str, live_path: str, source: str, diff_text: str, rationale: str) -> None:
    events = load_modified(root)
    events.append({
        "evt_id": f"evt_{len(events) + 1:04d}",
        "path": live_path,
        "core_key": core_key,
        "source": source,
        "agent": "tessctl-capture",
        "ts": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z",
        "diff": diff_text[:4000],  # cap at 4KB
        "rationale": rationale,
    })
    save_modified(root, events)


# ---------------------------------------------------------------------------
# Doctor check (per-file integrity)
# ---------------------------------------------------------------------------

def doctor_check_file(core_key: str, attrs: dict, root: Path) -> dict:
    """
    Returns a dict with keys: core_key, live_path, lock_status, tier,
    is_security, pristine, drift, core_tamper, issues.

    Two independent checks (defect #3):
      A. Core integrity: sha256(core file bytes) == base_sha in tess.lock.
         Detects .tess/core tampering even if the live file was also patched
         to match (the blind spot in a freshly-rendered comparison).
      B. Live drift: sha256(render_core_to_live(...)) != sha256(live_path).
         Detects in-place edits by the agent or operator.
    """
    live_rel = attrs.get("live_path")
    file_status = attrs.get("status", "core-managed")
    is_sec = is_security_tier(core_key, attrs)  # single predicate

    result = {
        "core_key": core_key,
        "live_path": live_rel,
        "lock_status": file_status,
        "tier": attrs.get("tier", "normal"),
        "is_security": is_sec,
        "pristine": None,
        "issues": [],
        "staged_warn": [],   # Non-failing WARN lines for staged entries that are un-recruitable
        "drift": False,
        "core_tamper": False,
    }

    if live_rel is None:
        if file_status == "staged":
            # Staged with no live_path: un-recruitable — surface a WARN but do not fail.
            result["staged_warn"].append(
                f"no live_path in lock (un-recruitable): {core_key}"
            )
            result["pristine"] = True
            return result

        # R1: core-internal files (no live_path, e.g. .tess/core/personas/*.md).
        # Run Check A (base_sha core-integrity) only — there is no live file to drift.
        # This ensures that tampering a persona file (which splices into
        # conductor/personality.md via {{PATHWAY}}) is detected even though the
        # persona file is never written to the live tree directly.
        base_sha_val = attrs.get("base_sha", "")
        if base_sha_val:
            core_path_ci = root / core_key
            if not core_path_ci.exists():
                result["issues"].append(f"core file missing: {core_key}")
                result["pristine"] = False
            else:
                core_sha_ci = sha256_file(core_path_ci)
                result["core_sha"] = core_sha_ci
                result["base_sha"] = base_sha_val
                if core_sha_ci != base_sha_val:
                    result["core_tamper"] = True
                    severity = "SECURITY-TIER CORE TAMPER" if is_sec else "CORE TAMPER"
                    result["issues"].append(
                        f"{severity} — .tess/core bytes differ from base_sha; "
                        f"lock or core file was modified outside tessctl"
                    )
                    result["pristine"] = False
                else:
                    result["pristine"] = True
            return result

        # No live_path and no base_sha — nothing checkable.
        result["issues"].append("no live_path in lock")
        return result

    core_path = root / core_key
    live_path = root / live_rel

    # Check core file exists
    if not core_path.exists():
        if file_status == "staged":
            # Staged with missing core: un-recruitable — surface a WARN but do not fail.
            result["staged_warn"].append(
                f"core file missing (un-recruitable): {core_key}"
            )
            result["pristine"] = True
        else:
            result["issues"].append(f"core file missing: {core_key}")
            result["pristine"] = False
        return result

    # ---- Check A: core integrity against base_sha (defect #3) ----
    base_sha = attrs.get("base_sha", "")
    if base_sha:
        core_sha = sha256_file(core_path)
        result["core_sha"] = core_sha
        result["base_sha"] = base_sha
        if core_sha != base_sha:
            result["core_tamper"] = True
            severity = "SECURITY-TIER CORE TAMPER" if is_sec else "CORE TAMPER"
            result["issues"].append(
                f"{severity} — .tess/core bytes differ from base_sha; "
                f"lock or core file was modified outside tessctl"
            )

    # Check live file exists
    if not live_path.exists():
        if file_status in ("user-created", "staged"):
            # staged = intentionally benched (absent from live is the correct state).
            # user-created = never materialized by tessctl.
            result["pristine"] = True
            return result
        result["issues"].append(f"live file missing: {live_rel}")
        result["pristine"] = False
        return result

    # For user-created: don't touch
    if file_status == "user-created":
        result["pristine"] = True
        return result

    # For staged: intentionally benched. Absent from live was already handled above.
    # If the live file IS somehow present (e.g. bench was not run after a manual install),
    # treat like 'held' — drift silently, no error raised.
    if file_status == "staged":
        result["pristine"] = True
        return result

    # quarantined: live should contain the PINNED authoritative version
    # (doctor keeps alarming until tessctl approve is run)
    if file_status == "quarantined":
        q_path = root / QUARANTINE_DIR / live_rel
        result["issues"].append(
            f"QUARANTINED — attempted edit recorded at {QUARANTINE_DIR}/{live_rel}; "
            f"authoritative version is live; run `tessctl approve {live_rel} --rationale ...` to accept"
        )
        result["pristine"] = False
        result["drift"] = True
        return result

    # ---- Check B: live drift (compare live to freshly-rendered core) ----
    expected_bytes = render_core_to_live(core_path, live_path, root)
    expected_sha = sha256_bytes(expected_bytes)
    live_sha = sha256_file(live_path)

    result["expected_sha"] = expected_sha
    result["live_sha"] = live_sha

    if expected_sha == live_sha and not result["core_tamper"]:
        result["pristine"] = True
    else:
        if expected_sha != live_sha:
            result["pristine"] = False
            result["drift"] = True

            if file_status == "core-managed":
                result["issues"].append("UNCAPTURED DRIFT — live file has been edited without capture")
            elif file_status == "locally-modified":
                result["issues"].append("captured drift (expected — file was modified and captured)")
            elif file_status == "user-published":
                result["issues"].append("drift hint — file diverges from upstream core (expected for published files)")
            elif file_status == "held":
                pass  # held files drift silently
            else:
                result["issues"].append(f"drift from core (status: {file_status})")

            if is_sec and file_status == "core-managed":
                result["issues"].append(
                    "SECURITY-TIER ALERT — security doctrine edited without quarantine/approval"
                )

    return result


# ---------------------------------------------------------------------------
# Command: init
# ---------------------------------------------------------------------------

def cmd_init(args, root: Path) -> None:
    """
    Scaffold a new project from the framework.
    On an existing repo with .tess/core committed: runs restore + render.
    With --from <upstream>: TODO (network).
    """
    if args.from_upstream:
        # TODO Phase 5: git clone upstream into .tess/core, generate tess.lock
        print(f"[TODO] --from <upstream> not yet implemented. Clone {args.from_upstream} to {root}/.tess/core manually.")
        print("Once .tess/core is in place, run `tessctl init` without --from to complete setup.")
        return

    core_path = root / CORE_DIR
    if not core_path.exists():
        sys.exit(
            f"tessctl init: .tess/core/ not found at {core_path}.\n"
            "  If this is a fresh repo, use --from <upstream> (Phase 5) or commit .tess/core first."
        )

    lock_path = root / LOCK_FILE
    if not lock_path.exists():
        sys.exit(
            f"tessctl init: {LOCK_FILE} not found.\n"
            "  Expected to be committed alongside .tess/core/."
        )

    # Create operator/ stubs if missing
    _scaffold_operator_stubs(root)

    # Create .tess/snapshots, .tess/staging dirs
    (root / SNAPSHOTS_DIR).mkdir(parents=True, exist_ok=True)
    (root / STAGING_DIR).mkdir(parents=True, exist_ok=True)

    print(f"tessctl init: using committed core at {core_path}")
    print(f"tessctl init: tess.lock version = {_lock_version(root)}")

    # Restore live tree
    _do_restore(root, verbose=True)

    # Render CLAUDE.md and settings.json
    _do_render(root, verbose=True)

    print("\ntessctl init: complete.")
    print("  Run `tessctl doctor` to verify integrity.")


def _scaffold_operator_stubs(root: Path) -> None:
    """Create operator/ stub files if they don't exist."""
    op_dir = root / "operator"
    op_dir.mkdir(exist_ok=True)

    # M6: profile.json — single source of operator state (name + pathway).
    # Written first so subsequent stubs that reference its defaults are consistent.
    profile_json = op_dir / "profile.json"
    if not profile_json.exists():
        _save_operator_profile(root, dict(_OPERATOR_PROFILE_DEFAULTS))
        print(
            f"  created operator/profile.json  "
            f"(defaults: assistant_name='Tess', operator_name='Operator', pathway='chief-of-staff')"
        )

    # M6: identity-stub uses {{ASSISTANT_NAME}} token so `tessctl rename` propagates
    # through to CLAUDE.md without editing the stub directly.
    identity = op_dir / "identity-stub.md"
    if not identity.exists():
        identity.write_text(
            "# {{ASSISTANT_NAME}} — AI Overseer & Conductor\n\n"
            "You are {{ASSISTANT_NAME}}: AI Chief of Staff, Overseer, and Conductor "
            "of an elite multi-agent intelligence system.\n\n"
            "You are the command layer, not the execution layer. You orchestrate. "
            "You never do specialist work yourself.\n\n"
            "Full doctrine: [conductor/](conductor/README.md)\n",
            encoding="utf-8",
        )
        print(f"  created operator/identity-stub.md")

    profile = op_dir / "user-profile.md"
    if not profile.exists():
        profile.write_text(
            "<!-- TESS OPERATOR STUB — user profile\n"
            "     Zone: {{OPERATOR_PROFILE}} in CLAUDE.md.tpl\n"
            "     Flip inject to true and run `tessctl render` to surface this in CLAUDE.md. -->\n"
            "---\nzone: OPERATOR_PROFILE\ninject: false\n---\n\n"
            "# Operator Profile\n\n[Describe the operator here.]\n",
            encoding="utf-8",
        )
        print(f"  created operator/user-profile.md")

    channels = op_dir / "org-channels.md"
    if not channels.exists():
        channels.write_text(
            "<!-- TESS OPERATOR STUB — organisation channel map\n"
            "     Zone: {{OPERATOR_CHANNELS}} in CLAUDE.md.tpl\n"
            "     Flip inject to true and run `tessctl render` to surface this in CLAUDE.md. -->\n"
            "---\nzone: OPERATOR_CHANNELS\ninject: false\n---\n\n"
            "# Channel Map\n\n[Define Telegram channels here.]\n",
            encoding="utf-8",
        )
        print(f"  created operator/org-channels.md")


def _lock_version(root: Path) -> str:
    try:
        lock = load_lock(root)
        fw = lock.get("framework", {})
        return f"{fw.get('track', '?')} v{fw.get('version', '?')}"
    except SystemExit:
        return "unknown"


# ---------------------------------------------------------------------------
# Command: restore
# ---------------------------------------------------------------------------

def _do_restore(root: Path, verbose: bool = False, dry_run: bool = False) -> dict:
    """
    Core restore logic. Returns counts dict.
    Copies .tess/core/<file> → live_path for all framework-owned files.

    Defect #5 (manifest write gate): every write is checked against
    owned_globs + never_touch BEFORE touching the filesystem.

    Defect #6 (silent-loss fix):
      - locally-modified files: skipped with a visible warning — restoring
        would discard the captured in-place edit.  Use `tessctl reset <path>`
        to explicitly discard.
      - Before overwriting any existing live file: snapshot the old bytes so
        the write is always recoverable.

    BLOCKER-1 (bulk-skip): GateError raised by guarded_write (or the dry-run
    gate pre-check) is caught per-iteration.  Files whose live path is a user
    symlink into a never_touch zone (e.g. .claude/skills/browser-use → .agents/)
    are skipped with a visible WARN rather than aborting the whole run.
    The standalone pre-check that used to call check_manifest_write_gate at the
    top of the loop is REMOVED: guarded_write calls the gate internally, and any
    GateError is now caught here.
    """
    lock = load_lock(root)
    manifest = load_manifest(root)
    owned = manifest.get("owned_globs", [])

    counts = {
        "updated": 0,
        "skipped_status": 0,
        "skipped_manifest": 0,
        "skipped_locally_modified": 0,
        "missing_core": 0,
        "skipped_gate": 0,
    }
    gate_skipped: list[str] = []

    files = lock.get("files", {})
    for core_key, attrs in files.items():
        live_rel = attrs.get("live_path")
        if live_rel is None:
            continue

        status = attrs.get("status", "core-managed")

        # Skip user-owned and staged (benched) statuses
        if status in ("user-published", "held", "user-created", "staged"):
            counts["skipped_status"] += 1
            if verbose:
                print(f"  skip [{status}]  {live_rel}")
            continue

        # Defect #6: locally-modified = do NOT silently discard.
        # Warn and skip; operator must explicitly `tessctl reset <path>`.
        if status == "locally-modified":
            counts["skipped_locally_modified"] += 1
            print(
                f"  WARN  skip [locally-modified]  {live_rel}  "
                f"— restoring would discard captured edit.  "
                f"Run `tessctl reset {live_rel}` to explicitly discard."
            )
            continue

        # Fast-path: if the path isn't in owned_globs there is no point running
        # the full gate (the gate would also reject it, but this is cheaper and
        # produces a cleaner message).  NOTE: owned check comes BEFORE the gate
        # call so the gate's GateError catch below is never pre-empted by this.
        if not path_matches_globs(live_rel, owned):
            counts["skipped_manifest"] += 1
            if verbose:
                print(f"  skip [not in manifest owned_globs]  {live_rel}")
            continue

        core_path = root / core_key
        if not core_path.exists():
            counts["missing_core"] += 1
            print(f"  WARN  core missing: {core_key}")
            continue

        live_path = root / live_rel
        rendered = render_core_to_live(core_path, live_path, root)

        # Check if update is actually needed
        if live_path.exists() and live_path.read_bytes() == rendered:
            if verbose:
                print(f"  ok    {live_rel}")
            continue

        if not dry_run:
            # Defect #6: snapshot existing live file before overwriting
            if live_path.exists():
                snapshot_single_file(root, live_rel)

            # H2/M3: manifest-gated atomic write (guarded_write calls gate internally).
            # BULK-SKIP (BLOCKER-1): catch GateError per-file; skip with WARN, do NOT abort.
            # guarded_write already sets 0755 for .sh files — no extra chmod needed.
            try:
                guarded_write(root, live_rel, rendered, op="restore", manifest=manifest)
            except GateError as e:
                counts["skipped_gate"] += 1
                gate_skipped.append(live_rel)
                print(f"  WARN  skipped {live_rel!r}: {e}")
                continue
        else:
            # Dry-run: check gate but don't abort on violation; print "would skip"
            try:
                check_manifest_write_gate(root, manifest, live_rel, op="restore")
            except GateError as e:
                counts["skipped_gate"] += 1
                gate_skipped.append(live_rel)
                print(f"  WARN  would skip {live_rel!r}: {e}")
                continue

        counts["updated"] += 1
        verb = "would update" if dry_run else "updated"
        if verbose:
            print(f"  {verb}  {live_rel}")

    if gate_skipped:
        print(
            f"\n  NOTE: {len(gate_skipped)} file(s) skipped by write-gate "
            f"(symlink-parent or never_touch violation — local version wins):\n"
            + "\n".join(f"    {p}" for p in gate_skipped)
        )

    return counts


def cmd_restore(args, root: Path) -> None:
    """
    Re-sync the live tree from .tess/core at the locked version.
    No network. Idempotent. The fresh-clone / CI command.
    Substitutes {{TESS_ROOT}} in all rendered files.
    """
    dry_run = getattr(args, "dry_run", False)
    if dry_run:
        print("tessctl restore --dry-run: showing what would change")
    else:
        print("tessctl restore: syncing live tree from .tess/core …")

    counts = _do_restore(root, verbose=True, dry_run=dry_run)

    print(f"\nrestore: {counts['updated']} {'would be ' if dry_run else ''}updated, "
          f"{counts['skipped_status']} skipped (user-owned), "
          f"{counts['skipped_gate']} skipped (write-gate / symlink), "
          f"{counts['missing_core']} missing core")

    if not dry_run:
        # Also render CLAUDE.md and settings.json
        _do_render(root, verbose=True)
        print("restore: complete.")


# ---------------------------------------------------------------------------
# Command: render
# ---------------------------------------------------------------------------

def _do_render(root: Path, verbose: bool = False) -> None:
    """
    Render CLAUDE.md and .claude/settings.json.
    M5: honors user-published status — skips those paths with a notice instead
        of silently overwriting a deliberately published file.
    H2/M3: uses guarded_write for all live writes (manifest-gated, atomic).
    """
    # Load lock to check user-published status (M5); graceful if lock absent (init)
    try:
        lock_data = load_lock(root)
        lock_files = lock_data.get("files", {})
    except SystemExit:
        lock_files = {}

    def _live_status(live_rel: str) -> str:
        for attrs in lock_files.values():
            if attrs.get("live_path") == live_rel:
                return attrs.get("status", "core-managed")
        return "core-managed"

    # CLAUDE.md
    claude_rel = "CLAUDE.md"
    if _live_status(claude_rel) == "user-published":
        if verbose:
            print(f"  skip (user-published)  {claude_rel}"
                  f"  — run `tessctl publish --force {claude_rel}` to re-seed from core")
    else:
        rendered_claude = render_claude_md(root).encode("utf-8")
        guarded_write(root, claude_rel, rendered_claude, op="render")
        if verbose:
            print(f"  rendered  {claude_rel}")

    # .claude/settings.json
    settings_rel = ".claude/settings.json"
    if _live_status(settings_rel) == "user-published":
        if verbose:
            print(f"  skip (user-published)  {settings_rel}"
                  f"  — run `tessctl publish --force {settings_rel}` to re-seed from core")
    else:
        rendered_settings = render_settings_json(root).encode("utf-8")
        guarded_write(root, settings_rel, rendered_settings, op="render")
        if verbose:
            print(f"  rendered  {settings_rel}")


    # M4/M6: re-render conductor files that carry name/pathway tokens.
    # conductor/** is in owned_globs — guarded_write is authorised.
    # These files are re-rendered after CLAUDE.md so the persona block and
    # name tokens resolve from the same operator/profile.json state.
    # QUINN: the client template carries {{ASSISTANT_NAME}} tokens; it must be
    # re-rendered whenever the conductor name changes (rename / set-operator).
    # Adding it here ensures `tessctl render` (and the auto-render in rename)
    # keeps the live template consistent with the operator profile.
    _NAME_BEARING = [
        (".tess/core/conductor/identity.md",    "conductor/identity.md"),
        (".tess/core/conductor/personality.md", "conductor/personality.md"),
        (".tess/core/templates/client/_template/CLAUDE.md", "clients/_template/CLAUDE.md"),
    ]
    for _core_key_rel, _live_rel in _NAME_BEARING:
        _core_path = root / _core_key_rel
        _live_path = root / _live_rel
        if not _core_path.exists():
            if verbose:
                print(f"  skip (core missing)  {_live_rel}")
            continue
        if _live_status(_live_rel) in ("user-published", "held"):
            if verbose:
                print(f"  skip ({_live_status(_live_rel)})  {_live_rel}")
            continue
        _rendered_bytes = render_core_to_live(_core_path, _live_path, root)
        try:
            guarded_write(root, _live_rel, _rendered_bytes, op="render")
            if verbose:
                print(f"  rendered  {_live_rel}")
        except GateError as e:
            if verbose:
                print(f"  WARN render: {_live_rel}: {e}")


def cmd_render(args, root: Path) -> None:
    """
    Render CLAUDE.md from CLAUDE.md.tpl + operator/ stubs.
    Resolve *.local.md append-first shadows.
    Render settings.json from settings-core.json ({{TESS_ROOT}} substituted).
    Render conductor/identity.md + conductor/personality.md (M4/M6 name tokens).
    """
    print("tessctl render …")
    _do_render(root, verbose=True)
    print("render: complete.")


# ---------------------------------------------------------------------------
# Command: doctor
# ---------------------------------------------------------------------------

def cmd_doctor(args, root: Path) -> None:
    """
    SHA-integrity check every core-managed file.
    Reports drift; security-tier files flagged distinctly.
    Manifest scope sanity check.
    """
    lock = load_lock(root)
    as_json = getattr(args, "json_out", False)
    fix = getattr(args, "fix", False)
    path_filter = getattr(args, "path", None)

    files = lock.get("files", {})
    results = []
    errors = 0
    warnings = 0

    for core_key, attrs in files.items():
        live_rel = attrs.get("live_path")
        file_status_pre = attrs.get("status", "core-managed")
        # Skip entries with no live_path UNLESS:
        #   (a) staged — must surface a STAGED-WARN (non-failing), OR
        #   (b) has a base_sha — R1 core-internal tamper tracking (e.g. persona files).
        if live_rel is None and not path_filter:
            has_base_sha = bool(attrs.get("base_sha", ""))
            if file_status_pre != "staged" and not has_base_sha:
                continue
            # Fall through: doctor_check_file handles staged_warn and core-internal Check A.
        if path_filter and live_rel != path_filter and core_key != path_filter:
            continue
        r = doctor_check_file(core_key, attrs, root)
        results.append(r)

        is_error = False
        for issue in r["issues"]:
            if "UNCAPTURED DRIFT" in issue or "SECURITY-TIER ALERT" in issue or "missing" in issue.lower():
                is_error = True

        if is_error:
            errors += 1
        elif r["issues"]:
            warnings += 1

    if as_json:
        print(json.dumps(results, indent=2, default=str))
        sys.exit(1 if errors else 0)

    # Human-readable output
    print(f"\ntessctl doctor — {len(results)} files checked\n")

    _drift_printed: set[str] = set()   # LOW-2: dedupe drift output by live_rel
    for r in results:
        live_rel = r.get("live_path") or r["core_key"]  # fallback to core_key when live_path is None
        lock_status = r.get("lock_status", "?")
        sec_badge = " [SECURITY]" if r.get("is_security") else ""

        if r.get("core_tamper"):
            print(f"  CORE-TAMPER {live_rel}{sec_badge}  — .tess/core bytes != base_sha ← CRITICAL")
            for issue in r["issues"]:
                print(f"             {issue}")
        elif lock_status == "quarantined":
            print(f"  QUARANTINED {live_rel}{sec_badge}  — run `tessctl approve {live_rel} --rationale ...`")
        elif lock_status == "staged":
            # Staged = intentionally benched; silent unless the entry is un-recruitable.
            for sw in r.get("staged_warn", []):
                print(f"  STAGED-WARN {live_rel or r['core_key']}  — {sw}")
        elif r.get("pristine") is True and not r["issues"]:
            print(f"  ok          {live_rel}{sec_badge}")
        elif r.get("drift") and lock_status == "locally-modified":
            print(f"  captured    {live_rel}{sec_badge}  (locally-modified)")
        elif r.get("drift") and lock_status == "user-published":
            print(f"  hint        {live_rel}{sec_badge}  (user-published, diverges from upstream)")
        elif r.get("drift") and lock_status == "core-managed":
            # R2: render-generated files drift when an operator stub or template is
            # updated but render has not been re-run.  The correct remedy is
            # `tessctl render` (re-sync from operator-state), NOT `tessctl capture`
            # (which would launder the stale render as a deliberate local modification).
            # LOW-2: skip duplicate live_rel output — multiple core keys may share
            # the same live_path (e.g. the 6 CLAUDE.md fragment entries). Track which
            # live paths have already been printed and suppress repeats.
            if live_rel not in _drift_printed:
                _drift_printed.add(live_rel)
                if live_rel in RENDER_GENERATED_LIVE_PATHS:
                    print(
                        f"  DRIFT       {live_rel}  ← run `tessctl render`"
                        f"  (re-sync from operator-state)"
                    )
                else:
                    sec_alarm = " *** SECURITY DRIFT ***" if r.get("is_security") else ""
                    print(f"  DRIFT       {live_rel}{sec_badge}{sec_alarm}  ← run `tessctl capture {live_rel}`")
                    if r.get("is_security"):
                        print(f"              ^^^ security-tier — capture will QUARANTINE (not locally-modify)")
        elif r["issues"]:
            print(f"  ISSUE       {live_rel}{sec_badge}  — " + "; ".join(r["issues"]))
        else:
            print(f"  ok          {live_rel}")

    # Summary — LOW-2: dedupe by live_path so 6 CLAUDE.md entries count as 1 drift.
    print(f"\n{'='*60}")
    pristine = sum(1 for r in results if r.get("pristine") and not r.get("drift") and r.get("lock_status") != "staged")
    staged_count = sum(1 for r in results if r.get("lock_status") == "staged")
    _drift_live_set = {
        r["live_path"] for r in results
        if r.get("drift") and r.get("lock_status") == "core-managed" and r.get("live_path")
    }
    drift_count = len(_drift_live_set)
    captured = sum(1 for r in results if r.get("drift") and r.get("lock_status") == "locally-modified")
    quarantined_count = sum(1 for r in results if r.get("lock_status") == "quarantined")
    core_tamper_count = sum(1 for r in results if r.get("core_tamper"))
    _sec_drift_live_set = {
        r["live_path"] for r in results
        if r.get("is_security") and r.get("drift")
        and r.get("lock_status") == "core-managed" and r.get("live_path")
    }
    security_drift = len(_sec_drift_live_set)

    print(
        f"pristine: {pristine}  |  staged (benched): {staged_count}  |  "
        f"uncaptured drift: {drift_count}  |  captured: {captured}  |  "
        f"quarantined: {quarantined_count}  |  core tamper: {core_tamper_count}  |  "
        f"security alerts: {security_drift}"
    )

    # Defect #2: --fix EXCLUDES security-tier (never route to capture/launder).
    # R2: --fix re-renders render-generated files instead of capturing them.
    # LOW-2: dedupe --fix passes — multiple core keys sharing a live_path would
    # otherwise call _capture_file N times for the same live file.
    if fix and drift_count > 0:
        print("\n--fix: resolving uncaptured drift (security-tier EXCLUDED) …")
        fixed_count = 0
        render_needed = False
        _fix_seen: set[str] = set()   # dedupe by live_path
        _fix_sec_skipped: set[str] = set()
        for r in results:
            if r.get("drift") and r.get("lock_status") == "core-managed":
                _lp = r.get("live_path", "")
                if _lp in _fix_seen:
                    continue  # already handled this live file
                if r.get("is_security"):
                    if _lp not in _fix_sec_skipped:
                        _fix_sec_skipped.add(_lp)
                        print(
                            f"  SKIP (security-tier)  {_lp}  "
                            f"— use `tessctl capture {_lp}` to quarantine, "
                            f"then `tessctl approve` with the operator rationale"
                        )
                    continue
                # R2: render-generated files must be re-rendered, never captured.
                if _lp in RENDER_GENERATED_LIVE_PATHS:
                    render_needed = True
                    _fix_seen.add(_lp)
                    continue
                _capture_file(
                    r["core_key"], r["live_path"], root, lock,
                    source="doctor --fix",
                    rationale="auto-captured by tessctl doctor --fix"
                )
                _fix_seen.add(_lp)
                fixed_count += 1
        save_lock(root, lock)
        if render_needed:
            print("  --fix: re-rendering render-generated files from operator-state …")
            _do_render(root, verbose=True)
        print(f"doctor --fix: {fixed_count} file(s) captured; render-generated files re-rendered. Re-run `tessctl doctor` to verify.")

    blocking = drift_count > 0 or quarantined_count > 0 or core_tamper_count > 0

    if core_tamper_count > 0:
        print(f"\ndoctor: FAIL — {core_tamper_count} core tamper(s) detected. "
              f"Restore .tess/core from git or run `tessctl rollback`.")
        sys.exit(1)
    if quarantined_count > 0:
        print(f"\ndoctor: FAIL — {quarantined_count} quarantined file(s) awaiting the operator approval.")
        sys.exit(1)
    if drift_count > 0:
        print(f"\ndoctor: FAIL — {drift_count} uncaptured drift(s). Update blocked until resolved.")
        # R2: if any drifted file is render-generated, the primary remedy is re-render.
        _rg_drift = any(
            r.get("drift") and r.get("lock_status") == "core-managed"
            and r.get("live_path") in RENDER_GENERATED_LIVE_PATHS
            for r in results
        )
        if _rg_drift:
            print("  Render-generated file(s) are stale — run `tessctl render` to re-sync.")
        print("  Options: `tessctl render` (for render-generated files), "
              "`tessctl capture <path>` (for hand-edited files, quarantines security-tier), "
              "or `tessctl doctor --fix` (auto-resolves both, excludes security-tier).")
        sys.exit(1)
    else:
        print("\ndoctor: OK")


# ---------------------------------------------------------------------------
# Command: capture
# ---------------------------------------------------------------------------

def _quarantine_file(core_key: str, live_rel: str, root: Path, lock: dict,
                     source: str, diff_text: str, rationale: str) -> None:
    """
    Security-tier quarantine path (defect #1).

    1. Restore the AUTHORITATIVE committed/base version as the live content,
       so a weakened guardrail never survives even temporarily.
    2. Save the attempted edit to .tess/quarantine/<live_rel> for review.
    3. Flip status → 'quarantined' in tess.lock.
    4. Record in modified.json.

    doctor keeps alarming on quarantined files.
    The operator runs `tessctl approve <path> --rationale "..."` out-of-band
    to accept the edit.  Rationale is hard-required in approve.
    """
    core_path = root / core_key
    live_path = root / live_rel
    q_path = root / QUARANTINE_DIR / live_rel

    # Save attempted edit to quarantine directory
    q_path.parent.mkdir(parents=True, exist_ok=True)
    if live_path.exists():
        shutil.copy2(live_path, q_path)

    # Pin the authoritative version back to live (H2/M3: manifest-gated + atomic)
    if core_path.exists():
        authoritative = render_core_to_live(core_path, live_path, root)
        guarded_write(root, live_rel, authoritative, op="quarantine")
        print(
            f"  QUARANTINED  {live_rel}  — security-tier file; "
            f"authoritative version pinned as live; "
            f"attempted edit saved to {QUARANTINE_DIR}/{live_rel}"
        )
    else:
        print(f"  WARN  quarantine: core file missing for {core_key}")

    # Update lock status
    if core_key in lock.get("files", {}):
        lock["files"][core_key]["status"] = "quarantined"
        lock["files"][core_key]["quarantined_at"] = datetime.datetime.now(
            datetime.timezone.utc
        ).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z"
        lock["files"][core_key]["quarantined_by"] = source

    # Record provenance
    record_capture_event(root, core_key, live_rel, source, diff_text,
                         rationale or "[QUARANTINED — edit to security-tier file]")


def _capture_file(core_key: str, live_rel: str, root: Path, lock: dict,
                  source: str = "manual", rationale: str = "") -> bool:
    """
    Mark a single file as locally-modified in tess.lock, or QUARANTINE it
    if it is security-tier (defect #1).
    Returns True if captured/quarantined, False if no change.
    """
    core_path = root / core_key
    live_path = root / live_rel

    if not live_path.exists():
        print(f"  WARN  live file not found: {live_rel}")
        return False

    expected_bytes = render_core_to_live(core_path, live_path, root) if core_path.exists() else b""
    live_bytes = live_path.read_bytes()

    if sha256_bytes(expected_bytes) == sha256_bytes(live_bytes):
        print(f"  no-op  {live_rel}  (live matches core — nothing to capture)")
        return False

    # Compute diff
    diff_text = ""
    with tempfile.NamedTemporaryFile(mode="wb", suffix=".base", delete=False) as f_base:
        f_base.write(expected_bytes)
        base_tmp = f_base.name

    try:
        result = subprocess.run(
            ["diff", "-u", "--label", f"core/{core_key}", "--label", f"live/{live_rel}",
             base_tmp, str(live_path)],
            capture_output=True, text=True
        )
        diff_text = result.stdout
    finally:
        os.unlink(base_tmp)

    attrs = lock.get("files", {}).get(core_key, {})

    # ---- Security-tier: QUARANTINE (never locally-modified) ----
    # Defect #1: capture of a security-tier file must not auto-flip to
    # locally-modified.  Pin authoritative, record attempt, require approval.
    if is_security_tier(core_key, attrs):
        _quarantine_file(core_key, live_rel, root, lock, source, diff_text, rationale)
        return True

    # ---- Normal tier: fail-loud on missing rationale for doctrine files ----
    tier = attrs.get("tier", "normal")
    if tier != "normal" and not rationale:
        sys.exit(
            f"tessctl capture: {live_rel} is non-normal tier ({tier}) — "
            f"--rationale is required for doctrine edits (fail-loud per spec §6)."
        )

    # ---- Normal tier: flip to locally-modified ----
    if core_key in lock.get("files", {}):
        lock["files"][core_key]["status"] = "locally-modified"
        lock["files"][core_key]["captured_at"] = datetime.datetime.now(
            datetime.timezone.utc
        ).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z"
        lock["files"][core_key]["captured_by"] = source

    # Record in modified.json
    record_capture_event(root, core_key, live_rel, source, diff_text, rationale)

    return True


def cmd_capture(args, root: Path) -> None:
    """
    Hash-detect a live core-managed file edited in place.
    Records it as locally-modified in tess.lock + logs provenance to .tess/modified.json.
    """
    lock = load_lock(root)
    target_path = getattr(args, "path", None)
    capture_all = getattr(args, "all", False)
    dry_run = getattr(args, "dry_run", False)
    rationale = getattr(args, "rationale", "") or ""
    source = getattr(args, "source", "manual") or "manual"

    files = lock.get("files", {})
    captured = 0

    for core_key, attrs in files.items():
        live_rel = attrs.get("live_path")
        if live_rel is None:
            continue

        status = attrs.get("status", "core-managed")

        # Filter by path if specified
        if target_path:
            if live_rel != target_path and core_key != target_path:
                continue
        elif not capture_all:
            # Default: scan all core-managed files for drift
            pass

        # Only capture core-managed files (locally-modified already captured)
        if status not in ("core-managed",) and not (capture_all or target_path):
            continue

        core_path = root / core_key
        live_path = root / live_rel

        if not live_path.exists() or not core_path.exists():
            continue

        expected_bytes = render_core_to_live(core_path, live_path, root)
        live_bytes = live_path.read_bytes()

        if sha256_bytes(expected_bytes) == sha256_bytes(live_bytes):
            continue  # No drift — nothing to capture

        if dry_run:
            print(f"  would capture  {live_rel}  (status: {status} → locally-modified)")
            captured += 1
            continue

        # M2 (bulk guard): _capture_file → _quarantine_file → guarded_write can
        # raise GateError if the security-tier file's live_rel fails the gate
        # (e.g. a poisoned lock entry with a never_touch live_path).  For a bulk
        # scan (capture --all / default), catch and skip-with-WARN so one bad
        # entry does not abort the entire scan.  For single-file `capture <path>`,
        # re-raise so main() calls sys.exit (hard-fail preserved).
        try:
            ok = _capture_file(core_key, live_rel, root, lock, source=source, rationale=rationale)
        except GateError as e:
            if target_path:
                raise  # Single-file: propagate to main() → sys.exit
            print(f"  WARN  skipped {live_rel!r} (gate): {e}")
            continue
        if ok:
            captured += 1
            # _quarantine_file / _capture_file already prints its own status line;

    if not dry_run and captured > 0:
        save_lock(root, lock)

    verb = "would capture" if dry_run else "captured"
    print(f"\ncapture: {verb} {captured} file(s)")

    if captured == 0 and not dry_run:
        print("  (no uncaptured drift found — live tree matches core)")


# ---------------------------------------------------------------------------
# Signed-tag fetch helpers
# ---------------------------------------------------------------------------

def _parse_gpg_fingerprint(raw_output: str) -> str:
    """
    Extract signing key fingerprint from `git verify-tag --raw` output.

    Handles two formats:
      [GNUPG:] VALIDSIG <fingerprint40> <date> ...    (machine-readable --raw)
      gpg:                using RSA key <fingerprint>  (human-readable fallback)

    Returns the fingerprint string (uppercased, no spaces) or '' if not found.
    """
    for line in raw_output.splitlines():
        parts = line.strip().split()
        # Machine-readable: [GNUPG:] VALIDSIG <fp> ...
        if len(parts) >= 3 and parts[0] == "[GNUPG:]" and parts[1] == "VALIDSIG":
            return parts[2].upper()
        # Human-readable fallback: "using RSA/ECDSA/... key <fp>"
        m = re.search(r"using\s+\S+\s+key\s+([0-9A-Fa-f]{16,})", line)
        if m:
            return m.group(1).upper()
    return ""


# _FULL_FP_RE: pinned trusted_key_fingerprint must be exactly 40 hex chars —
# the full fingerprint from `git verify-tag --raw` / VALIDSIG (subkey-aware).
# Short (16-char) key IDs are not accepted (C3 exact equality).
_FULL_FP_RE = re.compile(r"^[0-9A-Fa-f]{40}$")


def _verify_tag_secure(
    ref: str,
    cwd: str,
    trusted_fingerprint: str | None,
    root: Path,
    lock: dict,
    allow_tofu: bool = False,
) -> tuple[str, bool]:
    """
    Mandatory signed-tag verification with pinning + TOFU + isolated GNUPGHOME.

    Returns (signing_fingerprint, tofu_occurred).

    C1 — MANDATORY PINNING:
      If trusted_key_fingerprint is set: verify in an isolated GNUPGHOME seeded
      with ONLY the pinned key (not ambient ~/.gnupg).
      If empty/null AND allow_tofu=True: TOFU exception — verify with system
      keyring, record the full 40-char fingerprint to lock immediately, print a
      clear notice.  If empty/null AND allow_tofu=False (the default): HARD-REFUSE
      with a clear operator instruction (fail-closed first use).
    C3 — EXACT equality: no bidirectional endswith; full 40-char hex required.
    """
    if trusted_fingerprint:
        # C3: format validation — must be exactly 40 hex chars
        canon_pin = trusted_fingerprint.replace(" ", "").upper()
        if not _FULL_FP_RE.match(canon_pin):
            sys.exit(
                f"tessctl: SECURITY REJECT — framework.trusted_key_fingerprint "
                f"{trusted_fingerprint!r} is not a valid 40-hex-char fingerprint. "
                f"Correct it in tess.lock and retry."
            )

        # Isolated GNUPGHOME — seed with ONLY the pinned key
        isolated_gpg = Path(tempfile.mkdtemp(prefix="tessctl_gpg_"))
        try:
            try:
                isolated_gpg.chmod(0o700)
            except OSError:
                pass

            # Export pinned key from system keyring by exact fingerprint
            export_r = subprocess.run(
                ["gpg", "--export", "--armor", canon_pin],
                capture_output=True,
            )
            if export_r.returncode != 0 or not export_r.stdout.strip():
                sys.exit(
                    f"tessctl: SECURITY REJECT — cannot export pinned key "
                    f"{trusted_fingerprint!r} from system GPG keyring.\n"
                    f"  Import the signer's public key first: gpg --import <key.asc>"
                )

            subprocess.run(
                ["gpg", "--homedir", str(isolated_gpg), "--import"],
                input=export_r.stdout, capture_output=True,
            )
            # Set ultimate trust so verify-tag does not fail on untrusted-key warning
            subprocess.run(
                ["gpg", "--homedir", str(isolated_gpg), "--import-ownertrust"],
                input=f"{canon_pin}:6:\n".encode(), capture_output=True,
            )

            isolated_env = {**os.environ, "GNUPGHOME": str(isolated_gpg)}
            vr = subprocess.run(
                ["git", "verify-tag", "--raw", ref],
                capture_output=True, text=True, cwd=cwd, env=isolated_env,
            )
        finally:
            shutil.rmtree(str(isolated_gpg), ignore_errors=True)

        if vr.returncode != 0:
            sys.exit(
                f"tessctl: SECURITY REJECT — tag {ref!r} failed isolated-keyring "
                f"signature verification.\n"
                f"  Expected signing key: {trusted_fingerprint}\n"
                f"  verify-tag output: {(vr.stdout + vr.stderr).strip()}\n"
                f"  No files were extracted."
            )

        raw_gpg = vr.stdout + vr.stderr
        signing_fp = _parse_gpg_fingerprint(raw_gpg)
        canon_signing = signing_fp.replace(" ", "").upper()

        if not canon_signing:
            sys.exit(
                f"tessctl: SECURITY REJECT — could not extract fingerprint from "
                f"isolated verify-tag output. No files extracted."
            )

        # C3: EXACT equality (not bidirectional endswith)
        if canon_signing != canon_pin:
            sys.exit(
                f"tessctl: SECURITY REJECT — tag {ref!r} signed by wrong key.\n"
                f"  pinned:  {trusted_fingerprint}\n"
                f"  signing: {signing_fp}\n"
                f"  Exact 40-char match required (C3). No files extracted."
            )

        print(f"  signature OK (isolated keyring) — fingerprint matches pinned key")
        return signing_fp, False

    else:
        # C1: No pin — fail-closed by default.  TOFU only when allow_tofu=True.
        if not allow_tofu:
            sys.exit(
                "tessctl: SECURITY REFUSE — framework.trusted_key_fingerprint is not set "
                "in tess.lock.\n"
                "  By default, tessctl does NOT trust-on-first-use (fail-closed).\n\n"
                "  To proceed, choose one of:\n"
                "    a) Pin the signing-key fingerprint (recommended):\n"
                "         1. Import the signer's public key: gpg --import <key.asc>\n"
                "         2. Get the full 40-hex fingerprint: gpg --fingerprint <key-id>\n"
                "         3. Set framework.trusted_key_fingerprint in tess.lock to that value.\n"
                "    b) Explicit trust-on-first-use (one-time; pins the key automatically):\n"
                "         tessctl update --trust-on-first-use [--ref <tag>]\n"
                "         tessctl self-update --trust-on-first-use [--ref <tag>]\n\n"
                "  The pinned fingerprint must be the full 40-hex-char fingerprint from\n"
                "  `git verify-tag --raw` / VALIDSIG (subkey-aware)."
            )
        print(f"  TOFU mode — trusted_key_fingerprint not set; verifying with system keyring.")
        vr = subprocess.run(
            ["git", "verify-tag", "--raw", ref],
            capture_output=True, text=True, cwd=cwd,
        )

        if vr.returncode != 0:
            sys.exit(
                f"tessctl: SECURITY REJECT — tag {ref!r} failed signature verification.\n"
                f"  {(vr.stdout + vr.stderr).strip()}\n"
                f"  Only signed annotated tags may be fetched. No files extracted."
            )

        raw_gpg = vr.stdout + vr.stderr
        signing_fp = _parse_gpg_fingerprint(raw_gpg)
        if not signing_fp:
            sys.exit(
                f"tessctl: SECURITY REJECT — tag {ref!r} was verified but no fingerprint "
                f"could be extracted. Cannot establish TOFU pin. No files extracted."
            )

        # C3: validate the extracted fingerprint is full-length 40 hex chars
        canon_signing = signing_fp.replace(" ", "").upper()
        if not _FULL_FP_RE.match(canon_signing):
            sys.exit(
                f"tessctl: SECURITY REJECT — extracted fingerprint {signing_fp!r} is not "
                f"a valid 40-hex-char fingerprint. Cannot establish TOFU pin."
            )

        # TOFU: pin and save immediately
        print(
            f"\n  TOFU NOTICE: pin-on-first-use — signing key fingerprint recorded:\n"
            f"    {signing_fp}\n"
            f"  Pinned in tess.lock (framework.trusted_key_fingerprint).\n"
            f"  VERIFY THIS IS THE CORRECT KEY before trusting:\n"
            f"    gpg --fingerprint {signing_fp}\n"
            f"  Future fetches require a signature by exactly this key.\n"
        )
        lock.setdefault("framework", {})["trusted_key_fingerprint"] = signing_fp
        save_lock(root, lock)

        print(f"  signature OK (TOFU) — key pinned for future verification")
        return signing_fp, True


def fetch_to_staging(root: Path, ref: str, allow_tofu: bool = False) -> None:
    """
    Fetch the framework version at `ref` from upstream into .tess/staging/.

    Security model (CRITICAL):
      1. `ref` must be a non-empty git tag name (never a branch or raw commit SHA).
      2. The tag MUST be a signed annotated tag.  Signature is verified via
         `git verify-tag --raw` before ANY file is extracted.  Unsigned tags,
         tags with invalid signatures, or tags not in the local GPG keyring are
         ALL rejected with sys.exit — no extraction takes place.
      3. If `framework.trusted_key_fingerprint` is set in tess.lock, the
         signing key fingerprint must be an EXACT 40-hex-char match (C3 — no
         tail-match or short key IDs accepted).  The pinned value must be the
         full fingerprint of the signing key from `git verify-tag --raw` /
         VALIDSIG (subkey-aware; see _FULL_FP_RE).  Wrong-key tags are rejected
         even if the signature is otherwise valid.
      4. Archive extraction is hardened against path traversal: every destination
         path is resolved and asserted to remain inside .tess/staging/.  Absolute
         paths or `..` components in source filenames are also hard-rejected.

    After a successful, verified fetch, .tess/staging/ is populated with the
    .tess/core/ subtree from the upstream, mirroring the core_key structure used
    by _apply_per_file_resolution (staging/<core_key>).

    Exits non-zero on any security or network failure.
    """
    _check_tools("git")

    lock = load_lock(root)
    fw = lock.get("framework", {})
    upstream = fw.get("upstream", "").strip()
    trusted_fingerprint = (fw.get("trusted_key_fingerprint") or "").strip()

    if not upstream:
        sys.exit(
            "tessctl fetch: upstream not configured in tess.lock (framework.upstream).\n"
            "  Set it to the git repository URL and retry."
        )
    if not ref:
        sys.exit("tessctl fetch: ref must be a non-empty signed tag name (e.g. v2.0.0)")

    staging_dir = root / STAGING_DIR

    print(f"  upstream: {upstream}")
    print(f"  ref:      {ref}")

    with tempfile.TemporaryDirectory(prefix="tessctl_fetch_") as tmpdir:
        clone_dir = Path(tmpdir) / "clone"

        # -- F1: shallow clone at the target tag --
        print(f"  cloning {ref!r} …")
        r = subprocess.run(
            ["git", "clone", "--depth", "1", "--branch", ref,
             "--no-tags", upstream, str(clone_dir)],
            capture_output=True, text=True
        )
        if r.returncode != 0:
            sys.exit(
                f"tessctl fetch: clone failed for ref {ref!r}:\n"
                f"  {r.stderr.strip()}"
            )

        # -- F2: explicitly fetch the annotated tag object so verify-tag can read it --
        # (--no-tags on clone may have skipped the tag object; non-zero is tolerated
        #  because the tag object may already be present from the clone)
        subprocess.run(
            ["git", "fetch", "--depth=1", "origin",
             f"refs/tags/{ref}:refs/tags/{ref}"],
            capture_output=True, text=True, cwd=str(clone_dir)
        )

        # -- F2.5: C4 — verify ref resolves to an annotated tag object (not branch/commit) --
        cat_type_r = subprocess.run(
            ["git", "cat-file", "-t", ref],
            capture_output=True, text=True, cwd=str(clone_dir)
        )
        if cat_type_r.returncode != 0 or cat_type_r.stdout.strip() != "tag":
            sys.exit(
                f"tessctl fetch: SECURITY REJECT — ref {ref!r} resolves to "
                f"'{cat_type_r.stdout.strip()}', not an annotated tag object (C4).\n"
                f"  Only signed annotated tags may be fetched. No files extracted."
            )

        # -- F3: SIGNATURE VERIFICATION — mandatory pinning + TOFU + isolated GNUPGHOME --
        print(f"  verifying signature on {ref!r} …")
        _signing_fp, _tofu = _verify_tag_secure(
            ref, str(clone_dir), trusted_fingerprint or None, root, lock,
            allow_tofu=allow_tofu,
        )
        # If TOFU occurred, the fingerprint is now pinned in the saved lock;
        # update our in-memory trusted_fingerprint so downstream logic is consistent.
        if _tofu:
            trusted_fingerprint = _signing_fp

        # -- F5: extract .tess/core/ from clone → .tess/staging/ with traversal hardening --
        core_src = clone_dir / ".tess" / "core"
        if not core_src.exists():
            sys.exit(
                f"tessctl fetch: .tess/core/ not found in upstream at ref {ref!r}.\n"
                f"  The upstream may not be a valid Tess OS framework repository."
            )

        # Clear old staging content before populating (clean slate)
        if staging_dir.exists():
            shutil.rmtree(staging_dir)
        staging_dir.mkdir(parents=True)
        staging_dir_resolved = staging_dir.resolve()

        extracted = 0
        for src_file in core_src.rglob("*"):
            if src_file.is_dir():
                continue

            # C2: reject symlinks before any write (TOCTOU + symlink-escape prevention)
            if src_file.is_symlink():
                sys.exit(
                    f"tessctl fetch: SECURITY REJECT — upstream entry "
                    f"{str(src_file.relative_to(core_src))!r} is a symlink (C2).\n"
                    f"  Extraction aborted — no files were written."
                )

            # rel is relative to core_src, e.g. "conductor/guardrails.md"
            rel = src_file.relative_to(core_src)
            rel_str = str(rel).replace(os.sep, "/")

            # Hard-reject absolute paths or '..' traversal in source filename
            if os.path.isabs(rel_str) or ".." in Path(rel_str).parts:
                sys.exit(
                    f"tessctl fetch: PATH TRAVERSAL in upstream archive entry {rel_str!r}.\n"
                    f"  Extraction aborted — no files were written."
                )

            # C4: reject any '.git' path component (case-insensitive, trailing-dot-aware)
            _rel_parts = Path(rel_str).parts
            if any(p.lower().rstrip(". ") == ".git" for p in _rel_parts):
                sys.exit(
                    f"tessctl fetch: PATH TRAVERSAL — upstream entry {rel_str!r} contains "
                    f"'.git' path component (C4). Extraction aborted — no files written."
                )

            # Mirror the core_key structure: staging/.tess/core/<rel>
            # This matches the staging_path = staging_dir / core_key pattern in
            # _apply_per_file_resolution (core_key = ".tess/core/<rel>").
            dst = staging_dir / ".tess" / "core" / rel

            # Resolve and containment-check BEFORE writing
            try:
                dst_resolved = dst.resolve()
                dst_resolved.relative_to(staging_dir_resolved)
            except ValueError:
                sys.exit(
                    f"tessctl fetch: PATH TRAVERSAL — entry {rel_str!r} resolves outside "
                    f".tess/staging/.  Extraction aborted — no files were written."
                )

            dst.parent.mkdir(parents=True, exist_ok=True)
            # C2: follow_symlinks=False as defense-in-depth (symlinks already rejected above)
            shutil.copy2(src_file, dst, follow_symlinks=False)
            extracted += 1

        # Also copy upstream tess.lock to staging for new-file adoption (A2)
        upstream_lock_src = clone_dir / ".tess" / "tess.lock"
        if upstream_lock_src.exists():
            shutil.copy2(upstream_lock_src, staging_dir / "upstream-tess.lock", follow_symlinks=False)
            print(f"  extracted upstream tess.lock to staging")

        if extracted == 0:
            sys.exit(
                f"tessctl fetch: upstream .tess/core/ at {ref!r} appears empty.\n"
                f"  Nothing extracted."
            )

        print(f"  extracted {extracted} file(s) to .tess/staging/")


def _resolve_update_ref(args, lock: dict) -> str:
    """
    Determine the target ref for `tessctl update` or `tessctl self-update`.

    Priority:
      1. --ref <tag>  (explicit; takes precedence over --to)
      2. --to <version> (legacy semver arg; used as tag name directly)
      3. framework.upstream_ref in tess.lock (default — the pinned release tag)
    """
    ref = getattr(args, "ref", None) or getattr(args, "to", None)
    if not ref:
        fw = lock.get("framework", {})
        ref = fw.get("upstream_ref", "")
    if not ref:
        sys.exit(
            "tessctl: no --ref specified and framework.upstream_ref is not set in tess.lock.\n"
            "  Specify the signed release tag to fetch: --ref v2.0.0"
        )
    return ref


# ---------------------------------------------------------------------------
# Command: update
# ---------------------------------------------------------------------------

def cmd_update(args, root: Path) -> None:
    """
    Fetch a new framework version and apply per-file resolution.
    Merge engine: git subtree pull --prefix=.tess/core <upstream> <ref>
    Network-required for the fetch step (stubbed with a clear TODO).
    """
    dry_run = getattr(args, "dry_run", False) or getattr(args, "check", False)
    to_version = getattr(args, "to", None)

    lock = load_lock(root)
    fw = lock.get("framework", {})
    current_version = fw.get("version", "?")
    upstream = fw.get("upstream", "")

    print(f"tessctl update — current: {fw.get('track', 'v2')} v{current_version}")

    # Step 0: Unconditional snapshot
    print("\nStep 0: snapshot …")
    if not dry_run:
        ts = snapshot_live_tree(root, lock)
        print(f"  snapshot → .tess/snapshots/{ts}")
    else:
        print("  (dry-run: skipping snapshot)")

    # Step 1: Doctor gate — block on uncaptured drift AND unapproved quarantine.
    # M6: reuse doctor_check_file() so the detection rule lives in one place.
    # HIGH-1: render-generated drift (CLAUDE.md etc.) is NOT a blocker — Step 7
    # re-renders those files unconditionally.  Classify them separately so the gate
    # never tells the operator to `capture` a file that should never be captured.
    # LOW-2: dedupe by live_rel (set) so 6×-duplicate CLAUDE.md entries collapse
    # to one line in each list.
    print("\nStep 1: doctor gate …")
    files = lock.get("files", {})
    uncaptured: list[tuple[str, str]] = []
    render_stale: list[str] = []
    quarantined: list[tuple[str, str]] = []
    _gate_seen_live: set[str] = set()   # dedupe — same live_rel from multiple core keys
    for core_key, attrs in files.items():
        live_rel = attrs.get("live_path")
        if not live_rel:
            continue
        if live_rel in _gate_seen_live:
            continue  # already classified this live file — skip duplicate core keys
        r = doctor_check_file(core_key, attrs, root)
        # GAP 1 (parity with doctor): quarantined files block update — an
        # unapproved security decision must not be buried by a core pull.
        if r.get("lock_status") == "quarantined":
            _gate_seen_live.add(live_rel)
            quarantined.append((core_key, live_rel))
        elif r.get("drift") and r.get("lock_status") == "core-managed":
            _gate_seen_live.add(live_rel)
            # HIGH-1: render-generated files are stale render outputs, not hand edits.
            # Step 7 re-renders them; treat as informational, NOT a blocker.
            if live_rel in RENDER_GENERATED_LIVE_PATHS:
                render_stale.append(live_rel)
            else:
                uncaptured.append((core_key, live_rel))

    if quarantined or uncaptured:
        if render_stale:
            print(f"  INFO — {len(render_stale)} render-generated file(s) stale "
                  f"(Step 7 will re-render):")
            for lp in render_stale:
                print(f"    {lp}")
        if quarantined:
            print(f"  BLOCKED — {len(quarantined)} unapproved quarantined security file(s):")
            for ck, lp in quarantined:
                print(f"    {lp}  [SECURITY — quarantined]")
            print("  Run `tessctl approve <path> --rationale ...` (or `tessctl resolve`) "
                  "first, then retry update.")
        if uncaptured:
            print(f"  BLOCKED — {len(uncaptured)} uncaptured drift(s) found:")
            for ck, lp in uncaptured:
                print(f"    {lp}")
            print("  Run `tessctl capture` first, then retry update.")
        sys.exit(1)
    else:
        if render_stale:
            print(f"  INFO — {len(render_stale)} render-generated file(s) stale — "
                  f"Step 7 will re-render automatically")
        print("  doctor gate: PASS — no uncaptured drift, no quarantined files")

    # Step 2: Acquire update lock
    update_lock_path = root / UPDATE_LOCK
    if update_lock_path.exists():
        age = (datetime.datetime.now(datetime.timezone.utc) - datetime.datetime.fromtimestamp(update_lock_path.stat().st_mtime, tz=datetime.timezone.utc)).total_seconds()
        if age > 3600:
            print(f"  stale update.lock ({age:.0f}s old) — reclaiming")
            update_lock_path.unlink()
        else:
            sys.exit("tessctl update: another update is in progress (.tess/update.lock). Wait or remove it.")

    if not dry_run:
        update_lock_path.write_text(datetime.datetime.now(datetime.timezone.utc).isoformat(), encoding="utf-8")

    try:
        # Step 3: Mission check (advisory)
        mission_states = root / "conductor" / "mission-states.md"
        if mission_states.exists():
            print("\nStep 3: mission check — (advisory) update should run outside active missions")

        # Step 4: FETCH — signed-tag fetch from upstream (NETWORK REQUIRED)
        # Fetches the upstream at `target_ref`, verifies the tag signature, and
        # populates .tess/staging/ with the incoming .tess/core/ content.
        # fetch_to_staging() hard-exits on unsigned/invalid-signature tags,
        # wrong-key (if pinned), and any path traversal in the archive.
        print("\nStep 4: fetch …")
        if not upstream:
            sys.exit(
                "tessctl update: upstream not configured in tess.lock (framework.upstream).\n"
                "  Set framework.upstream to the git repository URL and retry."
            )

        target_ref = _resolve_update_ref(args, lock)
        _allow_tofu = getattr(args, "trust_on_first_use", False)
        if not dry_run:
            fetch_to_staging(root, target_ref, allow_tofu=_allow_tofu)
            # fetch_to_staging may TOFU-pin the signing key to tess.lock on disk
            # (when allow_tofu and no fingerprint was previously pinned).  Re-sync
            # that pin into our in-memory lock so the Step 8 save_lock() below does
            # not clobber the freshly recorded fingerprint with our stale copy.
            _disk_fw = (load_lock(root).get("framework", {}) or {})
            _disk_pin = (_disk_fw.get("trusted_key_fingerprint") or "").strip()
            if _disk_pin:
                lock.setdefault("framework", {})["trusted_key_fingerprint"] = _disk_pin
        else:
            print(f"  (dry-run: would fetch-and-verify {target_ref!r} from {upstream})")

        # Step 4.5: staging must be populated (dry-run skips the network call)
        staging_dir = root / STAGING_DIR
        staging_files = (
            [f for f in staging_dir.rglob("*") if f.is_file()]
            if staging_dir.exists() else []
        )
        if not staging_files and not dry_run:
            sys.exit(
                "tessctl update: .tess/staging/ is empty after fetch — unexpected.\n"
                "  This should not happen if fetch_to_staging succeeded.\n"
                "  Run `tessctl doctor` and `tessctl verify` to confirm integrity."
            )

        # Step 5 + 6: PLAN + APPLY per-file (staging is populated — real update)
        print("\nStep 5-6: plan and apply …")
        _apply_per_file_resolution(root, lock, dry_run=dry_run)

        # Step 6.5 / A1: ADVANCE CORE — sync staging into .tess/core for all tracked files
        # that have a staging counterpart.  This must happen AFTER per-file resolution
        # (merges use the OLD core as base — correct) and BEFORE re-pinning base_sha
        # (so the pin reflects the new upstream pristine bytes).
        if not dry_run:
            print("\nStep 6.5 (A1): advance core from staging …")
            staging_dir_adv = root / STAGING_DIR
            advanced = 0
            for core_key in list(lock.get("files", {}).keys()):
                staging_src = staging_dir_adv / core_key
                if not staging_src.exists():
                    continue
                if staging_src.is_symlink():
                    print(f"  WARN  advance core: skip symlink in staging: {core_key}")
                    continue
                core_path = root / core_key
                staging_bytes = staging_src.read_bytes()
                if core_path.exists() and core_path.read_bytes() == staging_bytes:
                    continue
                core_path.parent.mkdir(parents=True, exist_ok=True)
                tmp_fd_adv, tmp_path_adv = tempfile.mkstemp(
                    dir=str(core_path.parent), prefix=".tessctl_core_adv_"
                )
                try:
                    with os.fdopen(tmp_fd_adv, "wb") as fh:
                        fh.write(staging_bytes)
                    os.replace(tmp_path_adv, str(core_path))
                except Exception:
                    try:
                        os.unlink(tmp_path_adv)
                    except OSError:
                        pass
                    raise
                advanced += 1
            print(f"  advanced {advanced} core file(s) from staging")

        # Step 6.6 / A2: ADOPT NEW FILES — detect files present in staging but absent
        # from the instance lock; write to live + copy to core + add lock entry.
        if not dry_run:
            print("\nStep 6.6 (A2): adopt new upstream files …")
            staging_upstream_lock_path = root / STAGING_DIR / "upstream-tess.lock"
            adopted = 0
            if staging_upstream_lock_path.exists():
                try:
                    upstream_lock_data = yaml.safe_load(
                        staging_upstream_lock_path.read_text(encoding="utf-8")
                    )
                except Exception as _e:
                    print(f"  WARN  A2: could not parse upstream tess.lock: {_e}")
                    upstream_lock_data = None

                if upstream_lock_data:
                    upstream_files = upstream_lock_data.get("files", {})
                    instance_file_keys = set(lock.get("files", {}).keys())
                    manifest_adopt = load_manifest(root)

                    for upstream_key, upstream_attrs in upstream_files.items():
                        if upstream_key in instance_file_keys:
                            continue
                        live_path_rel = upstream_attrs.get("live_path")
                        if not live_path_rel:
                            continue
                        staging_src = root / STAGING_DIR / upstream_key
                        if not staging_src.exists():
                            print(f"  WARN  A2: new file {upstream_key!r} not in staging, skip")
                            continue
                        if staging_src.is_symlink():
                            print(f"  WARN  A2: skip symlink {upstream_key!r}")
                            continue
                        staging_bytes = staging_src.read_bytes()
                        core_path_new = root / upstream_key
                        live_path_new = root / live_path_rel
                        rendered_new = render_core_to_live(staging_src, live_path_new, root)
                        try:
                            guarded_write(
                                root, live_path_rel, rendered_new,
                                op="update-adopt", manifest=manifest_adopt
                            )
                        except GateError as _ge:
                            print(f"  WARN  adopt: skip {live_path_rel!r} (gate): {_ge}")
                            continue
                        core_path_new.parent.mkdir(parents=True, exist_ok=True)
                        tmp_fd_new, tmp_path_new = tempfile.mkstemp(
                            dir=str(core_path_new.parent), prefix=".tessctl_core_adopt_"
                        )
                        try:
                            with os.fdopen(tmp_fd_new, "wb") as fh:
                                fh.write(staging_bytes)
                            os.replace(tmp_path_new, str(core_path_new))
                        except Exception:
                            try:
                                os.unlink(tmp_path_new)
                            except OSError:
                                pass
                            raise
                        new_sha = sha256_file(core_path_new)
                        lock["files"][upstream_key] = {
                            "status": "core-managed",
                            "tier": upstream_attrs.get("tier", "normal"),
                            "base_sha": new_sha,
                            "live_path": live_path_rel,
                            "last_updated": datetime.datetime.now(
                                datetime.timezone.utc
                            ).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z",
                        }
                        print(f"  adopted: {live_path_rel}  (new upstream file)")
                        adopted += 1
            if adopted:
                print(f"  A2: adopted {adopted} new file(s) from upstream")
            else:
                print(f"  A2: no new files to adopt")

        # Step 7: RENDER — runs AFTER A1 (core advance) and A2 (new files adopted) so
        # that CLAUDE.md.tpl, claude-md/ fragments, and settings-core.json are read from
        # the NEW upstream core.  Rendering before A1 would produce live CLAUDE.md and
        # .claude/settings.json from the OLD core, leaving them stale by one version and
        # causing doctor/verify to fail after any release that touches these templates.
        if not dry_run:
            print("\nStep 7: render (from new core, post-A1/A2) …")
            _do_render(root, verbose=True)

        # Step 8: RE-PIN lock (H1) + A1 base_sha advance + A3 version bump
        # Re-pin base_sha from the NOW-CURRENT core (after A1 advance) so that
        # verify/doctor see them as pristine instead of reporting CORE TAMPER.
        if not dry_run:
            print("\nStep 8: update lock …")
            repinned = 0
            for core_key, attrs in lock.get("files", {}).items():
                core_path = root / core_key
                if core_path.exists():
                    new_sha = sha256_file(core_path)
                    if attrs.get("base_sha") != new_sha:
                        lock["files"][core_key]["base_sha"] = new_sha
                        repinned += 1

            # A3: BUMP VERSION — set framework.version + upstream_ref to fetched tag
            _strip_v = target_ref.lstrip("v") if target_ref.startswith("v") else target_ref
            lock["framework"]["version"] = _strip_v
            lock["framework"]["upstream_ref"] = target_ref
            # Clear upstream_commit/digest if tracked (unknown after shallow clone)
            if lock["framework"].get("upstream_commit") is not None:
                lock["framework"]["upstream_commit"] = None
            if lock["framework"].get("upstream_digest") is not None:
                lock["framework"]["upstream_digest"] = None

            lock["framework"]["last_updated"] = datetime.datetime.now(
                datetime.timezone.utc
            ).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z"
            save_lock(root, lock)
            if repinned:
                print(f"  re-pinned base_sha for {repinned} file(s)")
            else:
                print(f"  base_sha: all entries already current")
            print(f"  A3: version bumped → {_strip_v} (upstream_ref: {target_ref})")

        print("\nupdate: complete")

    finally:
        if not dry_run and update_lock_path.exists():
            update_lock_path.unlink()


def _apply_per_file_resolution(root: Path, lock: dict, dry_run: bool = False) -> None:
    """
    Per-file decision matrix (§5.3):
      ours=live, base=core (pinned), theirs=staging (new version in .tess/staging)
    Uses git merge-file for 3-way merge.
    """
    staging_dir = root / STAGING_DIR
    files = lock.get("files", {})
    plan = []

    for core_key, attrs in files.items():
        live_rel = attrs.get("live_path")
        if not live_rel:
            continue

        status = attrs.get("status", "core-managed")
        core_path = root / core_key
        live_path = root / live_rel
        staging_path = staging_dir / core_key

        # Decision matrix
        if status == "user-published":
            action = "skip"
            reason = "user-published → skip; emit drift hint"
        elif status == "held":
            action = "skip"
            reason = "held → skip silently"
        elif status == "user-created":
            action = "skip"
            reason = "user-created → never touch"
        elif status == "staged":
            action = "skip"
            reason = "staged → benched; not in live tree"
        elif not core_path.exists():
            action = "skip"
            reason = "core file missing"
        elif not staging_path.exists():
            # No staging version = upstream unchanged
            if status == "locally-modified":
                action = "keep"
                reason = "locally-modified + no upstream change → keep"
            elif status == "patch-override":
                action = "keep"
                reason = "patch-override + no upstream change → keep"
            else:
                action = "fast-forward"
                reason = "no staging = treat as same as core"
        elif status == "locally-modified":
            action = "merge"
            reason = "locally-modified + upstream changed → 3-way merge"
        elif status == "patch-override":
            action = "patch-apply"
            reason = "patch-override → re-apply stored diff onto new core"
        else:
            # core-managed
            action = "fast-forward"
            reason = "core-managed → fast-forward from staging"

        plan.append({
            "core_key": core_key,
            "live_rel": live_rel,
            "status": status,
            "action": action,
            "reason": reason,
        })

    # Print plan
    for item in plan:
        print(f"  [{item['action']:12}] {item['live_rel']}  — {item['reason']}")

    if dry_run:
        return

    conflicts = []
    gate_skipped: list[str] = []

    # Apply — BLOCKER-1: all guarded_write calls are wrapped in try/except GateError.
    # Files rejected by the gate (e.g. live path is a symlink into never_touch) are
    # skipped with a visible WARN and appended to gate_skipped; the run continues.
    for item in plan:
        if item["action"] == "patch-apply":
            # Re-apply stored diff onto new core version.
            # B FIX (no-clobber): apply the patch to a TEMP copy of the new upstream;
            # only guarded_write to live on patch SUCCESS.  On failure: live is left
            # exactly as the operator's version; .rej is parked; conflict recorded.
            # The "Your version is LIVE" promise holds for every conflict route.
            core_key = item["core_key"]
            live_rel = item["live_rel"]
            core_path = root / core_key
            staging_path = staging_dir / core_key
            live_path = root / live_rel

            src = staging_path if staging_path.exists() else core_path
            if not src.exists():
                continue

            rendered = render_core_to_live(src, live_path, root)
            attrs = lock.get("files", {}).get(core_key, {})
            diff_text = attrs.get("override_diff", "")

            if diff_text:
                # Write new upstream to a temp file; patch that — never touch live first
                with tempfile.NamedTemporaryFile(suffix=".patch", delete=False, mode="w") as fp:
                    fp.write(diff_text)
                    patch_tmp = fp.name
                tmp_target_fd, tmp_target = tempfile.mkstemp(
                    suffix=".patchtarget", dir=str(live_path.parent)
                )
                try:
                    with os.fdopen(tmp_target_fd, "wb") as fh:
                        fh.write(rendered)
                    # Preflight: _check_tools("patch") already ran at cmd entry via
                    # _TOOL_REQUIREMENTS["update"], but wrap in FileNotFoundError for
                    # belt-and-suspenders (tool removed after startup, unusual PATH).
                    # Mirror the D3 tool-error handling from the merge branch:
                    # record conflict + "your version is LIVE", leave live untouched.
                    try:
                        patch_result = subprocess.run(
                            ["patch", "-p0", tmp_target, patch_tmp],
                            capture_output=True, text=True
                        )
                    except FileNotFoundError:
                        conflicts.append(live_rel)
                        print(
                            f"    PATCH TOOL ERROR: 'patch' not found on PATH for "
                            f"{live_rel}  (your version is LIVE — no files were changed)"
                        )
                        continue
                    if patch_result.returncode != 0:
                        # Patch failed — leave live EXACTLY as the operator's version
                        rej_path = live_path.with_name(live_path.name + ".rej")
                        tmp_rej_fd, tmp_rej = tempfile.mkstemp(
                            dir=str(rej_path.parent), prefix=".tessctl_rej_"
                        )
                        try:
                            with os.fdopen(tmp_rej_fd, "w", encoding="utf-8") as fh:
                                fh.write(diff_text)
                            os.replace(tmp_rej, str(rej_path))
                        except Exception:
                            try:
                                os.unlink(tmp_rej)
                            except OSError:
                                pass
                            raise
                        conflicts.append(live_rel)
                        stderr_note = (
                            f"\n    patch stderr: {patch_result.stderr.strip()}"
                            if patch_result.stderr.strip() else ""
                        )
                        print(
                            f"    PATCH FAILED: {live_rel} → {rej_path.name} "
                            f"(your version is live){stderr_note}"
                        )
                    else:
                        # Patch succeeded — write patched content to live
                        patched_bytes = Path(tmp_target).read_bytes()
                        try:
                            guarded_write(root, live_rel, patched_bytes, op="update-patch-apply")
                            print(f"    patch-applied: {live_rel}")
                        except GateError as e:
                            gate_skipped.append(live_rel)
                            print(f"  WARN  skipped {live_rel!r} (gate): {e}")
                finally:
                    try:
                        os.unlink(patch_tmp)
                    except OSError:
                        pass
                    try:
                        os.unlink(tmp_target)
                    except OSError:
                        pass
            else:
                # No override diff — just fast-forward with new upstream content
                try:
                    guarded_write(root, live_rel, rendered, op="update-patch-apply")
                    print(f"    patch-apply (no override diff): {live_rel}")
                except GateError as e:
                    gate_skipped.append(live_rel)
                    print(f"  WARN  skipped {live_rel!r} (gate): {e}")
            continue

        if item["action"] in ("skip", "keep", "fast-forward"):
            if item["action"] == "fast-forward":
                core_path = root / item["core_key"]
                staging_path = staging_dir / item["core_key"]
                live_path = root / item["live_rel"]
                src = staging_path if staging_path.exists() else core_path
                if src.exists():
                    rendered = render_core_to_live(src, live_path, root)
                    # H2/M3: manifest-gated atomic write
                    try:
                        guarded_write(root, item["live_rel"], rendered, op="update-fast-forward")
                    except GateError as e:
                        gate_skipped.append(item["live_rel"])
                        print(f"  WARN  skipped {item['live_rel']!r} (gate): {e}")
            continue

        if item["action"] == "merge":
            core_path = root / item["core_key"]
            staging_path = staging_dir / item["core_key"]
            live_path = root / item["live_rel"]

            if not staging_path.exists() or not core_path.exists() or not live_path.exists():
                continue

            # 3-way merge: base=core, ours=live, theirs=staging
            with tempfile.NamedTemporaryFile(suffix=".base", delete=False) as fb:
                fb.write(render_core_to_live(core_path, live_path, root))
                base_tmp = fb.name
            with tempfile.NamedTemporaryFile(suffix=".ours", delete=False) as fo:
                fo.write(live_path.read_bytes())
                ours_tmp = fo.name
            with tempfile.NamedTemporaryFile(suffix=".theirs", delete=False) as ft:
                ft.write(render_core_to_live(staging_path, live_path, root))
                theirs_tmp = ft.name

            try:
                # LOW: -L labels so conflict markers show readable names, not temp paths
                result = subprocess.run(
                    ["git", "merge-file", "--diff3",
                     "-L", f"{item['live_rel']} (ours)",
                     "-L", "(base)",
                     "-L", f"{item['live_rel']} (incoming)",
                     ours_tmp, base_tmp, theirs_tmp],
                    capture_output=True
                )
                merged_bytes = Path(ours_tmp).read_bytes()

                if result.returncode < 0:
                    # D3: tool error (killed by signal, binary missing, etc.) — surface stderr
                    stderr_txt = result.stderr.strip() if isinstance(result.stderr, str) else result.stderr.decode(errors="replace").strip()
                    print(
                        f"    MERGE TOOL ERROR: git merge-file exited {result.returncode} for "
                        f"{item['live_rel']}\n"
                        f"    stderr: {stderr_txt}"
                    )
                    conflicts.append(item["live_rel"])
                elif result.returncode == 0:
                    # Clean merge (H2/M3: manifest-gated atomic write)
                    try:
                        guarded_write(root, item["live_rel"], merged_bytes, op="update-merge")
                        print(f"    merged (clean): {item['live_rel']}")
                    except GateError as e:
                        gate_skipped.append(item["live_rel"])
                        print(f"  WARN  skipped {item['live_rel']!r} (gate): {e}")
                else:
                    # returncode > 0: conflict markers written to ours_tmp
                    conflict_dir = root / ".tess" / "conflicts"
                    conflict_dir.mkdir(parents=True, exist_ok=True)
                    conflict_file = conflict_dir / item["live_rel"].replace("/", "_")
                    conflict_file.write_bytes(merged_bytes)
                    conflicts.append(item["live_rel"])
                    print(f"    CONFLICT: {item['live_rel']} → .tess/conflicts/{conflict_file.name}")
                    print(f"    Resolve with: tessctl resolve {item['live_rel']}")
            finally:
                for tmp in [base_tmp, ours_tmp, theirs_tmp]:
                    try:
                        os.unlink(tmp)
                    except OSError:
                        pass

    if gate_skipped:
        print(
            f"\n  update: {len(gate_skipped)} file(s) skipped by write-gate "
            f"(symlink-parent or never_touch violation — local version wins):\n"
            + "\n".join(f"    {p}" for p in gate_skipped)
        )

    if conflicts:
        print(f"\n  {len(conflicts)} conflict(s) — update BLOCKED. Your version is LIVE.")
        print("  Resolve conflicts then re-run `tessctl update`, or `tessctl rollback` to undo.")
        sys.exit(1)


# ---------------------------------------------------------------------------
# Command: publish
# ---------------------------------------------------------------------------

def cmd_publish(args, root: Path) -> None:
    """
    Copy core→live, flip status to user-published, stamp @published-from.
    --force shows diff + confirms before seeding from latest core.
    """
    lock = load_lock(root)
    manifest = load_manifest(root)   # needed for write gate
    fw = lock.get("framework", {})
    version = fw.get("version", "?")
    track = fw.get("track", "v2")
    tag_sel = getattr(args, "tag", None)
    target_path = getattr(args, "path", None)
    force = getattr(args, "force", False)

    tag_groups = {
        "hooks":      [k for k, a in lock["files"].items() if "hooks/" in k],
        "doctrine":   [k for k, a in lock["files"].items() if "conductor/" in k],
        "settings":   [k for k in lock["files"] if "settings-core.json" in k],
        "entry-point": [k for k in lock["files"] if "CLAUDE.md.tpl" in k or "MANIFEST.md" in k],
    }

    # Select targets
    targets = []
    if tag_sel:
        group = tag_groups.get(tag_sel, [])
        if not group:
            print(f"tessctl publish: unknown tag '{tag_sel}'. Known: {', '.join(tag_groups)}")
            sys.exit(1)
        targets = group
    elif target_path:
        # Find by live_path or core_key
        for k, a in lock["files"].items():
            if a.get("live_path") == target_path or k == target_path:
                targets.append(k)
                break
        if not targets:
            sys.exit(f"tessctl publish: path not found in lock: {target_path}")
    else:
        sys.exit("tessctl publish: specify a <path> or --tag <selector>")

    # M1: track gate-rejected targets in bulk (--tag) mode.
    # Single-target publish keeps hard-fail (GateError re-raised to main()).
    gate_skipped: list[str] = []

    for core_key in targets:
        attrs = lock["files"].get(core_key, {})
        live_rel = attrs.get("live_path")
        if not live_rel:
            print(f"  skip  {core_key}  (no live_path)")
            continue

        core_path = root / core_key
        live_path = root / live_rel

        if force:
            # Show diff first
            if core_path.exists() and live_path.exists():
                expected_bytes = render_core_to_live(core_path, live_path, root)
                with tempfile.NamedTemporaryFile(suffix=".expected", delete=False) as fe:
                    fe.write(expected_bytes)
                    expected_tmp = fe.name
                result = subprocess.run(
                    ["git", "diff", "--no-index", "--stat", expected_tmp, str(live_path)],
                    capture_output=True, text=True
                )
                os.unlink(expected_tmp)
                if result.stdout:
                    print(f"\nDiff for {live_rel}:")
                    print(result.stdout)
                ans = input(f"  Re-seed {live_rel} from latest core? [y/N] ").strip().lower()
                if ans not in ("y", "yes"):
                    print(f"  skipped  {live_rel}")
                    continue

        # Copy core → live with render; apply @published-from stamp in memory;
        # then a SINGLE guarded_write (manifest-gated + atomic) — H1 fix.
        # The standalone check_manifest_write_gate call is removed: guarded_write
        # calls the gate internally, making this genuinely one gated atomic op.
        #
        # M1 (bulk guard): wrap guarded_write so a gate violation on one target
        # does NOT abort the entire --tag batch.  Only targets where guarded_write
        # SUCCEEDS get their lock status flipped to user-published; gate-skipped
        # targets are neither written nor mutated in the lock (no live/lock
        # divergence).  Single-target publish re-raises so main() calls sys.exit.
        if core_path.exists():
            rendered = render_core_to_live(core_path, live_path, root)
            if live_path.suffix in (".md", ".markdown"):
                try:
                    _content = rendered.decode("utf-8")
                except UnicodeDecodeError:
                    _content = None
                if _content is not None and "@published-from" not in _content:
                    stamp = (
                        f"# @published-from {track} v{version} — "
                        f"{datetime.date.today().isoformat()}"
                    )
                    rendered = (stamp + "\n\n" + _content).encode("utf-8")
            try:
                guarded_write(root, live_rel, rendered, op="publish", manifest=manifest)
            except GateError as e:
                if tag_sel:
                    # Bulk mode: skip this target, continue the batch
                    gate_skipped.append(live_rel)
                    print(f"  WARN  skipped {live_rel!r} (gate): {e}")
                    continue
                raise  # Single-target: propagate to main() → sys.exit

        # Update lock — only reached after a successful write (or when core_path
        # was missing, which is a no-op write).  Gate-skipped targets never reach
        # here, so the persisted lock exactly mirrors what was actually written.
        lock["files"][core_key]["status"] = "user-published"
        lock["files"][core_key]["published_from"] = f"{track} v{version}"
        lock["files"][core_key]["published_at"] = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z"

        print(f"  published  {live_rel}  (status → user-published)")

    save_lock(root, lock)

    if gate_skipped:
        print(
            f"\n  publish: {len(gate_skipped)} file(s) skipped by write-gate "
            f"(gate violation — live version unchanged, lock not mutated):\n"
            + "\n".join(f"    {p}" for p in gate_skipped)
        )

    print("\npublish: complete.")


# ---------------------------------------------------------------------------
# Command: override
# ---------------------------------------------------------------------------

def cmd_override(args, root: Path) -> None:
    """
    Record a diff of the live file vs core (base) as a patch-override.
    The diff is stored in tess.lock and re-applied on update.
    """
    target_path = getattr(args, "path", None)
    if not target_path:
        sys.exit("tessctl override: specify a <path>")

    lock = load_lock(root)
    files = lock.get("files", {})

    # Find the entry
    core_key = None
    live_rel = None
    for k, a in files.items():
        if a.get("live_path") == target_path or k == target_path:
            core_key = k
            live_rel = a.get("live_path", target_path)
            break

    if not core_key:
        sys.exit(f"tessctl override: path not found in tess.lock: {target_path}")

    core_path = root / core_key
    live_path = root / live_rel

    if not live_path.exists():
        sys.exit(f"tessctl override: live file not found: {live_rel}")

    if not core_path.exists():
        sys.exit(f"tessctl override: core file not found: {core_key}")

    # Compute diff
    expected_bytes = render_core_to_live(core_path, live_path, root)

    with tempfile.NamedTemporaryFile(suffix=".base", delete=False, mode="wb") as fb:
        fb.write(expected_bytes)
        base_tmp = fb.name

    try:
        result = subprocess.run(
            ["diff", "-u", "--label", f"a/{live_rel}", "--label", f"b/{live_rel}", base_tmp, str(live_path)],
            capture_output=True, text=True
        )
        diff_text = result.stdout
    finally:
        os.unlink(base_tmp)

    if not diff_text:
        print(f"override: {live_rel} is identical to core — no override to record")
        return

    # Defect #5: manifest write gate (the override writes the diff to lock, not to live,
    # but the APPLY step later writes to live — gate it here too for early rejection)
    manifest = load_manifest(root)
    check_manifest_write_gate(root, manifest, live_rel, op="override")

    # Store in lock
    lock["files"][core_key]["status"] = "patch-override"
    lock["files"][core_key]["override_diff"] = diff_text
    lock["files"][core_key]["override_recorded_at"] = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z"
    lock["files"][core_key]["base_sha"] = sha256_file(core_path)

    save_lock(root, lock)
    print(f"override: recorded patch for {live_rel}  ({len(diff_text.splitlines())} lines)")
    print("  On `tessctl update`, this patch will be re-applied to the new core version.")
    print("  If it fails to apply: {live_rel}.rej will be written and update will halt.")


# ---------------------------------------------------------------------------
# Command: rollback
# ---------------------------------------------------------------------------

def cmd_rollback(args, root: Path) -> None:
    """
    Restore from a .tess/snapshots/<ts> + rewrite tess.lock.
    Defaults to most recent snapshot.
    """
    to_ts = getattr(args, "to", None)
    snaps_dir = root / SNAPSHOTS_DIR

    if not snaps_dir.exists():
        sys.exit("tessctl rollback: no snapshots found (.tess/snapshots/ missing)")

    # M2: sort by mtime (explicit), not name; separate full vs. single-file -pre snapshots
    all_snaps = sorted(snaps_dir.iterdir(), key=lambda p: p.stat().st_mtime)
    if not all_snaps:
        sys.exit("tessctl rollback: no snapshots found")

    if to_ts:
        snap = snaps_dir / to_ts
        if not snap.exists():
            available = [s.name for s in all_snaps]
            sys.exit(f"tessctl rollback: snapshot '{to_ts}' not found.\n  Available: {', '.join(available)}")
    else:
        # Exclude -pre single-file snapshots from default rollback (M2)
        full_snaps = [s for s in all_snaps if not s.name.endswith("-pre")]
        if not full_snaps:
            sys.exit(
                "tessctl rollback: no full snapshots found.\n"
                "  (-pre single-file snapshots are excluded from default rollback;\n"
                "   use `tessctl rollback --to <ts>` to target a specific snapshot)"
            )
        snap = full_snaps[-1]  # Most recent full snapshot by mtime

    print(f"tessctl rollback: restoring from {snap.name} …")

    # Restore files from snapshot.
    # N1: skip .kind (unused marker that would land in the live repo root).
    # tess.lock.snapshot is handled separately below.
    # Cyra LOW: containment check on each rel path (defense-in-depth against a
    # tampered snapshot directory).  We do NOT run the full manifest allowlist —
    # snapshot content is the recovery source — but we DO contain the path:
    #   1. Reject absolute rel paths or .. traversal components.
    #   2. Resolve dst and assert it stays inside root.
    root_resolved = root.resolve()
    for src in snap.rglob("*"):
        if src.is_dir():
            continue
        if src.name in ("tess.lock.snapshot", ".kind"):
            continue
        rel = src.relative_to(snap)
        rel_str = str(rel).replace(os.sep, "/")

        # Step 1: reject absolute or traversal paths in the snapshot
        if os.path.isabs(rel_str) or ".." in Path(rel_str).parts:
            print(f"  WARN  rollback: skipping unsafe path {rel_str!r} (absolute or '..' traversal)")
            continue

        # Step 2: resolve and verify dst stays inside root
        try:
            dst = (root / rel).resolve()
            dst.relative_to(root_resolved)
        except (ValueError, OSError):
            print(f"  WARN  rollback: skipping out-of-tree path {rel_str!r} (escaped root)")
            continue

        dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, dst)
        print(f"  restored  {rel}")

    # Rewrite tess.lock from snapshot
    lock_snap = snap / "tess.lock.snapshot"
    if lock_snap.exists():
        shutil.copy2(lock_snap, root / LOCK_FILE)
        print(f"  restored  tess.lock (from snapshot)")

    print(f"\nrollback: complete — restored to {snap.name}")
    print("  Run `tessctl doctor` to verify.")


# ---------------------------------------------------------------------------
# Command: diff
# ---------------------------------------------------------------------------

def cmd_diff(args, root: Path) -> None:
    """
    Show core (rendered) vs live diff.
    Uses git diff --no-index for human-readable output.
    """
    target_path = getattr(args, "path", None)
    stat_only = getattr(args, "stat", False)
    lock = load_lock(root)
    files = lock.get("files", {})

    targets = {}
    if target_path:
        for k, a in files.items():
            if a.get("live_path") == target_path or k == target_path:
                targets[k] = a
                break
        if not targets:
            sys.exit(f"tessctl diff: path not found in tess.lock: {target_path}")
    else:
        # Show diff for all non-pristine files
        targets = {k: a for k, a in files.items() if a.get("live_path")}

    any_diff = False

    for core_key, attrs in targets.items():
        live_rel = attrs.get("live_path")
        if not live_rel:
            continue

        status = attrs.get("status", "core-managed")
        if status in ("user-created",):
            continue

        core_path = root / core_key
        live_path = root / live_rel

        if not core_path.exists() or not live_path.exists():
            continue

        expected_bytes = render_core_to_live(core_path, live_path, root)

        with tempfile.NamedTemporaryFile(suffix=".core", delete=False, mode="wb") as fe:
            fe.write(expected_bytes)
            expected_tmp = fe.name

        try:
            cmd = ["git", "diff", "--no-index"]
            if stat_only:
                cmd.append("--stat")
            cmd += [expected_tmp, str(live_path)]
            result = subprocess.run(cmd, capture_output=True, text=True)
            output = result.stdout

            if output:
                # Replace temp file path with readable labels
                output = output.replace(expected_tmp, f"core/{live_rel}")
                output = output.replace(str(live_path), f"live/{live_rel}")
                print(output, end="")
                any_diff = True
        finally:
            os.unlink(expected_tmp)

    if not any_diff:
        print("diff: no differences found — live tree matches core")


# ---------------------------------------------------------------------------
# Command: verify (defect #3)
# ---------------------------------------------------------------------------

def cmd_verify(args, root: Path) -> None:
    """
    Security audit: verify .tess/core bytes against committed base_sha to
    detect CORE tampering; flag security-tier drift and quarantined files.

    base_sha = sha256 of the RAW (un-substituted) .tess/core/<file> bytes
    at the pinned version (path-independent — spec defect #4).

    Exits non-zero on any core tamper, security drift, or quarantined file.
    """
    lock = load_lock(root)
    files = lock.get("files", {})

    core_tampers = []
    security_drifts = []
    normal_drifts = []
    _normal_drift_seen: set[str] = set()  # LOW-2: dedupe by live_rel across multiple core keys
    quarantined_files = []
    staged_warns = []   # Non-failing WARN lines for un-recruitable staged entries
    ok_count = 0

    print("\ntessctl verify — checking core integrity and security-tier status\n")

    for core_key, attrs in files.items():
        live_rel = attrs.get("live_path")
        file_status = attrs.get("status", "core-managed")

        # No live_path: handle staged (WARN) and core-internal (Check A) separately.
        if not live_rel:
            if file_status == "staged":
                msg = f"no live_path in lock (un-recruitable): {core_key}"
                staged_warns.append(msg)
                print(f"  STAGED-WARN  {core_key}  — {msg}")
                ok_count += 1
            elif attrs.get("base_sha"):
                # R1: core-internal file (e.g. .tess/core/personas/*.md) — Check A only.
                # No live tree entry exists; verify raw core bytes against base_sha.
                _ci_base_sha = attrs["base_sha"]
                _ci_core_path = root / core_key
                _ci_sec = is_security_tier(core_key, attrs)
                if _ci_core_path.exists():
                    _ci_core_sha = sha256_file(_ci_core_path)
                    if _ci_core_sha != _ci_base_sha:
                        _ci_badge = "[SECURITY]" if _ci_sec else ""
                        core_tampers.append((core_key, _ci_badge, _ci_base_sha, _ci_core_sha))
                        print(f"  CORE TAMPER {_ci_badge}  {core_key}  (core-internal — no live path)")
                        print(f"    expected: {_ci_base_sha}")
                        print(f"    got:      {_ci_core_sha}")
                    else:
                        ok_count += 1
                        print(f"  ok  {core_key}  (core-internal)")
                else:
                    core_tampers.append((core_key, "", _ci_base_sha, "sha256:MISSING"))
                    print(f"  CORE TAMPER  {core_key}  (core-internal — file missing)")
            continue

        sec = is_security_tier(core_key, attrs)
        core_path = root / core_key
        base_sha = attrs.get("base_sha", "")

        # Staged with missing core: un-recruitable — WARN but do not fail.
        if file_status == "staged" and not core_path.exists():
            msg = f"core file missing (un-recruitable): {core_key}"
            staged_warns.append(msg)
            print(f"  STAGED-WARN  {live_rel}  — {msg}")
            ok_count += 1
            continue

        # Check A: core file bytes vs base_sha (path-independent hash of raw bytes)
        if base_sha and core_path.exists():
            core_sha = sha256_file(core_path)
            if core_sha != base_sha:
                badge = "[SECURITY]" if sec else ""
                core_tampers.append((live_rel, badge, base_sha, core_sha))
                print(f"  CORE TAMPER {badge}  {live_rel}")
                print(f"    expected: {base_sha}")
                print(f"    got:      {core_sha}")
                continue

        # Check B: quarantined files still waiting for approval
        if file_status == "quarantined":
            quarantined_files.append(live_rel)
            print(f"  QUARANTINED [SECURITY]  {live_rel}  — awaiting tessctl approve")
            continue

        # Check C: security-tier drift (live modified without quarantine)
        if sec and file_status == "core-managed":
            live_path = root / live_rel
            if core_path.exists() and live_path.exists():
                expected_bytes = render_core_to_live(core_path, live_path, root)
                live_sha = sha256_file(live_path)
                if sha256_bytes(expected_bytes) != live_sha:
                    security_drifts.append(live_rel)
                    print(f"  SECURITY DRIFT  {live_rel}  — edited without quarantine; run `tessctl capture {live_rel}`")
                    continue

        # Check D (A4): NORMAL-tier live-vs-core drift — honest verify catches broken upgrades.
        # Without this check, a failed fast-forward or partial update gives a false all-clear.
        # staged files are intentionally absent from live; skip drift check for them.
        if file_status not in ("user-published", "user-created", "held", "locally-modified", "staged"):
            live_path = root / live_rel
            if core_path.exists() and live_path.exists():
                expected_bytes = render_core_to_live(core_path, live_path, root)
                live_sha = sha256_file(live_path)
                if sha256_bytes(expected_bytes) != live_sha:
                    # LOW-2: multiple core keys can map to the same live_rel (e.g. the 6
                    # CLAUDE.md fragment entries).  Only append + print once per live file.
                    if live_rel not in _normal_drift_seen:
                        _normal_drift_seen.add(live_rel)
                        badge = "[SECURITY]" if sec else ""
                        normal_drifts.append(live_rel)
                        # R2: render-generated files drift when a stub/template was updated
                        # but render has not been re-run; the remedy is `tessctl render`.
                        if live_rel in RENDER_GENERATED_LIVE_PATHS:
                            print(
                                f"  LIVE DRIFT {badge}  {live_rel}  "
                                f"— render-generated file is stale "
                                f"(run `tessctl render`)"
                            )
                        else:
                            print(
                                f"  LIVE DRIFT {badge}  {live_rel}  "
                                f"— live content differs from core "
                                f"(run `tessctl capture {live_rel}`)"
                            )
                    continue

        ok_count += 1

    print(f"\n{'='*60}")
    print(
        f"ok: {ok_count}  |  staged warns: {len(staged_warns)}  |  "
        f"core tampers: {len(core_tampers)}  |  "
        f"security drifts: {len(security_drifts)}  |  live drifts: {len(normal_drifts)}  |  "
        f"quarantined: {len(quarantined_files)}"
    )

    if core_tampers or security_drifts or normal_drifts or quarantined_files:
        print("\nverify: FAIL")
        if core_tampers:
            print(f"  {len(core_tampers)} core tamper(s) — restore .tess/core from git or `tessctl rollback`")
        if security_drifts:
            print(f"  {len(security_drifts)} security drift(s) — run `tessctl capture <path>` to quarantine")
        if normal_drifts:
            # LOW-1: split remedy by drift type — render-generated files need
            # `tessctl render`, hand-edited files need `tessctl capture <path>`.
            _rg = [p for p in normal_drifts if p in RENDER_GENERATED_LIVE_PATHS]
            _he = [p for p in normal_drifts if p not in RENDER_GENERATED_LIVE_PATHS]
            if _rg:
                print(f"  {len(_rg)} render-generated file(s) stale — run `tessctl render`")
            if _he:
                print(f"  {len(_he)} live drift(s) — live content differs from core; "
                      f"run `tessctl capture <path>`")
        if quarantined_files:
            print(f"  {len(quarantined_files)} quarantined file(s) — run `tessctl approve <path> --rationale ...`")
        sys.exit(1)
    else:
        warn_note = f"; {len(staged_warns)} staged warn(s) — un-recruitable entries" if staged_warns else ""
        print(f"\nverify: OK — core integrity confirmed; no security-tier tampering; live matches core{warn_note}")


# ---------------------------------------------------------------------------
# Command: approve (defect #1)
# ---------------------------------------------------------------------------

def cmd_approve(args, root: Path) -> None:
    """
    Accept a quarantined security-tier edit.

    This is the ONLY path by which a quarantined edit can go live.
    --rationale is REQUIRED: sys.exit(1) if missing or empty (fail-loud,
    per spec §6 + Karpathy fail-loud doctrine).

    Flow:
      1. Validate rationale is present and non-empty.
      2. Read the quarantined file from .tess/quarantine/<live_rel>.
      3. Copy it to live_path.
      4. Flip status → locally-modified (now a normal merge candidate).
      5. Record approval event in modified.json.
    """
    target_path = getattr(args, "path", None)
    rationale = (getattr(args, "rationale", "") or "").strip()

    if not target_path:
        sys.exit("tessctl approve: specify a <path>")

    # Rationale hard-required (fail-loud, no default, no bypass)
    if not rationale:
        sys.exit(
            "tessctl approve: --rationale is REQUIRED and must be non-empty.\n"
            "  This is the the operator-authorization gate for security-tier edits.\n"
            "  Provide a specific reason why this change to security doctrine is acceptable."
        )

    lock = load_lock(root)
    files = lock.get("files", {})

    # Find the entry
    core_key = None
    live_rel = None
    for k, a in files.items():
        if a.get("live_path") == target_path or k == target_path:
            core_key = k
            live_rel = a.get("live_path", target_path)
            break

    if not core_key:
        sys.exit(f"tessctl approve: path not found in tess.lock: {target_path}")

    attrs = files[core_key]
    if attrs.get("status") != "quarantined":
        print(f"tessctl approve: {live_rel} is not quarantined (status: {attrs.get('status')})")
        print("  Only quarantined files require approval.")
        sys.exit(1)

    q_path = root / QUARANTINE_DIR / live_rel
    live_path = root / live_rel

    if not q_path.exists():
        sys.exit(
            f"tessctl approve: quarantined file not found at {QUARANTINE_DIR}/{live_rel}.\n"
            f"  The quarantine directory may have been deleted.  Cannot approve without it."
        )

    # Apply the quarantined edit to live (H2/M3: manifest-gated + atomic)
    guarded_write(root, live_rel, q_path.read_bytes(), op="approve")

    # Flip status to locally-modified (normal merge candidate going forward)
    lock["files"][core_key]["status"] = "locally-modified"
    lock["files"][core_key]["approved_at"] = datetime.datetime.now(
        datetime.timezone.utc
    ).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z"
    lock["files"][core_key]["approved_rationale"] = rationale
    lock["files"][core_key].pop("quarantined_at", None)
    lock["files"][core_key].pop("quarantined_by", None)

    # Record approval in modified.json
    diff_text = ""
    core_path = root / core_key
    if core_path.exists():
        expected_bytes = render_core_to_live(core_path, live_path, root)
        with tempfile.NamedTemporaryFile(mode="wb", suffix=".base", delete=False) as fb:
            fb.write(expected_bytes)
            base_tmp = fb.name
        try:
            res = subprocess.run(
                ["diff", "-u", "--label", f"core/{core_key}", "--label", f"live/{live_rel}",
                 base_tmp, str(live_path)],
                capture_output=True, text=True
            )
            diff_text = res.stdout
        finally:
            os.unlink(base_tmp)

    record_capture_event(
        root, core_key, live_rel,
        source="tessctl-approve",
        diff_text=diff_text,
        rationale=f"APPROVED: {rationale}"
    )
    save_lock(root, lock)

    print(f"tessctl approve: {live_rel} approved.")
    print(f"  rationale: {rationale}")
    print(f"  status: quarantined → locally-modified")
    print(f"  quarantined file retained at {QUARANTINE_DIR}/{live_rel} for audit trail.")
    print(f"  Run `tessctl doctor` to confirm clean state.")


# ---------------------------------------------------------------------------
# Command: resolve (defect #7)
# ---------------------------------------------------------------------------

def cmd_resolve(args, root: Path) -> None:
    """
    Resolve a file that has conflict markers (from tessctl update collision).

    Modes:
      --ours     accept the local version (discard incoming upstream changes)
      --theirs   accept the incoming upstream version from .tess/conflicts/
      --edit     open $EDITOR on the conflict file (default if no flag given)

    After resolution: clears markers, re-pins base_sha in tess.lock.
    If no mode given and EDITOR is not set, instruct the user.
    """
    target_path = getattr(args, "path", None)
    accept_ours = getattr(args, "ours", False)
    accept_theirs = getattr(args, "theirs", False)
    open_editor = getattr(args, "edit", False)

    if not target_path:
        sys.exit("tessctl resolve: specify a <path>")

    lock = load_lock(root)
    files = lock.get("files", {})

    core_key = None
    live_rel = None
    for k, a in files.items():
        if a.get("live_path") == target_path or k == target_path:
            core_key = k
            live_rel = a.get("live_path", target_path)
            break

    if not core_key:
        sys.exit(f"tessctl resolve: path not found in tess.lock: {target_path}")

    manifest = load_manifest(root)   # H1: needed for guarded_write in --edit path
    live_path = root / live_rel
    conflict_dir = root / ".tess" / "conflicts"
    conflict_file = conflict_dir / live_rel.replace("/", "_")

    if accept_ours:
        # Keep the live file as-is; just mark as locally-modified
        if live_path.exists():
            # Verify no remaining conflict markers (LOW: anchored regex to avoid
            # false-trigger on 7+ '=' setext heading underlines in markdown)
            content = live_path.read_text(encoding="utf-8", errors="replace")
            if re.search(r'^<{7} |^={7}\s*$|^>{7} ', content, re.MULTILINE):
                print(f"  WARN  {live_rel} still contains conflict markers — edit first.")
                sys.exit(1)
        lock["files"][core_key]["status"] = "locally-modified"
        lock["files"][core_key]["resolved_at"] = datetime.datetime.now(
            datetime.timezone.utc
        ).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z"
        lock["files"][core_key]["resolved_mode"] = "ours"
        save_lock(root, lock)
        # Remove from conflicts dir
        if conflict_file.exists():
            conflict_file.unlink()
        print(f"tessctl resolve: {live_rel} resolved (kept ours). status → locally-modified.")

    elif accept_theirs:
        if not conflict_file.exists():
            sys.exit(
                f"tessctl resolve: conflict file not found at {conflict_file}.\n"
                f"  Cannot accept theirs without the incoming version."
            )
        # Overwrite live with the conflict/incoming version (H2/M3: gated + atomic)
        guarded_write(root, live_rel, conflict_file.read_bytes(), op="resolve-theirs")
        lock["files"][core_key]["status"] = "core-managed"
        lock["files"][core_key]["resolved_at"] = datetime.datetime.now(
            datetime.timezone.utc
        ).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z"
        lock["files"][core_key]["resolved_mode"] = "theirs"
        # H1: re-pin base_sha to current core bytes so verify/doctor see pristine
        _core_path = root / core_key
        if _core_path.exists():
            lock["files"][core_key]["base_sha"] = sha256_file(_core_path)
        save_lock(root, lock)
        conflict_file.unlink()
        print(f"tessctl resolve: {live_rel} resolved (accepted theirs). status → core-managed.")

    elif open_editor or (not accept_ours and not accept_theirs):
        # Open editor on the conflict file (or the live file if no conflict copy)
        editor = os.environ.get("EDITOR", os.environ.get("VISUAL", ""))
        edit_target = str(conflict_file) if conflict_file.exists() else str(live_path)

        if not editor:
            print(
                f"tessctl resolve: no mode specified and $EDITOR is not set.\n\n"
                f"  Manual options:\n"
                f"    tessctl resolve {live_rel} --ours      # keep your local version\n"
                f"    tessctl resolve {live_rel} --theirs    # accept incoming upstream\n"
                f"    EDITOR=vim tessctl resolve {live_rel} --edit  # open in editor\n\n"
                f"  Conflict file: {edit_target}\n"
                f"  After editing, re-run: tessctl resolve {live_rel} --ours"
            )
            sys.exit(1)

        print(f"tessctl resolve: opening {edit_target} in {editor} …")
        ret = subprocess.call([editor, edit_target])
        if ret != 0:
            sys.exit(f"tessctl resolve: editor exited with code {ret}")
        # H1 fix: replace ungated shutil.copy2 with manifest-gated atomic write
        if conflict_file.exists():
            guarded_write(root, live_rel, conflict_file.read_bytes(),
                          op="resolve-edit", manifest=manifest)
        # Verify no remaining markers (LOW: anchored regex)
        if live_path.exists():
            content = live_path.read_text(encoding="utf-8", errors="replace")
            if re.search(r'^<{7} |^={7}\s*$|^>{7} ', content, re.MULTILINE):
                print(f"  WARN  {live_rel} still contains conflict markers after editing.")
                print(f"  Re-edit and run `tessctl resolve {live_rel} --ours` when clean.")
                sys.exit(1)
        lock["files"][core_key]["status"] = "locally-modified"
        lock["files"][core_key]["resolved_at"] = datetime.datetime.now(
            datetime.timezone.utc
        ).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z"
        lock["files"][core_key]["resolved_mode"] = "edited"
        save_lock(root, lock)
        if conflict_file.exists():
            conflict_file.unlink()
        print(f"tessctl resolve: {live_rel} resolved (edited). status → locally-modified.")


# ---------------------------------------------------------------------------
# Command: reset (M1)
# ---------------------------------------------------------------------------

def cmd_reset(args, root: Path) -> None:
    """
    Discard a captured/locally-modified edit — restore the file from core
    and re-pin the lock entry to pristine (status → core-managed).

    This is the EXPLICIT discard path.  tessctl restore intentionally refuses
    to silently overwrite locally-modified files; tessctl reset is the operator's
    deliberate opt-in.  A single-file snapshot is taken before discarding so
    the edit is always recoverable via tessctl rollback --to <ts>.
    """
    target_path = getattr(args, "path", None)
    if not target_path:
        sys.exit("tessctl reset: specify a <path>")

    lock = load_lock(root)
    manifest = load_manifest(root)
    files = lock.get("files", {})

    core_key = None
    live_rel = None
    for k, a in files.items():
        if a.get("live_path") == target_path or k == target_path:
            core_key = k
            live_rel = a.get("live_path", target_path)
            break

    if not core_key:
        sys.exit(f"tessctl reset: path not found in tess.lock: {target_path}")

    attrs = files[core_key]
    status = attrs.get("status", "core-managed")

    if status not in ("locally-modified", "core-managed"):
        sys.exit(
            f"tessctl reset: {live_rel} has status {status!r} — reset only applies to\n"
            f"  locally-modified files (or already-pristine core-managed files).\n"
            f"  For quarantined: use `tessctl approve` or restore manually.\n"
            f"  For user-published: use `tessctl publish --force {live_rel}` to re-seed from core."
        )

    core_path = root / core_key
    live_path = root / live_rel

    if not core_path.exists():
        sys.exit(f"tessctl reset: core file not found: {core_key}")

    rendered = render_core_to_live(core_path, live_path, root)

    # Snapshot the current live file before discarding (always recoverable).
    # LOW fix: snapshot_single_file now returns the ts (directory name), not the
    # full file path — rollback --to wants the directory name, not the file path.
    if live_path.exists():
        snap_ts = snapshot_single_file(root, live_rel)
        snap_file = root / SNAPSHOTS_DIR / snap_ts / live_rel
        print(f"  snapshot of current edit saved to: {snap_file}")
        print(f"  To undo this reset: tessctl rollback --to {snap_ts}")
        print(f"  Then run: tessctl capture   (re-records the drift so doctor stays clean)")

    # Restore from core — manifest-gated + atomic (H2/M3)
    guarded_write(root, live_rel, rendered, op="reset", manifest=manifest)

    # Re-pin lock to pristine
    lock["files"][core_key]["status"] = "core-managed"
    lock["files"][core_key]["base_sha"] = sha256_file(core_path)
    for field in ("captured_at", "captured_by", "override_diff", "override_recorded_at"):
        lock["files"][core_key].pop(field, None)

    save_lock(root, lock)
    print(f"tessctl reset: {live_rel} restored from core. status → core-managed.")
    print(f"  Run `tessctl doctor` to verify.")


# ---------------------------------------------------------------------------
# Command: lock (M1 — CI gate)
# ---------------------------------------------------------------------------

def _lock_regen(args, root: Path) -> None:
    """
    MAINTAINER re-baseline.  Re-pin every lock entry's base_sha to the sha256
    of the CURRENT .tess/core/<core_key> bytes, re-baselining integrity to
    whatever core is right now.

    Use ONLY after a deliberate, reviewed change to .tess/core (e.g. a
    de-identification scrub that intentionally altered core bytes).  This verb
    "blesses" the present core as pristine, so doctor/verify will report 0 core
    tampers afterward — INCLUDING any change you did not intend.  It is gated
    behind --yes (non-interactive) or an interactive y/N confirmation.
    """
    print(
        "WARNING: `tessctl lock --regen` RE-BASELINES integrity to the CURRENT "
        ".tess/core bytes.\n"
        "         Every base_sha in tess.lock will be re-pinned to whatever core "
        "is right now.\n"
        "         doctor/verify will then report core as pristine — this blesses "
        "the present\n"
        "         core, including any unintended change. Run ONLY after a "
        "deliberate, reviewed\n"
        "         change to .tess/core."
    )

    if not getattr(args, "yes", False):
        if not sys.stdin.isatty():
            sys.exit(
                "tessctl lock --regen: refused — re-baselining integrity is a "
                "maintainer action.\n"
                "  Re-run with --yes to confirm, e.g. `tessctl lock --regen --yes`."
            )
        try:
            reply = input("Re-baseline tess.lock to current core? [y/N] ").strip().lower()
        except EOFError:
            reply = ""
        if reply not in ("y", "yes"):
            print("tessctl lock --regen: aborted (no confirmation).")
            sys.exit(1)

    lock = load_lock(root)
    files = lock.get("files", {})
    total = repinned = missing = 0
    for core_key, attrs in files.items():
        total += 1
        core_path = root / core_key
        if not core_path.exists():
            missing += 1
            continue
        new_sha = sha256_file(core_path)
        if attrs.get("base_sha") != new_sha:
            lock["files"][core_key]["base_sha"] = new_sha
            repinned += 1

    lock.setdefault("framework", {})["last_updated"] = datetime.datetime.now(
        datetime.timezone.utc
    ).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z"
    save_lock(root, lock)

    print(
        f"tessctl lock --regen: re-baselined {total} entr"
        f"{'y' if total == 1 else 'ies'} to current core "
        f"({repinned} base_sha changed, {missing} core file(s) missing)."
    )
    sys.exit(0)


def cmd_lock(args, root: Path) -> None:
    """
    Lock file operations.

    --check: strict CI gate — exits non-zero if any core tamper, uncaptured
             drift, or quarantined file is found.  Equivalent to running
             `tessctl doctor` in fail-fast mode.  Reference this in CI
             instead of relying on exit codes from the more verbose `doctor`.

    --regen: MAINTAINER re-baseline — re-pin every base_sha to sha256 of the
             current .tess/core/<core_key> file, blessing the present core as
             pristine.  Use ONLY after a deliberate, reviewed change to core.
             Gated behind --yes or an interactive y/N prompt; prints a clear
             warning that it re-baselines integrity to current core.
    """
    check = getattr(args, "check", False)
    regen = getattr(args, "regen", False)

    if regen:
        _lock_regen(args, root)
        return

    if not check:
        sys.exit(
            "tessctl lock: no operation specified.\n"
            "  Use `tessctl lock --check` for the CI integrity gate,\n"
            "  use `tessctl lock --regen --yes` to re-baseline base_sha to current core (MAINTAINER),\n"
            "  or `tessctl verify` for a full security audit."
        )

    lock = load_lock(root)
    files = lock.get("files", {})
    issues = []

    for core_key, attrs in files.items():
        live_rel = attrs.get("live_path")
        if not live_rel:
            continue
        r = doctor_check_file(core_key, attrs, root)
        status = r.get("lock_status", "core-managed")
        if r.get("core_tamper"):
            issues.append(("CORE-TAMPER", live_rel))
        elif status == "quarantined":
            issues.append(("QUARANTINED", live_rel))
        elif r.get("drift") and status == "core-managed":
            issues.append(("DRIFT", live_rel))

    if issues:
        print(f"tessctl lock --check: FAIL — {len(issues)} issue(s)")
        for kind, path in issues:
            print(f"  {kind:12}  {path}")
        sys.exit(1)
    else:
        total = sum(1 for a in files.values() if a.get("live_path"))
        print(f"tessctl lock --check: OK — {total} managed files verified")
        sys.exit(0)


# ---------------------------------------------------------------------------
# Command: self-update
# ---------------------------------------------------------------------------

def cmd_self_update(args, root: Path) -> None:
    """
    Update the tessctl engine itself (.tess/bin/tessctl + engine files).

    .tess/** is intentionally OUTSIDE owned_globs so the normal update/restore
    pipeline cannot touch it.  self-update is the deliberate, operator-gated
    path for engine upgrades.

    Flow:
      1. Resolve target ref (--ref > --to > framework.upstream_ref).
      2. Clone upstream at ref into a temporary directory.
      3. Verify the tag signature (same signed-tag rules as fetch_to_staging).
         Unsigned or wrong-key tags are rejected with no changes made.
      4. AST-parse the new engine to catch corrupt/incomplete downloads before
         touching the live engine.
      5. Backup current engine to .tess/bin/tessctl.bak.
      6. Atomically replace .tess/bin/tessctl with the new engine.
      7. Run `doctor` with the new engine.  On any engine-level error
         (SyntaxError, import crash, missing __main__): rollback to backup.
      8. Update tess.lock upstream_ref if the ref changed.

    The backup (.tess/bin/tessctl.bak) is retained after success so the
    operator can manually restore it.  It is overwritten on every self-update.
    """
    _check_tools("git")

    lock = load_lock(root)
    fw = lock.get("framework", {})
    upstream = fw.get("upstream", "").strip()
    trusted_fingerprint = (fw.get("trusted_key_fingerprint") or "").strip()

    if not upstream:
        sys.exit(
            "tessctl self-update: upstream not configured in tess.lock (framework.upstream).\n"
            "  Set framework.upstream to the git repository URL and retry."
        )

    ref = _resolve_update_ref(args, lock)
    engine_path = root / ".tess" / "bin" / "tessctl"
    backup_path = engine_path.with_suffix(".bak")

    print(f"tessctl self-update — engine: {engine_path}")
    print(f"  ref: {ref}")

    with tempfile.TemporaryDirectory(prefix="tessctl_selfupdate_") as tmpdir:
        clone_dir = Path(tmpdir) / "clone"

        # -- Step 1: clone + verify signed tag (same security model as fetch_to_staging) --
        print("\nStep 1: verify-signed fetch …")
        print(f"  cloning {ref!r} from {upstream} …")
        r = subprocess.run(
            ["git", "clone", "--depth", "1", "--branch", ref,
             "--no-tags", upstream, str(clone_dir)],
            capture_output=True, text=True
        )
        if r.returncode != 0:
            sys.exit(
                f"tessctl self-update: clone failed:\n  {r.stderr.strip()}"
            )

        # Fetch annotated tag object explicitly
        subprocess.run(
            ["git", "fetch", "--depth=1", "origin",
             f"refs/tags/{ref}:refs/tags/{ref}"],
            capture_output=True, text=True, cwd=str(clone_dir)
        )

        # C4: verify ref is an annotated tag object
        cat_type_r = subprocess.run(
            ["git", "cat-file", "-t", ref],
            capture_output=True, text=True, cwd=str(clone_dir)
        )
        if cat_type_r.returncode != 0 or cat_type_r.stdout.strip() != "tag":
            sys.exit(
                f"tessctl self-update: SECURITY REJECT — ref {ref!r} resolves to "
                f"'{cat_type_r.stdout.strip()}', not an annotated tag object (C4).\n"
                f"  Current engine is unchanged."
            )

        # Signature verification — mandatory pinning + TOFU + isolated GNUPGHOME
        print(f"  verifying signature on {ref!r} …")
        _allow_tofu_su = getattr(args, "trust_on_first_use", False)
        _signing_fp, _tofu = _verify_tag_secure(
            ref, str(clone_dir), trusted_fingerprint or None, root, lock,
            allow_tofu=_allow_tofu_su,
        )
        if _tofu:
            trusted_fingerprint = _signing_fp
            fw["trusted_key_fingerprint"] = _signing_fp

        # -- Step 2: locate new engine in clone --
        new_engine_path = clone_dir / ".tess" / "bin" / "tessctl"
        if not new_engine_path.exists():
            sys.exit(
                f"tessctl self-update: .tess/bin/tessctl not found in upstream at {ref!r}.\n"
                f"  The upstream may not have a compatible engine layout.\n"
                f"  Current engine is unchanged."
            )
        new_engine_bytes = new_engine_path.read_bytes()

        # -- Step 3: AST parse-check before touching the live engine --
        print("\nStep 2: parse-check new engine …")
        parse_result = subprocess.run(
            [sys.executable, "-c",
             "import ast, sys; ast.parse(open(sys.argv[1]).read()); print('parse OK')",
             str(new_engine_path)],
            capture_output=True, text=True
        )
        if parse_result.returncode != 0:
            sys.exit(
                f"tessctl self-update: ABORT — new engine fails AST parse:\n"
                f"  {parse_result.stderr.strip()}\n"
                f"  Current engine is unchanged."
            )
        print(f"  {parse_result.stdout.strip()}")

        # -- Step 4: backup current engine + capture original mode (D2) --
        print("\nStep 3: backup …")
        # D2: capture mode BEFORE replacement so we restore it, not mkstemp's 0600 → 0711
        orig_engine_mode: int | None = None
        if engine_path.exists():
            try:
                orig_engine_mode = stat.S_IMODE(engine_path.stat().st_mode)
            except OSError:
                pass
            shutil.copy2(engine_path, backup_path)
            print(f"  backup → {backup_path}")
        else:
            print(f"  (no existing engine to backup)")

        # -- Step 5: atomically replace engine --
        print("\nStep 4: install …")
        engine_path.parent.mkdir(parents=True, exist_ok=True)
        tmp_fd, tmp_path_str = tempfile.mkstemp(
            dir=str(engine_path.parent), prefix=".tessctl_selfupdate_"
        )
        try:
            with os.fdopen(tmp_fd, "wb") as fh:
                fh.write(new_engine_bytes)
            os.replace(tmp_path_str, str(engine_path))
        except Exception as exc:
            try:
                os.unlink(tmp_path_str)
            except OSError:
                pass
            # Rollback
            if backup_path.exists():
                shutil.copy2(backup_path, engine_path)
                print(f"  rolled back to backup after install failure")
            sys.exit(f"tessctl self-update: installation failed: {exc}")

        # D2: restore original mode (or 0o755 if engine was absent), always ensure exec bit
        try:
            final_mode = (orig_engine_mode | 0o111) if orig_engine_mode is not None else 0o755
            os.chmod(str(engine_path), final_mode)
        except OSError:
            pass
        print(f"  installed: {engine_path}")

        # -- Step 6: verify new engine — run doctor with it --
        print("\nStep 5: verify new engine (doctor) …")
        verify_run = subprocess.run(
            [sys.executable, str(engine_path), "doctor"],
            capture_output=True, text=True,
            cwd=str(root), env={**os.environ, "TESS_ROOT": str(root)}
        )
        # D1: gate on exit code only. doctor exits 0 (all OK) or 1 (drift/issues found —
        # engine is functional). Any code outside {0, 1} is an engine-level crash
        # (SyntaxError, ImportError, unhandled exception) — rollback unconditionally.
        if verify_run.returncode not in (0, 1):
            print(
                f"  FAIL — new engine crashed (exit code {verify_run.returncode}):\n"
                f"  {verify_run.stderr.strip()}"
            )
            # Rollback
            if backup_path.exists():
                shutil.copy2(backup_path, engine_path)
                print(f"  rolled back to backup")
            sys.exit("tessctl self-update: new engine failed verification — rolled back.")
        print(f"  verification: OK (doctor ran cleanly; exit code {verify_run.returncode})")

    # -- Step 7: update tess.lock if ref changed --
    if fw.get("upstream_ref") != ref:
        lock["framework"]["upstream_ref"] = ref
        lock["framework"]["last_updated"] = datetime.datetime.now(
            datetime.timezone.utc
        ).strftime("%Y-%m-%dT%H:%M:%S.%f") + "Z"
        save_lock(root, lock)
        print(f"\n  tess.lock: upstream_ref updated to {ref}")

    print(f"\ntessctl self-update: complete — engine updated to {ref}")
    if backup_path.exists():
        print(f"  Previous engine retained at: {backup_path}")
        print(f"  To rollback manually: cp {backup_path} {engine_path}")


# ---------------------------------------------------------------------------
# Roster helpers — curated-squad mechanism
# ---------------------------------------------------------------------------

def _load_roster_paths(root: Path) -> dict:
    """
    Load .tess/core/roster-paths.json — the squad config.
    Keys: universal_base (list), paths (dict of path_name → {squad, orchestrators}).
    """
    rp_path = root / ROSTER_PATHS_FILE
    if not rp_path.exists():
        sys.exit(
            f"tessctl: {ROSTER_PATHS_FILE} not found.\n"
            f"  This file defines the starter-squad install sets. "
            f"Ensure the core is complete (tessctl init or git checkout)."
        )
    try:
        return json.loads(rp_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        sys.exit(f"tessctl: {ROSTER_PATHS_FILE} is invalid JSON: {e}")


def _agent_name_from_key(core_key: str) -> str:
    """
    Extract agent name from a core_key like '.tess/core/agents-dispatch/ada.md'.
    Returns 'ada' (strips directory prefix and .md suffix).
    """
    return Path(core_key).stem


def _agent_keys_by_name(lock: dict) -> dict:
    """
    Return a dict mapping agent-name → core_key for all agents-dispatch entries.
    E.g., 'ada' → '.tess/core/agents-dispatch/ada.md'.
    Only entries with a live_path are included (dispatchable agents).
    """
    mapping = {}
    for core_key, attrs in lock.get("files", {}).items():
        if "agents-dispatch/" in core_key and attrs.get("live_path"):
            name = _agent_name_from_key(core_key)
            mapping[name] = core_key
    return mapping


def _roster_install_set(roster_data: dict, path_name: str) -> set:
    """
    Build the complete install set for a given STARTER_PATH.
    Returns a set of agent names (without .md suffix): squad + universal_base + orchestrators.
    """
    universal_base = set(roster_data.get("universal_base", []))
    paths = roster_data.get("paths", {})
    if path_name not in paths:
        valid = ", ".join(sorted(paths.keys()))
        sys.exit(
            f"tessctl roster: unknown path {path_name!r}.\n"
            f"  Valid paths: {valid}"
        )
    path_cfg = paths[path_name]
    squad = set(path_cfg.get("squad", []))
    orchestrators = set(path_cfg.get("orchestrators", []))
    return universal_base | squad | orchestrators


def guarded_remove(root: Path, live_rel: str, manifest: dict = None) -> bool:
    """
    Manifest-gated live file removal (companion to guarded_write).
    Checks owned_globs allowlist before deleting — never touches never_touch or .git.
    Returns True if the file was removed, False if skipped (not found or gate refused).
    """
    if manifest is None:
        manifest = load_manifest(root)
    try:
        norm_rel = check_manifest_write_gate(root, manifest, live_rel, op="remove")
    except GateError as e:
        print(f"  WARN  remove refused (gate): {e}")
        return False
    live_path = root / norm_rel
    if live_path.exists():
        live_path.unlink()
        return True
    return False


def _resolve_agent_names(names: list, by_name: dict, roster_data: dict) -> tuple[set, list]:
    """
    Shared resolver used by BOTH recruit and bench.

    Tries (in order): exact agent name → name + '-orchestrator' shorthand →
    path-group expansion (path name → squad + orchestrators, DELIBERATELY
    EXCLUDING universal_base so leah/eva can never be benched or over-recruited
    via a group label).

    Returns (resolved: set[str], not_found: list[str]).
    """
    resolved = set()
    not_found = []
    for name in names:
        n = name.strip().lower()
        if n in by_name:
            resolved.add(n)
        elif n + "-orchestrator" in by_name:
            resolved.add(n + "-orchestrator")
        elif n in roster_data.get("paths", {}):
            # Path-group expansion: squad + orchestrators only — universal_base excluded
            path_cfg = roster_data["paths"][n]
            resolved.update(path_cfg.get("squad", []))
            resolved.update(path_cfg.get("orchestrators", []))
        else:
            not_found.append(name)
    return resolved, not_found


# ---------------------------------------------------------------------------
# Command: roster  (roster apply <path>  |  roster list)
# ---------------------------------------------------------------------------

def cmd_roster(args, root: Path) -> None:
    """
    tess roster apply <founders|builders|operators>
        Install squad+base for the path (status → core-managed + write live file).
        Set everything else to staged (status → staged + remove live file). Idempotent.

    tess roster list
        Show installed vs staged agent counts + listing.
    """
    subcmd = getattr(args, "roster_sub", None)
    if subcmd == "apply":
        _roster_apply(args, root)
    elif subcmd == "list":
        _roster_list(args, root)
    else:
        sys.exit(
            "tessctl roster: specify a subcommand.\n"
            "  tessctl roster apply founders|builders|operators\n"
            "  tessctl roster list"
        )


def _roster_apply(args, root: Path) -> None:
    """
    Install the chosen squad+universal-base to live; stage everything else.

    For each agents-dispatch entry in tess.lock:
      - agent in install_set → status = core-managed + write live file
      - agent NOT in install_set → status = staged + remove live file
    Idempotent: re-running with the same path is a no-op.
    """
    path_name = getattr(args, "path_name", None)
    if not path_name:
        sys.exit("tessctl roster apply: specify a path (founders | builders | operators)")

    roster_data = _load_roster_paths(root)
    install_set = _roster_install_set(roster_data, path_name)

    lock = load_lock(root)
    manifest = load_manifest(root)
    by_name = _agent_keys_by_name(lock)

    installed: list[str] = []
    staged_list: list[str] = []
    gate_skipped: list[str] = []

    for agent_name in sorted(by_name.keys()):
        core_key = by_name[agent_name]
        attrs = lock["files"][core_key]
        live_rel = attrs.get("live_path")
        if not live_rel:
            continue

        if agent_name in install_set:
            # Install: write live file first, THEN set status to core-managed.
            # Status is set only after guarded_write succeeds so a gate failure
            # or missing core never leaves a false core-managed status in the lock.
            core_path = root / core_key
            live_path = root / live_rel
            if not core_path.exists():
                # WARN: un-recruitable without a core file; skip silently in count.
                print(f"  WARN  core missing for {agent_name}: {core_key}")
                continue
            rendered = render_core_to_live(core_path, live_path, root)
            if not live_path.exists() or live_path.read_bytes() != rendered:
                try:
                    guarded_write(root, live_rel, rendered, op="roster-apply", manifest=manifest)
                except GateError as e:
                    gate_skipped.append(agent_name)
                    print(f"  WARN  skipped {agent_name}: {e}")
                    continue
            # Write succeeded (or live already current) — now record in lock.
            lock["files"][core_key]["status"] = "core-managed"
            installed.append(agent_name)
        else:
            # Bench: staged + remove live file
            lock["files"][core_key]["status"] = "staged"
            live_path = root / live_rel
            if live_path.exists():
                try:
                    guarded_remove(root, live_rel, manifest=manifest)
                except GateError as e:
                    print(f"  WARN  remove skipped {agent_name}: {e}")
            staged_list.append(agent_name)

    save_lock(root, lock)

    print(f"\ntessctl roster apply [{path_name}]")
    print(f"  installed: {len(installed)}  staged: {len(staged_list)}  gate_skipped: {len(gate_skipped)}")
    print(f"  install set: {', '.join(sorted(install_set))}")
    if gate_skipped:
        print(f"  WARN — gate skipped: {', '.join(gate_skipped)}")
    print(f"\n  Run `tessctl doctor` to verify integrity.")


def _roster_list(args, root: Path) -> None:
    """Show installed vs staged agent counts + listing."""
    lock = load_lock(root)
    by_name = _agent_keys_by_name(lock)

    installed: list[str] = []
    staged_list: list[str] = []

    for agent_name in sorted(by_name.keys()):
        core_key = by_name[agent_name]
        attrs = lock["files"][core_key]
        status = attrs.get("status", "core-managed")
        if status == "staged":
            staged_list.append(agent_name)
        else:
            installed.append(agent_name)

    print(f"\ntessctl roster list")
    print(f"  installed ({len(installed)}):")
    if installed:
        # Print in columns (up to 5 per row)
        for i in range(0, len(installed), 5):
            chunk = installed[i:i+5]
            print("    " + "  ".join(chunk))
    else:
        print("    (none)")

    print(f"\n  staged / benched ({len(staged_list)}):")
    if staged_list:
        # Show first 30 + count
        preview = staged_list[:30]
        for i in range(0, len(preview), 5):
            chunk = preview[i:i+5]
            print("    " + "  ".join(chunk))
        if len(staged_list) > 30:
            print(f"    ... and {len(staged_list) - 30} more")
    else:
        print("    (none)")


# ---------------------------------------------------------------------------
# Command: recruit  (staged → core-managed + write live file)
# ---------------------------------------------------------------------------

def cmd_recruit(args, root: Path) -> None:
    """
    Move staged agent(s) from staged → core-managed and write their live file.

    Accepts:
      - Agent name (exact):         tessctl recruit vega
      - Orchestrator shorthand:     tessctl recruit revenue   (→ revenue-orchestrator)
      - Path-group expansion:       tessctl recruit founders  (→ squad + orchestrators)
      - Multiple names:             tessctl recruit vega cyra freya
    """
    names = getattr(args, "names", [])
    if not names:
        sys.exit("tessctl recruit: specify one or more agent names")

    lock = load_lock(root)
    manifest = load_manifest(root)
    by_name = _agent_keys_by_name(lock)
    roster_data = _load_roster_paths(root)

    to_recruit, not_found = _resolve_agent_names(names, by_name, roster_data)

    for name in not_found:
        print(f"  WARN  agent {name!r} not found in lock — skipped")

    if not to_recruit:
        sys.exit("tessctl recruit: no agents matched. Check agent name spelling.")

    recruited: list[str] = []
    already_installed: list[str] = []
    gate_skipped: list[str] = []

    for agent_name in sorted(to_recruit):
        core_key = by_name.get(agent_name)
        if not core_key:
            print(f"  WARN  {agent_name!r} not in lock — skipped")
            continue

        attrs = lock["files"][core_key]
        status = attrs.get("status", "core-managed")
        live_rel = attrs.get("live_path")
        if not live_rel:
            continue

        if status != "staged":
            already_installed.append(agent_name)
            continue

        core_path = root / core_key
        live_path = root / live_rel

        if not core_path.exists():
            print(f"  WARN  core missing for {agent_name}: {core_key} — skipped")
            continue

        rendered = render_core_to_live(core_path, live_path, root)
        try:
            guarded_write(root, live_rel, rendered, op="recruit", manifest=manifest)
            lock["files"][core_key]["status"] = "core-managed"
            recruited.append(agent_name)
        except GateError as e:
            gate_skipped.append(agent_name)
            print(f"  WARN  recruit {agent_name}: {e}")

    save_lock(root, lock)

    if recruited:
        print(f"tessctl recruit: installed {len(recruited)} agent(s): {', '.join(recruited)}")
    if already_installed:
        print(f"  already installed (no-op): {', '.join(already_installed)}")
    if gate_skipped:
        print(f"  gate skipped: {', '.join(gate_skipped)}")
    if not recruited and not already_installed:
        print("tessctl recruit: no agents recruited")
    else:
        print("  Run `tessctl doctor` to verify.")


# ---------------------------------------------------------------------------
# Command: bench  (core-managed → staged + remove live file)
# ---------------------------------------------------------------------------

def cmd_bench(args, root: Path) -> None:
    """
    Move installed agent(s) from core-managed → staged; remove their live file.

    Accepts: exact agent name / orchestrator shorthand (name + '-orchestrator') /
    path-group expansion (same resolution as recruit — squad + orchestrators,
    DELIBERATELY excluding universal_base so leah/eva cannot be benched via a group).
    Idempotent: benching an already-staged agent is a no-op.
    """
    names = getattr(args, "names", [])
    if not names:
        sys.exit("tessctl bench: specify one or more agent names")

    lock = load_lock(root)
    manifest = load_manifest(root)
    by_name = _agent_keys_by_name(lock)
    roster_data = _load_roster_paths(root)

    to_bench, not_found = _resolve_agent_names(names, by_name, roster_data)

    for name in not_found:
        print(f"  WARN  agent {name!r} not found — skipped")

    if not to_bench:
        sys.exit("tessctl bench: no agents matched. Check agent name spelling.")

    benched: list[str] = []
    already_staged: list[str] = []

    for agent_name in sorted(to_bench):
        core_key = by_name.get(agent_name)
        if not core_key:
            continue

        attrs = lock["files"][core_key]
        status = attrs.get("status", "core-managed")
        live_rel = attrs.get("live_path")
        if not live_rel:
            continue

        if status == "staged":
            already_staged.append(agent_name)
            continue

        # Remove live file
        live_path = root / live_rel
        if live_path.exists():
            guarded_remove(root, live_rel, manifest=manifest)

        lock["files"][core_key]["status"] = "staged"
        benched.append(agent_name)

    save_lock(root, lock)

    if benched:
        print(f"tessctl bench: staged {len(benched)} agent(s): {', '.join(benched)}")
    if already_staged:
        print(f"  already staged (no-op): {', '.join(already_staged)}")
    if not benched and not already_staged:
        print("tessctl bench: no agents benched")
    else:
        print("  Run `tessctl doctor` to verify.")


# ---------------------------------------------------------------------------
# Commands: identity, rename, set-operator, pathway  (M4/M6)
# ---------------------------------------------------------------------------

def _validate_name(name: str, context: str) -> str:
    """
    Validate a free-text operator or conductor name.

    Allowed: Unicode letters, digits, spaces, hyphens, apostrophes. 1–30 chars.
    Rejects control characters, YAML/markdown-breaking special chars (colon, hash,
    brackets, braces, backticks, pipes), and blank strings.

    Returns the stripped, validated name. sys.exit() on any violation (C5 spec rule).
    """
    import unicodedata
    name = name.strip()
    if not name:
        sys.exit(f"tessctl {context}: name must not be empty.")
    if len(name) > 30:
        sys.exit(
            f"tessctl {context}: name {name!r} exceeds 30 characters ({len(name)}).\n"
            f"  Maximum length is 30 characters."
        )
    _DISALLOWED = set(':[]{}#`|<>\\/"*?!')
    for ch in name:
        if ord(ch) < 0x20:  # control characters
            sys.exit(
                f"tessctl {context}: name {name!r} contains a control character "
                f"(U+{ord(ch):04X}). Control characters are not allowed."
            )
        if ch in _DISALLOWED:
            sys.exit(
                f"tessctl {context}: name {name!r} contains disallowed character {ch!r}.\n"
                f"  Allowed: letters, digits, spaces, hyphens (-), apostrophes (')."
            )
        cat = unicodedata.category(ch)
        if cat in ("Zs",):  # all space separators allowed
            continue
        if ch in (" ", "-", "'"):
            continue
        if cat[0] in ("L", "N"):  # letters and numbers
            continue
        sys.exit(
            f"tessctl {context}: name {name!r} contains unsupported character {ch!r} "
            f"(Unicode category {cat}).\n"
            f"  Allowed: letters, digits, spaces, hyphens (-), apostrophes (')."
        )
    return name


def cmd_identity(args, root: Path) -> None:
    """
    Show or set conductor identity + operator name (M6).

    Without flags: print current state.
    With --name / --operator: update profile.json and re-render.
    """
    profile = _load_operator_profile(root)
    name_arg = getattr(args, "assistant_name", None)
    operator_arg = getattr(args, "operator_name", None)

    changed = False
    if name_arg is not None:
        validated = _validate_name(name_arg, "identity --name")
        profile["assistant_name"] = validated
        changed = True
    if operator_arg is not None:
        validated = _validate_name(operator_arg, "identity --operator")
        profile["operator_name"] = validated
        changed = True

    if changed:
        _save_operator_profile(root, profile)
        print(
            f"tessctl identity: saved — "
            f"assistant_name={profile['assistant_name']!r}  "
            f"operator_name={profile['operator_name']!r}"
        )
        print("tessctl identity: re-rendering …")
        _do_render(root, verbose=True)
        print("tessctl identity: done. Run `tessctl doctor` to verify.")
    else:
        # Read-only: show current state
        print(f"\ntessctl identity — current operator state\n")
        print(f"  assistant_name : {profile['assistant_name']!r}")
        print(f"  operator_name  : {profile['operator_name']!r}")
        active_pw = profile["pathway"]
        print(f"  pathway        : {active_pw!r}  ({PATHWAY_LABELS.get(active_pw, '?')})")
        print(f"\n  Verbs:")
        print(f"    tessctl rename <name>          — set conductor name + re-render")
        print(f"    tessctl set-operator <name>    — set operator name + re-render")
        print(f"    tessctl identity --name X      — same as rename")
        print(f"    tessctl identity --operator X  — same as set-operator")
        print(f"    tessctl pathway <key>          — switch persona + re-render")
        print(f"    tessctl pathway list           — list all 5 pathways")


def cmd_rename(args, root: Path) -> None:
    """
    Set the conductor/assistant name and re-render (M6).
    tess rename <name>

    Updates operator/profile.json[assistant_name] and calls _do_render so that
    CLAUDE.md, conductor/identity.md, and conductor/personality.md all reflect
    the new name. doctor + verify remain green because both compare the rendered
    output from the same profile.json state.
    """
    name = getattr(args, "name", None)
    if not name:
        sys.exit(
            "tessctl rename: specify a name.\n"
            "  Usage: tessctl rename <name>"
        )
    validated = _validate_name(name, "rename")
    profile = _load_operator_profile(root)
    old_name = profile["assistant_name"]
    if old_name == validated:
        print(f"tessctl rename: no change — conductor name is already {validated!r}")
        return
    profile["assistant_name"] = validated
    _save_operator_profile(root, profile)
    print(f"tessctl rename: {old_name!r} → {validated!r}")
    print("tessctl rename: re-rendering …")
    _do_render(root, verbose=True)
    print(f"tessctl rename: done. Run `tessctl doctor` to verify.")


def cmd_set_operator(args, root: Path) -> None:
    """
    Set the operator's name and re-render (M6).
    tess set-operator <name>

    Updates operator/profile.json[operator_name] and re-renders so that
    persona arrival beats and any {{OPERATOR_NAME}} token sites reflect the name.
    """
    name = getattr(args, "name", None)
    if not name:
        sys.exit(
            "tessctl set-operator: specify a name.\n"
            "  Usage: tessctl set-operator <name>"
        )
    validated = _validate_name(name, "set-operator")
    profile = _load_operator_profile(root)
    old_name = profile["operator_name"]
    if old_name == validated:
        print(f"tessctl set-operator: no change — operator name is already {validated!r}")
        return
    profile["operator_name"] = validated
    _save_operator_profile(root, profile)
    print(f"tessctl set-operator: {old_name!r} → {validated!r}")
    print("tessctl set-operator: re-rendering …")
    _do_render(root, verbose=True)
    print(f"tessctl set-operator: done. Run `tessctl doctor` to verify.")


def cmd_pathway(args, root: Path) -> None:
    """
    Show or switch the conductor's communication pathway/persona (M4).

    tess pathway              — show current + list all options
    tess pathway list         — list all 5 pathways with descriptions
    tess pathway <key>        — switch to key + re-render personality.md

    The selected pathway is read from operator/profile.json[pathway] and
    rendered into conductor/personality.md via the {{PATHWAY}} token in the
    core template. Changing pathway calls _do_render — doctor stays green
    because it always compares against the freshly-rendered core output.
    """
    key = getattr(args, "key", None)

    if not key or key == "list":
        profile = _load_operator_profile(root)
        active = profile["pathway"]
        print(f"\ntessctl pathway — available pathways\n")
        for pw_key, label in PATHWAY_LABELS.items():
            marker = "* " if pw_key == active else "  "
            print(f"  {marker}{label}")
        print(f"\n  Active: {active!r}")
        print(f"  Switch: tessctl pathway <key>")
        return

    if key not in VALID_PATHWAYS:
        valid_list = " | ".join(sorted(VALID_PATHWAYS))
        sys.exit(
            f"tessctl pathway: unknown pathway {key!r}.\n"
            f"  Valid: {valid_list}\n"
            f"  Run `tessctl pathway list` to see descriptions."
        )

    profile = _load_operator_profile(root)
    old_pathway = profile["pathway"]
    if old_pathway == key:
        print(f"tessctl pathway: no change — pathway is already {key!r}")
        return
    profile["pathway"] = key
    _save_operator_profile(root, profile)
    print(f"tessctl pathway: {old_pathway!r} → {key!r}")
    print("tessctl pathway: re-rendering …")
    _do_render(root, verbose=True)
    print(f"tessctl pathway: done. Run `tessctl doctor` to verify.")


