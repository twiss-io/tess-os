# Copy this file to .env and fill in real values. NEVER commit .env.

# Telegram notification channel (create a bot via @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here
# Your private DM chat id (numeric) — where Tess sends you updates
TELEGRAM_DM_CHAT_ID=your-dm-chat-id-here

# Claude Code / Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: local timezone for the utc-local-context hook (IANA name, e.g. America/New_York). Defaults to UTC.
TESS_LOCAL_TZ=UTC
